</div>

<!-- ===== REFERRAL ===== -->
<div class="page" id="page-referral">
  <div class="pg-title">Referral Program</div>
  <div class="two-col" style="max-width:820px">
    <div class="card">
      <div class="ct">Your Referral Link</div>
      <div class="ref-box"><input type="text" id="refLinkInput" readonly/><button class="btn btn-p btn-sm" onclick="copyRef()">Copy</button></div>
      <div style="font-size:.7rem;color:var(--muted);margin-top:7px">Earn sponsor commission for every activated referral</div>
