  function bfs(uid,side,lvl){
    if(!uid||!ALLU[uid])return;
    const u=ALLU[uid];if(side==='left')lCnt++;else if(side==='right')rCnt++;
    downline.push({u,side,lvl});
    if(u.leftChild)bfs(u.leftChild,side||'left',lvl+1);
    if(u.rightChild)bfs(u.rightChild,side||'right',lvl+1);
  }
  if(lc)bfs(lc,'left',1);if(rc)bfs(rc,'right',1);
  set('tr-left',lCnt);set('tr-right',rCnt);
  set('tr-weak',lCnt<=rCnt?'Left':'Right');
  function nH(uid,lbl,isYou){
    if(!uid)return`<div style="display:flex;flex-direction:column;align-items:center"><div style="border:2px dashed var(--muted);border-radius:9px;padding:7px 11px;min-width:80px;text-align:center;opacity:.35;font-size:.7rem;color:var(--muted)">Empty<br><small>${lbl}</small></div></div>`;
    const n=ALLU[uid],nm=n?(n.fullName||n.username||uid.slice(0,8)):uid.slice(0,8),act=n?n.isActive:false;
    return`<div style="display:flex;flex-direction:column;align-items:center"><div style="border:2px solid ${isYou?'var(--accent)':act?'var(--green)':'var(--border)'};background:${isYou?'rgba(0,198,255,.08)':act?'rgba(16,185,129,.05)':'var(--card)'};border-radius:9px;padding:7px 11px;min-width:80px;text-align:center;font-size:.7rem"><div style="font-weight:800;font-size:.75rem;max-width:75px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${isYou?'👤 '+nm:nm}</div><div style="font-size:.6rem;color:var(--muted)">@${n?n.username:'?'}</div><span class="pill ${act?'pg':'py'}" style="margin-top:2px;font-size:.6rem">${act?'Act':'Inact'}</span><div style="font-size:.58rem;color:var(--muted);margin-top:1px">${lbl}</div></div></div>`;
  }
  function lvl2(uid){const n=uid?ALLU[uid]:null,l=n?n.leftChild:null,r=n?n.rightChild:null;return`<div style="display:flex;gap:12px">${nH(l,'L')}${nH(r,'R')}</div>`;}
  document.getElementById('treeView').innerHTML=`<div style="display:flex;flex-direction:column;align-items:center;gap:0;padding:8px">
    ${nH(CU.uid,'YOU',true)}
    <div style="width:1px;height:16px;background:${(lc||rc)?'var(--border)':'transparent'}"></div>
    <div style="width:${(lc||rc)?160:0}px;height:1px;background:${(lc||rc)?'var(--border)':'transparent'}"></div>
    <div style="display:flex;gap:28px">
      <div style="display:flex;flex-direction:column;align-items:center">${nH(lc,'LEFT')}${lc?`<div style="width:1px;height:12px;background:var(--border)"></div>${lvl2(lc)}`:''}</div>
      <div style="display:flex;flex-direction:column;align-items:center">${nH(rc,'RIGHT')}${rc?`<div style="width:1px;height:12px;background:var(--border)"></div>${lvl2(rc)}`:''}</div>
    </div>
  </div>`;
  document.getElementById('downlineTb').innerHTML=downline.length
    ?downline.map(({u,side,lvl})=>`<tr>
        <td style="font-weight:700">${u.fullName||'User'}</td>
        <td style="color:var(--muted)">@${u.username||'—'}</td>
        <td><span class="pill pb">Level ${lvl}</span></td>
        <td><span class="pill ${side==='left'?'pb':'pp'}">${side.toUpperCase()}</span></td>
        <td><span class="pill ${u.isActive?'pg':'py'}">${u.isActive?'Active':'Inactive'}</span></td>
        <td>${u.createdAt?(u.createdAt.toDate?u.createdAt.toDate().toLocaleDateString():new Date(u.createdAt).toLocaleDateString()):'—'}</td>
      </tr>`).join('')
    :'<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:14px">No downline yet</td></tr>';
}

