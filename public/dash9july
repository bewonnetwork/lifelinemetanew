  <div class="two-col">
    <div class="card">
      <div class="ct">All Income (Dynamic)</div>
      <div class="tw">
        <table class="inc-table">
          <thead><tr><th>Type</th><th>Amount</th><th>Status</th></tr></thead>
          <tbody id="incomeTable">
