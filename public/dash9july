  </div>
  <nav>
    <a class="active" onclick="showP('overview',this)"><span class="ic">🏠</span> Overview</a>
    <a onclick="showP('profile',this)"><span class="ic">👤</span> Profile</a>
    <a onclick="showP('referral',this)"><span class="ic">🔗</span> Referral</a>
    <a onclick="showP('tree',this)"><span class="ic">🌳</span> Binary Tree</a>
    <a onclick="showP('team',this)"><span class="ic">👥</span> My Team</a>
    <a onclick="showP('income',this)"><span class="ic">💰</span> Income (All)</a>
