<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Life Line Meta – Dashboard</title>
<style>
:root{
  --bg:#0b0f1a;--surface:#111827;--card:#1a2235;--border:#1e2d45;
  --accent:#00c6ff;--accent2:#7c3aed;--gold:#f59e0b;--green:#10b981;
  --red:#ef4444;--orange:#f97316;--text:#e2e8f0;--muted:#64748b;--radius:14px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
button{cursor:pointer;font-family:inherit}
input,select,textarea{font-family:inherit}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

/* SIDEBAR */
.sidebar{position:fixed;top:0;left:0;height:100vh;width:245px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:200;transition:transform .3s;overflow-y:auto}
.logo-area{padding:16px 16px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0}
.logo-img{width:40px;height:40px;border-radius:50%;object-fit:cover;border:2px solid var(--accent);flex-shrink:0}
.logo-text h2{font-size:.95rem;font-weight:900;background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.logo-text p{font-size:.6rem;color:var(--muted)}
nav{flex:1;padding:8px 0;overflow-y:auto}
nav a{display:flex;align-items:center;gap:9px;padding:9px 16px;font-size:.8rem;color:var(--muted);border-left:3px solid transparent;transition:.18s;cursor:pointer;user-select:none}
nav a:hover{color:var(--text);background:rgba(0,198,255,.05)}
nav a.active{color:var(--text);background:rgba(0,198,255,.07);border-left-color:var(--accent)}
nav a .ic{width:16px;text-align:center;font-size:.85rem;flex-shrink:0}
.sb-footer{padding:12px 16px;border-top:1px solid var(--border);flex-shrink:0}
.user-mini{display:flex;align-items:center;gap:9px}
.av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.82rem;color:#fff;flex-shrink:0}
.um-info strong{font-size:.78rem;display:block;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.um-info span{font-size:.64rem;color:var(--muted)}

/* NOTICE MARQUEE */
.notice-bar{background:linear-gradient(90deg,rgba(0,198,255,.1),rgba(124,58,237,.1));border-bottom:1px solid var(--border);padding:6px 0;overflow:hidden;position:fixed;top:54px;left:245px;right:0;z-index:98;transition:left .3s;display:none}
.notice-track{display:inline-block;animation:marquee 40s linear infinite;font-size:.74rem;padding:0 20px;white-space:nowrap}
.notice-track:hover{animation-play-state:paused;cursor:pointer}
@keyframes marquee{0%{transform:translateX(100vw)}100%{transform:translateX(-100%)}}
.nm-item{display:inline-block;margin-right:60px}
.nm-badge{font-size:.66rem;font-weight:700;padding:1px 6px;border-radius:8px;margin-right:5px}
.nb-info{background:rgba(0,198,255,.2);color:var(--accent)}
.nb-warn{background:rgba(245,158,11,.2);color:var(--gold)}
.nb-success{background:rgba(16,185,129,.2);color:var(--green)}
.nb-urgent{background:rgba(239,68,68,.2);color:var(--red);animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.5}}

/* TOPBAR */
.topbar{position:fixed;top:0;left:245px;right:0;height:54px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 18px;z-index:199;transition:left .3s}
.menu-btn{display:none;background:none;border:none;color:var(--text);font-size:1.3rem;padding:4px}
.pg-label{font-size:.85rem;font-weight:700;color:var(--muted)}
.tb-right{display:flex;align-items:center;gap:9px}
.theme-btn{background:none;border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:5px 11px;font-size:.74rem;cursor:pointer}

/* MAIN */
.main{margin-left:245px;padding-top:54px;min-height:100vh;transition:margin-left .3s}
.page{display:none;padding:18px}
.page.active{display:block}
.pg-title{font-size:1.2rem;font-weight:800;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}

/* BANNER */
.banner{border-radius:12px;padding:12px 15px;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.bw{background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.25)}
.br{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2)}
.bg2{background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2)}

/* CARDS */
.cg{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:12px;margin-bottom:16px}
.sc{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:15px;position:relative;overflow:hidden}
.sc::before{content:'';position:absolute;top:-18px;right:-18px;width:70px;height:70px;border-radius:50%;opacity:.07}
.cb::before{background:var(--accent)}.cp::before{background:var(--accent2)}.cg2::before{background:var(--gold)}.cgr::before{background:var(--green)}.cr::before{background:var(--red)}
.sl{font-size:.66rem;color:var(--muted);text-transform:uppercase;letter-spacing:.3px;margin-bottom:4px}
.sv{font-size:1.5rem;font-weight:800;margin-bottom:2px}
.cb .sv{color:var(--accent)}.cp .sv{color:var(--accent2)}.cg2 .sv{color:var(--gold)}.cgr .sv{color:var(--green)}.cr .sv{color:var(--red)}
.ss{font-size:.68rem;color:var(--muted)}
.si{position:absolute;bottom:11px;right:11px;font-size:1.3rem;opacity:.2}

/* PROG */
.prog{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:6px}
.prog-f{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:2px;transition:width .5s}

/* CARD */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:15px;margin-bottom:12px}
.ct{font-size:.85rem;font-weight:700;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}

/* TABLE */
.tw{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:.76rem}
th{color:var(--muted);font-weight:600;padding:7px 9px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap;font-size:.68rem;text-transform:uppercase}
td{padding:8px 9px;border-bottom:1px solid rgba(30,45,69,.4);white-space:nowrap;vertical-align:middle}
tr:hover td{background:rgba(0,198,255,.02)}
tr:last-child td{border-bottom:none}
.pill{display:inline-block;padding:2px 8px;border-radius:20px;font-size:.66rem;font-weight:700}
.pg{background:rgba(16,185,129,.15);color:var(--green)}
.py{background:rgba(245,158,11,.15);color:var(--gold)}
.pr{background:rgba(239,68,68,.15);color:var(--red)}
.pb{background:rgba(0,198,255,.15);color:var(--accent)}
.pp{background:rgba(124,58,237,.15);color:var(--accent2)}

/* BUTTONS */
.btn{padding:7px 15px;border-radius:9px;font-size:.78rem;font-weight:700;border:none;cursor:pointer;transition:.15s;white-space:nowrap}
.btn:hover{opacity:.85}
.btn-p{background:linear-gradient(90deg,var(--accent),var(--accent2));color:#fff}
.btn-g{background:linear-gradient(90deg,var(--gold),#d97706);color:#000}
.btn-gr{background:var(--green);color:#fff}
.btn-r{background:var(--red);color:#fff}
.btn-o{background:none;border:1px solid var(--border);color:var(--text)}
.btn-or{background:var(--orange);color:#fff}
.btn-sm{padding:3px 9px;font-size:.68rem}

/* FORM */
.fg{margin-bottom:12px}
.fg label{display:block;font-size:.72rem;color:var(--muted);margin-bottom:4px;font-weight:600}
.fg input,.fg select,.fg textarea{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:9px 11px;color:var(--text);font-size:.83rem;outline:none;transition:.2s}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--accent)}

/* REF BOX */
.ref-box{background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:10px 13px;display:flex;align-items:center;gap:9px}
.ref-box input{flex:1;background:none;border:none;color:var(--text);font-size:.78rem;outline:none}

/* INFO BOX */
.ib{background:rgba(0,198,255,.05);border:1px solid rgba(0,198,255,.14);border-radius:9px;padding:10px 13px;font-size:.75rem;color:var(--accent);margin-bottom:12px;line-height:1.7}
.wb{background:rgba(245,158,11,.05);border:1px solid rgba(245,158,11,.14);border-radius:9px;padding:10px 13px;font-size:.75rem;color:var(--gold);margin-bottom:12px;line-height:1.7}

/* TOGGLE */
.tog{position:relative;display:inline-block;width:36px;height:19px;flex-shrink:0}
.tog input{opacity:0;width:0;height:0}
.sldr{position:absolute;cursor:pointer;inset:0;background:var(--border);border-radius:20px;transition:.3s}
.sldr:before{content:'';position:absolute;height:13px;width:13px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.3s}
input:checked+.sldr{background:var(--green)}
input:checked+.sldr:before{transform:translateX(17px)}
.tw-row{display:flex;align-items:center;gap:9px;margin-bottom:9px}
.tw-lbl{font-size:.78rem;font-weight:600}

/* INCOME TABLE */
.inc-table{width:100%;border-collapse:collapse;font-size:.8rem}
.inc-table th{color:var(--muted);font-size:.68rem;text-transform:uppercase;padding:7px 10px;border-bottom:1px solid var(--border);text-align:left}
.inc-table td{padding:9px 10px;border-bottom:1px solid rgba(30,45,69,.3)}
.inc-table tr:last-child td{border-bottom:none}
.inc-table tr:hover td{background:rgba(0,198,255,.02)}

/* WEB3 */
.w3-btn{width:100%;padding:11px 16px;border-radius:10px;font-size:.82rem;font-weight:700;border:none;cursor:pointer;display:flex;align-items:center;gap:10px;transition:.2s;margin-bottom:9px}
.w3-btn:hover{transform:translateY(-1px);opacity:.9}
.w3-meta{background:linear-gradient(135deg,#f6851b,#e4761b);color:#fff}
.w3-trust{background:linear-gradient(135deg,#3375bb,#0070e0);color:#fff}
.w3-wc{background:linear-gradient(135deg,#3b99fc,#1c6ed4);color:#fff}
.w3-addr-box{background:var(--bg);border:1px solid var(--green);border-radius:10px;padding:11px 14px;display:flex;align-items:center;gap:10px;margin-bottom:12px}
.w3-addr{font-family:monospace;font-size:.72rem;color:var(--green);word-break:break-all}

/* OTP / 2FA */
.otp-input{display:flex;gap:8px;justify-content:center;margin:12px 0}
.otp-input input{width:42px;height:48px;text-align:center;font-size:1.3rem;font-weight:800;background:var(--bg);border:2px solid var(--border);border-radius:10px;color:var(--text);outline:none;transition:.2s}
.otp-input input:focus{border-color:var(--accent)}

/* KYC */
.kyc-step{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:10px;display:flex;align-items:center;gap:12px}
.kyc-step .step-num{width:30px;height:30px;border-radius:50%;background:var(--accent2);display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:800;color:#fff;flex-shrink:0}
.kyc-status-badge{padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700}

/* OVERLAY & TOAST */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:199}
.overlay.show{display:block}
.toast{position:fixed;bottom:18px;right:18px;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 16px;font-size:.79rem;z-index:9999;opacity:0;transform:translateY(12px);transition:.3s;pointer-events:none;max-width:270px}
.toast.show{opacity:1;transform:translateY(0)}

body.light{--bg:#f1f5f9;--surface:#fff;--card:#f8fafc;--border:#e2e8f0;--text:#1e293b;--muted:#64748b}

@media(max-width:768px){
  .sidebar{transform:translateX(-100%)}
  .sidebar.open{transform:translateX(0)}
  .main{margin-left:0}
  .topbar,.notice-bar{left:0}
  .menu-btn{display:block}
  .two-col{grid-template-columns:1fr}
  .cg{grid-template-columns:1fr 1fr}
}
@media(max-width:440px){.cg{grid-template-columns:1fr}}
</style>
</head>
<body>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <div class="logo-area">
    <img src="assets/images/logo.jpeg" alt="LLM" class="logo-img"
         onerror="this.onerror=null;this.src='assets/logo/livelinemeta.png';this.onerror=function(){this.style.display='none'}">
