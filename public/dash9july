    <div class="card">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:15px">
        <div style="width:58px;height:58px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:1.6rem;color:#fff;font-weight:800;flex-shrink:0" id="pfAv">U</div>
