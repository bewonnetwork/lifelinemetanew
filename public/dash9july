  const otp=['otp1','otp2','otp3','otp4','otp5','otp6'].map(id=>document.getElementById(id).value).join('');
  if(otp.length!==6){toast('Enter 6-digit OTP');return;}
  // Demo: accept 123456
  if(otp!=='123456'){toast('Invalid OTP. Try again.');return;}
  const phone=document.getElementById('tfa-phone').value;
  await rtdb.ref('tfa/'+CU.uid).set({enabled:true,phone,enabledAt:Date.now()});
  renderTFAEnabled();toast('✅ 2FA enabled successfully!');
  await rtdb.ref('loginHistory/'+CU.uid).push({device:'2FA Setup',timestamp:Date.now(),status:'2FA Enabled'});
};
window.resendOTP=()=>toast('OTP resent (demo: use 123456)');
function renderTFAEnabled(){
  document.getElementById('tfa-icon').textContent='🔐';
  set('tfa-status','2FA is Active ✅');
  document.getElementById('tfa-status-box').style.borderColor='var(--green)';
  document.getElementById('tfa-enable-section').style.display='none';
  document.getElementById('tfa-verify-section').style.display='none';
  document.getElementById('tfa-disable-section').style.display='block';
  document.getElementById('info2FA').innerHTML='<span class="pill pg">✅ Enabled</span>';
}
window.disable2FA=async()=>{
  if(!confirm('Disable 2FA?'))return;
  await rtdb.ref('tfa/'+CU.uid).remove();
  document.getElementById('tfa-icon').textContent='🔓';
  set('tfa-status','2FA Disabled');
  document.getElementById('tfa-disable-section').style.display='none';
  document.getElementById('tfa-enable-section').style.display='block';
  document.getElementById('info2FA').innerHTML='<span class="pill pr">Disabled</span>';
  toast('2FA disabled');
};
window.otpNav=(el,nextId)=>{if(el.value.length===1&&nextId)document.getElementById(nextId)?.focus();};
function renderLoginHistory(lhObj){
  const list=Object.values(lhObj).sort((a,b)=>b.timestamp-a.timestamp);
  document.getElementById('loginHistTb').innerHTML=list.slice(0,10).map(l=>`<tr>
    <td style="font-size:.68rem">${new Date(l.timestamp).toLocaleDateString()}</td>
    <td style="font-size:.68rem;max-width:120px;overflow:hidden;text-overflow:ellipsis">${l.device||'Browser'}</td>
    <td style="font-size:.68rem;color:var(--muted)">${l.ip||'—'}</td>
    <td><span class="pill pg">✅</span></td>
  </tr>`).join('');
}

// ── NOTICE BOARD ─────────────────────────────────────
async function loadNoticeBoard(){
  try{
    const sn=await rtdb.ref('notices').get();
    if(!sn.exists())return;
    const list=Object.values(sn.val()).filter(n=>{
      if(!n.active)return false;
      if(n.expiry&&new Date(n.expiry)<new Date())return false;
      if(n.target==='active'&&!UD?.isActive)return false;
      if(n.target==='inactive'&&UD?.isActive)return false;
      return true;
    });
    if(!list.length)return;
    const tc={info:'nb-info',success:'nb-success',warning:'nb-warn',urgent:'nb-urgent'};
    const ic={info:'ℹ',success:'✅',warning:'⚠',urgent:'🔴'};
    document.getElementById('noticeTrack').innerHTML=list.map(n=>`
      <span class="nm-item">
        <span class="nm-badge ${tc[n.type]||'nb-info'}">${ic[n.type]||'📢'} ${(n.type||'INFO').toUpperCase()}</span>
        <strong>${n.title}</strong> — ${n.message}
      </span>`).join('');
    const bar=document.getElementById('noticeBar');
    bar.style.display='block';
    document.getElementById('mainEl').style.paddingTop='calc(54px + 32px)';
    if(window.innerWidth<=768){bar.style.left='0';}
  }catch(e){}
}

// ── ADMIN CUSTOM BUTTONS ──────────────────────────────
async function loadAdminButtons(){
  try{
    const sn=await rtdb.ref('dashboardButtons').get();
    if(!sn.exists())return;
    const btns=Object.values(sn.val()).filter(b=>{
      if(!b.active)return false;
      if(b.show==='active'&&!UD?.isActive)return false;
      if(b.show==='inactive'&&UD?.isActive)return false;
      return true;
    });
    const el=document.getElementById('adminButtons');
    if(!btns.length){el.style.display='none';return;}
    el.style.display='flex';
    el.innerHTML=btns.map(b=>`<button class="btn ${b.color||'btn-p'}" onclick="handleAdminBtn('${b.link}')">${b.icon||''} ${b.label}</button>`).join('');
  }catch(e){}
}
window.handleAdminBtn=link=>{
  if(link.startsWith('http')||link.startsWith('//')){window.open(link,'_blank');}
  else{showP(link,null);}
};

// ── ACTIONS ──────────────────────────────────────────
window.saveProfile=async()=>{
  await fsdb.collection('users').doc(CU.uid).update({fullName:document.getElementById('pfName').value.trim(),mobile:document.getElementById('pfPhone').value.trim(),paymentWallet:document.getElementById('pfWallet').value.trim(),updatedAt:new Date()});
  UD.fullName=document.getElementById('pfName').value.trim();
  set('sbName',UD.fullName||'User');toast('✅ Profile saved!');
};
window.submitActivation=async()=>{
  if(UD?.isActive){toast('Already active!');return;}
  const txid=document.getElementById('actTxid').value.trim();
  if(!txid){toast('Enter transaction hash');return;}
  await rtdb.ref('activationRequests').push({uid:CU.uid,email:CU.email,name:UD?.fullName||UD?.username||'',username:UD?.username||'',txid,method:document.getElementById('actMethod').value,amount:+(SETS.activationFee||30),status:'pending',createdAt:Date.now()});
  toast('✅ Activation request submitted! Admin will approve soon.');
  document.getElementById('actTxid').value='';
};
window.submitInvestment=async()=>{
  if(!UD?.isActive){toast('Activate account first!');return;}
  const amt=parseFloat(document.getElementById('invAmt').value);
  const txid=document.getElementById('invTxid').value.trim();
  const minInv=+(SETS.minInv||100);
  if(!amt||amt<minInv){toast('Minimum investment is $'+minInv);return;}
  if(!txid){toast('Enter transaction hash');return;}
  await rtdb.ref('investments/'+CU.uid).push({amount:amt,method:document.getElementById('invMethod').value,txid,roiRate:+(SETS.roiRate||10),status:'pending',earnedROI:0,createdAt:Date.now()});
  const newInv=(+(UD?.totalInvested||0))+amt;
  await rtdb.ref('users/'+CU.uid+'/totalInvested').set(newInv);
  toast('✅ Investment submitted! Admin will activate shortly.');
  document.getElementById('invAmt').value='';document.getElementById('invTxid').value='';
};
window.withdrawCapital=async pid=>{
  if(!confirm('Withdraw capital? '+(SETS.invFee||10)+'% fee deducted.'))return;
  await rtdb.ref('investments/'+CU.uid+'/'+pid).update({status:'withdrawal_requested',wdRequestAt:Date.now()});
  toast('Capital withdrawal requested!');
};
window.submitWithdraw=async()=>{
  if(UD?.withdrawOff){toast('⛔ Withdrawal disabled for your account');return;}
  const amt=parseFloat(document.getElementById('wdAmt').value);
  const addr=document.getElementById('wdAddr').value.trim();
  if(!amt||amt<10){toast('Min withdrawal $10');return;}
  if(!addr){toast('Enter wallet address');return;}
  const bal=+(UD?.walletBalance||0);
  if(amt>bal){toast('Insufficient balance');return;}
  await rtdb.ref('withdrawals/'+CU.uid).push({amount:amt,address:addr,status:'pending',createdAt:Date.now()});
  toast('✅ Withdrawal request submitted!');
  document.getElementById('wdAmt').value='';document.getElementById('wdAddr').value='';
  hideWdForm();
};
window.copyRef=()=>{navigator.clipboard.writeText(document.getElementById('refLinkInput').value).then(()=>toast('✅ Referral link copied!'));};
window.shareWA=()=>{window.open('https://wa.me/?text=Join+Life+Line+Meta:+'+encodeURIComponent(document.getElementById('refLinkInput').value),'_blank');};
window.shareTG=()=>{window.open('https://t.me/share/url?url='+encodeURIComponent(document.getElementById('refLinkInput').value),'_blank');};
window.showWdForm=()=>{document.getElementById('wdFormCard').style.display='block';};
window.hideWdForm=()=>{document.getElementById('wdFormCard').style.display='none';};
window.doLogout=async()=>{await auth.signOut();window.location.href='login.html';};

// ── HELPERS ──────────────────────────────────────────
function set(id,val){const e=document.getElementById(id);if(e)e.textContent=val;}
function setW(id,val){const e=document.getElementById(id);if(e)e.style.width=val;}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),3200);}

// ── NAV ──────────────────────────────────────────────
const PL={overview:'Overview',profile:'Profile',referral:'Referral',tree:'Binary Tree',team:'My Team',income:'Income Report',roi:'ROI Investment',wallet:'Wallet',web3:'Web3 Wallet',rank:'Rank Progress',cashback:'Cashback Pool',club:'Club Bonus',activation:'Activation',kyc:'KYC Verification',security:'2FA Security'};
window.showP=(page,el)=>{
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const t=document.getElementById('page-'+page);if(t)t.classList.add('active');
  document.querySelectorAll('nav a').forEach(a=>a.classList.remove('active'));
  if(el)el.classList.add('active');
  set('pgLabel',PL[page]||page);
  closeSidebar();
  if(page==='tree'&&UD)renderBinaryTree();
  if(page==='web3'){loadRTDB();}
};
window.toggleSidebar=()=>{document.getElementById('sidebar').classList.toggle('open');document.getElementById('overlay').classList.toggle('show');};
window.closeSidebar=()=>{document.getElementById('sidebar').classList.remove('open');document.getElementById('overlay').classList.remove('show');};
let isLight=false;
window.toggleTheme=()=>{isLight=!isLight;document.body.classList.toggle('light',isLight);document.getElementById('themeBtn').textContent=isLight?'🌙 Dark':'☀ Light';};
