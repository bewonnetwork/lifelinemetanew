    <div class="sc cp"><div class="sl">Wallet Balance</div><div class="sv" id="ov-wallet">$0.00</div><div class="ss">Available</div><div class="si">💳</div></div>
    <div class="sc cg2"><div class="sl">Direct Referrals</div><div class="sv" id="ov-refs">0</div><div class="ss" id="ov-refs-sub">0 active</div><div class="si">👥</div></div>
    <div class="sc cgr"><div class="sl">Matching Income</div><div class="sv" id="ov-match">$0.00</div><div class="ss">Cap: <span id="ov-cap">$1000</span></div><div class="si">🤝</div><div class="prog"><div class="prog-f" id="ov-matchp" style="width:0%"></div></div></div>
