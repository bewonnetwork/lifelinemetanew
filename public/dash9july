    <a onclick="showP('rank',this)"><span class="ic">⭐</span> Rank Progress</a>
    <a onclick="showP('cashback',this)"><span class="ic">🎁</span> Cashback</a>
    <a onclick="showP('club',this)"><span class="ic">🏆</span> Club Bonus</a>
    <a onclick="showP('activation',this)"><span class="ic">✅</span> Activation</a>
    <a onclick="showP('kyc',this)"><span class="ic">🪪</span> KYC <span id="kycBadge" style="font-size:.6rem;background:var(--gold);color:#000;border-radius:8px;padding:1px 5px;margin-left:auto;display:none">NEW</span></a>
    <a onclick="showP('security',this)"><span class="ic">🔐</span> 2FA Security</a>
    <a onclick="doLogout()" style="color:var(--red);margin-top:6px"><span class="ic">🚪</span> Logout</a>
  </nav>
  <div class="sb-footer">
    <div class="user-mini">
      <div class="av" id="avInit">U</div>
      <div class="um-info"><strong id="sbName">Loading…</strong><span id="sbStatus">—</span></div>
    </div>
  </div>
</aside>

<!-- NOTICE BAR -->
<div class="notice-bar" id="noticeBar">
  <div class="notice-track" id="noticeTrack"></div>
</div>

<!-- TOPBAR -->
<div class="topbar">
  <div style="display:flex;align-items:center;gap:9px">
    <button class="menu-btn" onclick="toggleSidebar()">☰</button>
    <span class="pg-label" id="pgLabel">Overview</span>
  </div>
  <div class="tb-right">
    <button class="theme-btn" onclick="toggleTheme()" id="themeBtn">☀ Light</button>
    <button class="btn btn-o btn-sm" onclick="doLogout()">Logout</button>
  </div>
</div>

<main class="main" id="mainEl">

<!-- ===== OVERVIEW ===== -->
<div class="page active" id="page-overview">
  <div class="pg-title">Overview <span id="greetMsg"></span></div>

  <!-- Activation Banner -->
  <div id="actBanner" class="banner bw" style="display:none">
    <div><strong style="color:var(--gold)">⚠ Account Not Activated</strong><br><small style="color:var(--muted)">Pay $30 to unlock all income features</small></div>
    <button class="btn btn-g btn-sm" onclick="showP('activation',null)">Activate Now →</button>
  </div>

  <!-- Income OFF Banner -->
  <div id="incOffBanner" class="banner br" style="display:none">
    <div><strong style="color:var(--red)">⛔ Income Disabled</strong><br><small style="color:var(--muted)">Your income has been paused by admin. Contact support.</small></div>
  </div>

  <!-- KYC Banner -->
  <div id="kycBanner" class="banner bw" style="display:none">
    <div><strong style="color:var(--gold)">🪪 KYC Required</strong><br><small style="color:var(--muted)">Complete KYC to enable withdrawals</small></div>
    <button class="btn btn-sm btn-p" onclick="showP('kyc',null)">Complete KYC →</button>
