  if(type==='users'){rows=[['ID','Name','Username','Email','Country','Mobile','Sponsor','Joined','Status','Blocked','Income','WD']];Object.values(AU).forEach(u=>{const j=u.createdAt?(u.createdAt.toDate?u.createdAt.toDate().toLocaleDateString():new Date(u.createdAt).toLocaleDateString()):'';rows.push([u.id,u.fullName||'',u.username||'',u.email||'',u.country||'',u.mobile||'',u.sponsorId||'',j,u.isActive?'Active':'Inactive',u.blocked?'Yes':'No',u.incomeOff?'OFF':'ON',u.withdrawOff?'OFF':'ON']);});}
  else if(type==='transactions'){rows=[['Date','User','Type','Amount','Note','Status']];TX.forEach(t=>rows.push([new Date(t.timestamp||Date.now()).toLocaleDateString(),AU[t.uid]?.fullName||t.uid,t.type||'',t.amount||0,t.note||'',t.status||'']));}
  else if(type==='withdrawals'){rows=[['User','Amount','Address','Date','Status']];Object.entries(WD).forEach(([,w])=>rows.push([AU[w.uid]?.fullName||w.uid,w.amount||0,w.address||'',w.createdAt?new Date(w.createdAt).toLocaleDateString():'',w.status||''  ]));}
  else if(type==='investments'){rows=[['User','Amount','ROI%','Date','Earned','Status']];Object.entries(INV).forEach(([,p])=>rows.push([AU[p.uid]?.fullName||p.uid,p.amount||0,p.roiRate||10,p.createdAt?new Date(p.createdAt).toLocaleDateString():'',p.earnedROI||0,p.status||''  ]));}
  const csv=rows.map(r=>r.map(c=>'"'+String(c).replace(/"/g,'""')+'"').join(',')).join('\n');
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));a.download=fn;a.click();
