window.distributeCustomIncome = async() => {
  const type   = document.getElementById('dist-type').value;
  const amt    = parseFloat(document.getElementById('dist-amt').value);
  const target = document.getElementById('dist-target').value;
  const uid    = (document.getElementById('dist-uid').value||'').trim();
  if(!type){toast('Select income type');return;}
  if(!amt||amt<=0){toast('Enter valid amount');return;}

  // Get income name
  const defInc = DEFAULT_INCOMES.find(i=>i.key===type);
  const incomeName = defInc ? defInc.name : type;

  let users = [];
  if(target==='specific'){
    if(!uid){toast('Enter user UID');return;}
    if(!AU[uid]){toast('User not found');return;}
    users = [AU[uid]];
  } else if(target==='active'){
    users = Object.values(AU).filter(u=>u.isActive&&!u.blocked&&!u.incomeOff);
  } else {
    users = Object.values(AU).filter(u=>!u.blocked);
  }

  if(!users.length){toast('No eligible users');return;}
  if(!confirm('Distribute $'+amt+' ('+incomeName+') to '+users.length+' user(s)?'))return;

  let cnt=0;
  for(const u of users){
    try{
      // Add to RTDB income bucket
      const ir = db.ref('users/'+u.id+'/income/'+type);
      const is = await ir.get();
      await ir.set(parseFloat(is.exists()?is.val():0)+amt);
      // Add to wallet
      const wr = db.ref('users/'+u.id+'/walletBalance');
      const ws = await wr.get();
      const nw = parseFloat(ws.exists()?ws.val():0)+amt;
      await wr.set(nw);
      // Transaction log
      await db.ref('transactions/'+u.id).push({
        type: incomeName, amount: amt,
        note: 'Admin distributed '+incomeName,
        timestamp: Date.now(), status:'completed', balance:nw
      });
      cnt++;
    }catch(e){console.log('dist error:',u.id,e.message);}
  }
  logA('Distributed '+incomeName+' $'+amt+' to '+cnt+' users','Admin');
  toast('✅ $'+amt+' '+incomeName+' paid to '+cnt+' user(s)!');
  document.getElementById('dist-amt').value='';
  loadUserIncomeTable();
};

window.loadUserIncomeTable = async() => {
  try{
    const tb = document.getElementById('inc-table-body');
    const head = document.getElementById('inc-table-head');
    tb.innerHTML = '<tr><td colspan="10" style="text-align:center;color:#64748b;padding:14px">Loading…</td></tr>';

    // Get custom income types for dynamic columns
    const cSn = await db.ref('customIncomes').get();
    const customCols = cSn.exists() ? Object.entries(cSn.val()).filter(([,c])=>c.active) : [];

    // Build header
    const extraTh = customCols.map(([,c])=>`<th>${c.name}</th>`).join('');
    head.innerHTML = `<tr><th>User</th><th>Sponsor</th><th>Matching</th><th>Cashback</th><th>Club</th><th>ROI</th><th>Generation</th>${extraTh}<th style="color:#22c55e">Total</th><th>WB</th></tr>`;

    const users = Object.values(AU).slice(0,100); // limit for performance
    if(!users.length){tb.innerHTML='<tr><td colspan="10" style="text-align:center;color:#64748b;padding:14px">No users</td></tr>';return;}

    const rows = await Promise.all(users.map(async u => {
      try{
        const sn = await db.ref('users/'+u.id+'/income').get();
        const inc = sn.exists()?sn.val():{};
        const wb = await db.ref('users/'+u.id+'/walletBalance').get();
        const bal = parseFloat(wb.exists()?wb.val():0);

        const sp2  = parseFloat(inc.sponsor||0);
        const mt   = parseFloat(inc.matching||0);
        const cb   = parseFloat(inc.cashback||0);
        const cl   = parseFloat(inc.club||0);
        const roi  = parseFloat(inc.roi||0);
        const gen  = parseFloat(inc.generation||0);

        // Custom income columns
        let customVals = [], customTotal = 0;
        customCols.forEach(([id])=>{
          const v = parseFloat(inc[id]||0);
          customVals.push(v);
          customTotal += v;
        });

        const total = sp2+mt+cb+cl+roi+gen+customTotal;
        const customTd = customVals.map(v=>`<td style="font-size:.74rem">$${v.toFixed(2)}</td>`).join('');

        return `<tr>
          <td style="font-weight:600">${u.fullName||u.username||u.id.slice(0,8)}</td>
          <td style="font-size:.74rem">$${sp2.toFixed(2)}</td>
          <td style="font-size:.74rem">$${mt.toFixed(2)}</td>
          <td style="font-size:.74rem">$${cb.toFixed(2)}</td>
          <td style="font-size:.74rem">$${cl.toFixed(2)}</td>
          <td style="font-size:.74rem">$${roi.toFixed(2)}</td>
          <td style="font-size:.74rem">$${gen.toFixed(2)}</td>
          ${customTd}
          <td style="font-weight:700;color:#22c55e">$${total.toFixed(2)}</td>
          <td style="font-size:.74rem;color:#3b82f6">$${bal.toFixed(2)}</td>
        </tr>`;
      }catch(e){return `<tr><td>${u.fullName||'User'}</td><td colspan="9" style="color:#64748b">Error loading</td></tr>`;}
    }));

    tb.innerHTML = rows.join('');
  }catch(e){console.log('loadUserIncomeTable:',e.message);}
};

