      <thead><tr><th>#</th><th>UID</th><th>Name</th><th>Username</th><th>Email</th><th>Joined</th><th>Sponsor By</th><th>Status</th><th>Income</th><th>WD</th><th>Blocked</th><th>Actions</th></tr></thead>
      <tbody id="u-tb"><tr><td colspan="12" style="text-align:center;color:#64748b;padding:20px">Loading users…</td></tr></tbody>
    </table></div>
  </div>
</div>

<!-- ACTIVATIONS -->
<div class="pg" id="pg-activations">
  <div class="pg-title">Activation Requests</div>
  <div class="ib">💡 On approval: $4 → Sponsor | $5 → Company Fund. Verify TxID before approving.</div>
  <div class="sb2">
    <select id="ac-f" onchange="filterAct()">
      <option value="all">All</option><option value="pending">Pending</option>
      <option value="approved">Approved</option><option value="rejected">Rejected</option>
