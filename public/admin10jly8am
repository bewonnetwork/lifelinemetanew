window.fundOp=async()=>{
  const op=document.getElementById('fd-op').value,amt=parseFloat(document.getElementById('fd-amt').value),note=(document.getElementById('fd-note').value||'').trim();
  if(!amt||amt<=0){toast('Enter valid amount');return;}
  if(!confirm(op.toUpperCase()+' $'+amt+'?'))return;
  try{
    const fr=db.ref('settings/companyFundBalance'),fs2=await fr.get(),cur=parseFloat(fs2.exists()?fs2.val():0);
    if(op==='add'){await fr.set(cur+amt);await db.ref('fundHistory').push({type:'Add',amount:amt,note:note||'Manual add',timestamp:Date.now()});toast('✅ $'+amt+' added');}
    else if(op==='withdraw'){if(amt>cur){toast('Insufficient fund ($'+cur.toFixed(2)+')');return;}await fr.set(cur-amt);await db.ref('fundHistory').push({type:'Withdraw',amount:-amt,note:note||'Manual withdraw',timestamp:Date.now()});toast('✅ $'+amt+' withdrawn');}
    else if(op==='distribute'){
      const users=Object.values(AU).filter(u=>u.isActive&&!u.blocked);if(!users.length){toast('No active users');return;}if(amt>cur){toast('Insufficient fund');return;}
      const per=amt/users.length;
      for(const u of users){const wr=db.ref('users/'+u.id+'/walletBalance'),ws=await wr.get(),nw=parseFloat(ws.exists()?ws.val():0)+per;await wr.set(nw);await db.ref('transactions/'+u.id).push({type:'Fund Distribution',amount:per,note:note||'Fund distribution',timestamp:Date.now(),status:'completed',balance:nw});}
      await fr.set(cur-amt);toast('✅ $'+per.toFixed(4)+' to '+users.length+' users');
    }
    logA('Fund '+op+' $'+amt,'Admin');loadFundH();document.getElementById('fd-amt').value='';document.getElementById('fd-note').value='';
  }catch(e){toast('Error: '+e.message);}
};
async function loadFundH(){
  try{
    const sn=await db.ref('settings/companyFundBalance').get();
    const bal=parseFloat(sn.exists()?sn.val():0);
    sv('fd-b','$'+bal.toFixed(2));sv('ov-f','$'+bal.toFixed(0));
    const hs=await db.ref('fundHistory').get(),tb=document.getElementById('fd-tb');
    if(!hs.exists()){tb.innerHTML='<tr><td colspan="4" style="text-align:center;color:#64748b">No records</td></tr>';return;}
