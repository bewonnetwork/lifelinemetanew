window.doBackup=async()=>{
  const type=document.getElementById('bk-t').value;let data={};
  try{
    if(type==='full'||type==='users'){const sn=await fs.collection('users').get();data.users={};sn.forEach(d=>{data.users[d.id]={...d.data(),_id:d.id};});}
    if(type==='full'||type==='transactions'){const sn=await db.ref('transactions').get();if(sn.exists())data.transactions=sn.val();}
    if(type==='full'||type==='investments'){const sn=await db.ref('investments').get();if(sn.exists())data.investments=sn.val();}
    if(type==='full'||type==='settings'){const sn=await db.ref('settings').get();if(sn.exists())data.settings=sn.val();}
    data._meta={type,createdAt:new Date().toISOString(),by:auth.currentUser?.email};
    const json=JSON.stringify(data,null,2),fn='llm-backup-'+type+'-'+new Date().toISOString().slice(0,10)+'.json';
    const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([json],{type:'application/json'}));a.download=fn;a.click();
    await db.ref('backups').push({type,filename:fn,size:Math.round(json.length/1024)+'KB',createdAt:Date.now()});
    logA('Backup: '+type,'Admin');toast('✅ Downloaded: '+fn);loadBkList();
  }catch(e){toast('Backup error: '+e.message);}
};
window.fullBackup=()=>{document.getElementById('bk-t').value='full';doBackup();};
