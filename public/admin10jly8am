window.saveMatchSet=async()=>{
  const pct=parseFloat(document.getElementById('ma-p').value)||5,cap=parseFloat(document.getElementById('ma-c').value)||1000;
  await db.ref('settings').update({matchingPct:pct,matchingCap:cap});Object.assign(S,{matchingPct:pct,matchingCap:cap});
  sv('ov-mp',pct+'%');sv('ma-r',pct+'%');sv('ma-cp','$'+cap);toast('✅ Matching settings saved');
};
window.runMatching=async()=>{
  if(!confirm('Run matching bonus?'))return;
  const users=Object.values(AU).filter(u=>u.isActive&&!u.blocked&&!u.incomeOff);
  const pct=parseFloat(S.matchingPct||5)/100,cap=parseFloat(S.matchingCap||1000);
  let atCap=0,totalPaid=0;
  for(const u of users){
    function legCnt(sUID){let cnt=0;const q=[sUID],vis=new Set();while(q.length){const c=q.shift();if(!c||vis.has(c))continue;vis.add(c);const n=AU[c];if(!n)continue;if(n.isActive)cnt++;if(n.leftChild)q.push(n.leftChild);if(n.rightChild)q.push(n.rightChild);}return cnt;}
    const lv=u.leftChild?legCnt(u.leftChild)*(parseFloat(S.activationFee||30)):0;
    const rv=u.rightChild?legCnt(u.rightChild)*(parseFloat(S.activationFee||30)):0;
    const weaker=Math.min(lv,rv);if(weaker<=0)continue;
    const mr=db.ref('users/'+u.id+'/income/matching'),ms=await mr.get(),earned=parseFloat(ms.exists()?ms.val():0);
    if(earned>=cap){atCap++;continue;}
    const bonus=Math.min(weaker*pct,cap-earned);if(bonus<=0)continue;
    await mr.set(earned+bonus);
    const wr=db.ref('users/'+u.id+'/walletBalance'),ws=await wr.get(),nw=parseFloat(ws.exists()?ws.val():0)+bonus;await wr.set(nw);
    await db.ref('transactions/'+u.id).push({type:'Matching Bonus',amount:bonus,note:'L:$'+lv.toFixed(0)+' R:$'+rv.toFixed(0),timestamp:Date.now(),status:'completed',balance:nw});
    totalPaid+=bonus;
  }
  sv('ma-tp','$'+totalPaid.toFixed(2));sv('ma-ac',atCap);logA('Matching $'+totalPaid.toFixed(2),'Admin');toast('✅ Matching: $'+totalPaid.toFixed(2));
};

