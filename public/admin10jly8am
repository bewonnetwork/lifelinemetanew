<!-- SUB-ADMIN -->
<div class="pg" id="pg-subadmin">
  <div class="pg-title">Sub-Admin Management</div>
  <div class="two-col">
    <div class="card">
      <div class="ct">Create Sub-Admin</div>
      <div class="fg"><label>User UID or Email</label><input type="text" id="sa-q" placeholder="UID or email"/></div>
      <div class="fg"><label>Role Name</label><input type="text" id="sa-role" placeholder="e.g. Finance Manager"/></div>
      <div class="fg"><label>Permissions</label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:5px">
          <label style="display:flex;align-items:center;gap:6px;font-size:.75rem;cursor:pointer"><input type="checkbox" id="p-u" checked/> Users</label>
          <label style="display:flex;align-items:center;gap:6px;font-size:.75rem;cursor:pointer"><input type="checkbox" id="p-a"/> Activations</label>
          <label style="display:flex;align-items:center;gap:6px;font-size:.75rem;cursor:pointer"><input type="checkbox" id="p-w"/> Withdrawals</label>
          <label style="display:flex;align-items:center;gap:6px;font-size:.75rem;cursor:pointer"><input type="checkbox" id="p-i"/> Investments</label>
          <label style="display:flex;align-items:center;gap:6px;font-size:.75rem;cursor:pointer"><input type="checkbox" id="p-d"/> Distributions</label>
          <label style="display:flex;align-items:center;gap:6px;font-size:.75rem;cursor:pointer"><input type="checkbox" id="p-s"/> Settings</label>
          <label style="display:flex;align-items:center;gap:6px;font-size:.75rem;cursor:pointer"><input type="checkbox" id="p-r"/> Reports</label>
          <label style="display:flex;align-items:center;gap:6px;font-size:.75nm;cursor:pointer"><input type="checkbox" id="p-n"/> Notices</label>
        </div>
      </div>
      <button class="btn btn-blue" onclick="createSA()" style="width:100%">🛡 Create Sub-Admin</button>
    </div>
