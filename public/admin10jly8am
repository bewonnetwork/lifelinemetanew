// ── COMPUTE OVERVIEW ─────────────────────────────────
function computeOV(){
  const users=Object.values(AU),active=users.filter(u=>u.isActive);
  const rev=active.length*(parseFloat(S.activationFee)||30),fund=active.length*(parseFloat(S.companyFund)||5),comm=active.length*(parseFloat(S.sponsorComm)||4);
  const cbPool=(rev*(parseFloat(S.cashbackPct||3)/100)).toFixed(2),clubPool=(rev*(parseFloat(S.clubPct||4)/100)).toFixed(2);
  sv('ov-u',users.length);sv('ov-ua',active.length+' active');sv('ov-r','$'+rev);
  sv('ov-cb','$'+cbPool);sv('ov-cl','$'+clubPool);
  const ivTot=Object.values(INV).reduce((st,p)=>st+(p.amount||0),0);sv('ov-i','$'+ivTot.toFixed(0));
  sv('rp-r',users.length);sv('rp-rv','$'+rev);sv('rp-f','$'+fund);sv('rp-c','$'+comm);
  sv('cb-v','$'+rev);sv('cb-ps','$'+cbPool);sv('cb-el',active.length);
  const jf=parseFloat(S.joinFee||30),mul=parseFloat(S.cbMultiplier||2),cbLim=jf*mul;
  sv('cb-mx','$'+cbLim.toFixed(0));sv('cb-pm',active.length>0?'$'+(parseFloat(cbPool)/active.length).toFixed(4):'$0');
  sv('cl-pl','$'+clubPool);
  const mr=parseInt(S.clubMinRefs||10),celig=users.filter(u=>users.filter(u2=>u2.sponsorId===u.id).length>=mr);
  sv('cl-el',celig.length);sv('cl-pm',celig.length>0?'$'+(parseFloat(clubPool)/celig.length).toFixed(2):'$0');
  document.getElementById('cl-tb').innerHTML=celig.length?celig.map(u=>{const dr=users.filter(u2=>u2.sponsorId===u.id).length;return`<tr><td style="font-weight:600">${u.fullName||u.username||'User'}</td><td>${dr}</td><td>—</td><td><span class="pill pg-p">✅ Refs</span></td></tr>`;}).join(''):'<tr><td colspan="4" style="text-align:center;color:#64748b">None yet</td></tr>';
  for(let n=1;n<=7;n++){const el=document.getElementById('rk-'+n+'c');if(el)el.textContent=active.filter(u=>(u.matching||0)>=[50,300,1000,3000,10000,30000,100000][n-1]).length;}
}

