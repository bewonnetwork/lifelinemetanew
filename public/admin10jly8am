window.doRestore=async()=>{
  const file=document.getElementById('bk-f').files[0];if(!file){toast('Select backup file');return;}
  if(!confirm('⚠ RESTORE will OVERWRITE current data. Sure?'))return;
  const type=document.getElementById('bk-rt').value;
  const reader=new FileReader();
  reader.onload=async e=>{
    try{const data=JSON.parse(e.target.result);
    if((type==='full'||type==='users')&&data.users){for(const[uid,u]of Object.entries(data.users)){const{_id,...rest}=u;await fs.collection('users').doc(uid).set(rest,{merge:true});}}
    if(type==='full'&&data.transactions)await db.ref('transactions').set(data.transactions);
    if(type==='full'&&data.investments)await db.ref('investments').set(data.investments);
    if((type==='full'||type==='settings')&&data.settings)await db.ref('settings').set(data.settings);
    logA('Restored: '+type,'Admin');toast('✅ Restore complete! Reloading…');setTimeout(()=>loadAll(),1500);}
    catch(err){toast('Restore error: '+err.message);}
  };reader.readAsText(file);
};

