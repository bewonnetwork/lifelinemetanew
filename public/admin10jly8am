    const cSn = await db.ref('customIncomes').get();
    const customCols = cSn.exists() ? Object.entries(cSn.val()).filter(([,c])=>c.active) : [];
    const customHeaders = customCols.map(([,c])=>c.name);
    const rows = [['User','Email','Sponsor','Matching','Cashback','Club','ROI','Generation',...customHeaders,'Total','Wallet Balance']];
    for(const u of Object.values(AU)){
      try{
        const sn = await db.ref('users/'+u.id+'/income').get();
        const inc = sn.exists()?sn.val():{};
        const wb = await db.ref('users/'+u.id+'/walletBalance').get();
        const sp2=parseFloat(inc.sponsor||0),mt=parseFloat(inc.matching||0),cb2=parseFloat(inc.cashback||0),cl=parseFloat(inc.club||0),roi=parseFloat(inc.roi||0),gen=parseFloat(inc.generation||0);
        const customs = customCols.map(([id])=>parseFloat(inc[id]||0));
        const tot = sp2+mt+cb2+cl+roi+gen+customs.reduce((a,b)=>a+b,0);
        rows.push([u.fullName||'',u.email||'',sp2,mt,cb2,cl,roi,gen,...customs,tot,parseFloat(wb.exists()?wb.val():0)]);
      }catch(e){}
    }
    const csv=rows.map(r=>r.map(c=>'"'+String(c).replace(/"/g,'""')+'"').join(',')).join('\n');
    const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));a.download='income_'+new Date().toISOString().slice(0,10)+'.csv';a.click();
    toast('⬇ Income CSV exported');
    return;
  }
  _xCSV(type);
};

