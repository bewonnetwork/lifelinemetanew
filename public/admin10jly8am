<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Life Line Meta – Admin</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',sans-serif;background:#f1f5f9;color:#1e293b;min-height:100vh}
button{cursor:pointer;font-family:inherit}
input,select,textarea{font-family:inherit}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:2px}

/* SIDEBAR */
.sb{position:fixed;top:0;left:0;height:100vh;width:220px;background:#1e293b;display:flex;flex-direction:column;z-index:200;overflow-y:auto;transition:transform .3s}
.sb-logo{padding:16px;border-bottom:1px solid #334155;flex-shrink:0}
.sb-logo h2{font-size:.95rem;font-weight:800;color:#38bdf8;margin-bottom:2px}
.sb-logo p{font-size:.62rem;color:#ef4444;font-weight:700;text-transform:uppercase}
.ns{padding:10px 12px 3px;font-size:.6rem;color:#64748b;text-transform:uppercase;letter-spacing:.8px;font-weight:700}
nav a{display:flex;align-items:center;gap:8px;padding:9px 12px;font-size:.78rem;color:#94a3b8;border-left:3px solid transparent;transition:.15s;cursor:pointer;user-select:none}
nav a:hover{color:#fff;background:rgba(255,255,255,.05)}
nav a.active{color:#fff;background:rgba(56,189,248,.1);border-left-color:#38bdf8}
.nb{background:#ef4444;color:#fff;border-radius:9px;padding:1px 5px;font-size:.6rem;margin-left:auto}

/* TOPBAR */
.topbar{position:fixed;top:0;left:220px;right:0;height:50px;background:#fff;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;justify-content:space-between;padding:0 16px;z-index:199}
.menu-btn{display:none;background:none;border:none;color:#1e293b;font-size:1.2rem;padding:4px;cursor:pointer}
.tb-r{display:flex;align-items:center;gap:8px}

/* MAIN */
.main{margin-left:220px;padding-top:50px;min-height:100vh}
.pg{display:none;padding:16px}
.pg.active{display:block}
.pg-title{font-size:1.1rem;font-weight:800;margin-bottom:14px;color:#1e293b}

/* STAT CARDS */
.cg{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-bottom:14px}
.sc{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:14px;position:relative}
.sl{font-size:.65rem;color:#64748b;text-transform:uppercase;margin-bottom:4px}
.sv{font-size:1.4rem;font-weight:800;color:#1e293b}
.ss{font-size:.65rem;color:#64748b;margin-top:2px}
.si{position:absolute;bottom:10px;right:12px;font-size:1.3rem;opacity:.15}

/* CARD */
.card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:14px;margin-bottom:12px}
.ct{font-size:.84rem;font-weight:700;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:5px;color:#1e293b}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}

/* TABLE */
.tw{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:.74rem}
th{color:#64748b;font-weight:600;padding:7px 9px;text-align:left;border-bottom:2px solid #e2e8f0;font-size:.67rem;text-transform:uppercase;white-space:nowrap;background:#f8fafc}
td{padding:8px 9px;border-bottom:1px solid #f1f5f9;vertical-align:middle;white-space:nowrap}
tr:hover td{background:#f8fafc}
tr:last-child td{border-bottom:none}

/* PILLS */
.pill{display:inline-block;padding:2px 8px;border-radius:20px;font-size:.65rem;font-weight:700}
.pg-p{background:#dcfce7;color:#166534}
.py-p{background:#fef9c3;color:#854d0e}
.pr-p{background:#fee2e2;color:#991b1b}
.pb-p{background:#dbeafe;color:#1d4ed8}
.pp-p{background:#ede9fe;color:#6d28d9}

/* BUTTONS */
.btn{padding:6px 13px;border-radius:7px;font-size:.74rem;font-weight:700;border:none;cursor:pointer;transition:.15s}
.btn:hover{opacity:.85}
.btn-blue{background:#3b82f6;color:#fff}
.btn-green{background:#22c55e;color:#fff}
.btn-red{background:#ef4444;color:#fff}
.btn-yellow{background:#f59e0b;color:#fff}
.btn-gray{background:#e2e8f0;color:#475569;border:1px solid #cbd5e1}
.btn-orange{background:#f97316;color:#fff}
.btn-sm{padding:3px 8px;font-size:.67rem}

/* FORM */
.fg{margin-bottom:11px}
.fg label{display:block;font-size:.71rem;color:#64748b;margin-bottom:3px;font-weight:600}
.fg input,.fg select,.fg textarea{width:100%;background:#fff;border:1px solid #e2e8f0;border-radius:7px;padding:8px 10px;color:#1e293b;font-size:.82rem;outline:none;transition:.2s}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.1)}
.fg textarea{resize:vertical;min-height:65px}

/* SEARCH BAR */
.sb2{display:flex;gap:8px;margin-bottom:11px;flex-wrap:wrap}
.sb2 input{flex:1;min-width:160px;background:#fff;border:1px solid #e2e8f0;border-radius:7px;padding:7px 11px;color:#1e293b;font-size:.78rem;outline:none}
.sb2 input:focus{border-color:#3b82f6}
.sb2 select{background:#fff;border:1px solid #e2e8f0;border-radius:7px;padding:7px 9px;color:#1e293b;font-size:.78rem;outline:none}

/* INFO BOXES */
.ib{background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:9px 12px;font-size:.74rem;color:#1d4ed8;margin-bottom:11px;line-height:1.6}
.wb{background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:9px 12px;font-size:.74rem;color:#92400e;margin-bottom:11px;line-height:1.6}
.rb{background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:9px 12px;font-size:.74rem;color:#991b1b;margin-bottom:11px;line-height:1.6}

/* TOGGLE */
.tog{position:relative;display:inline-block;width:36px;height:19px;flex-shrink:0}
.tog input{opacity:0;width:0;height:0}
.sldr{position:absolute;cursor:pointer;inset:0;background:#cbd5e1;border-radius:20px;transition:.3s}
.sldr:before{content:'';position:absolute;height:13px;width:13px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.3s}
input:checked+.sldr{background:#22c55e}
input:checked+.sldr:before{transform:translateX(17px)}
.tw-row{display:flex;align-items:center;gap:9px;margin-bottom:10px}
.tw-lbl{font-size:.78rem;font-weight:600;color:#1e293b}

/* MODAL */
.mbg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:999;align-items:center;justify-content:center;padding:10px}
.mbg.show{display:flex}
.modal{background:#fff;border-radius:12px;padding:20px;width:90%;max-width:500px;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.mt{font-size:.95rem;font-weight:800;margin-bottom:13px;display:flex;align-items:center;justify-content:space-between;color:#1e293b}
.mc{background:none;border:none;color:#64748b;font-size:1.1rem;cursor:pointer}

/* NOTICE items */
.ni{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:11px 13px;margin-bottom:8px;position:relative}
.ni h4{font-size:.8rem;font-weight:700;margin-bottom:3px}
.ni p{font-size:.73rem;color:#64748b}
.ni .dx{position:absolute;top:8px;right:8px;background:none;border:none;color:#94a3b8;cursor:pointer;font-size:.9rem}

/* OVERLAY & TOAST */
.mob-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:198}
.mob-ov.show{display:block}
.toast{position:fixed;bottom:16px;right:16px;background:#1e293b;color:#fff;border-radius:9px;padding:10px 16px;font-size:.78rem;z-index:9999;opacity:0;transform:translateY(12px);transition:.3s;pointer-events:none;max-width:280px}
.toast.show{opacity:1;transform:translateY(0)}

@media(max-width:768px){
  .sb{transform:translateX(-100%)}.sb.open{transform:translateX(0)}
  .main{margin-left:0}.topbar{left:0}.menu-btn{display:block}
  .two-col{grid-template-columns:1fr}.cg{grid-template-columns:1fr 1fr}
}
@media(max-width:400px){.cg{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="mob-ov" id="mobOv" onclick="closeSB()"></div>

<aside class="sb" id="sbEl">
  <div class="sb-logo">
    <h2>Life Line Meta</h2>
    <p>⚡ Super Admin</p>
  </div>
  <nav>
    <div class="ns">Dashboard</div>
    <a class="active" onclick="sp('overview',this)">🏠 Overview</a>
    <div class="ns">Users</div>
    <a onclick="sp('users',this)">👥 All Users <span class="nb" id="nb-u"></span></a>
    <a onclick="sp('activations',this)">✅ Activations <span class="nb" id="nb-a"></span></a>
    <a onclick="sp('edituser',this)">✏ Edit User</a>
    <a onclick="sp('subadmin',this)">🛡 Sub-Admins</a>
    <a onclick="sp('tree',this)">🌳 Binary Tree</a>
    <div class="ns">Finance</div>
    <a onclick="sp('withdrawals',this)">💸 Withdrawals <span class="nb" id="nb-w"></span></a>
    <a onclick="sp('investments',this)">📈 Investments</a>
    <a onclick="sp('fundac',this)">🏦 Fund Account</a>
    <a onclick="sp('transactions',this)">📋 Transactions</a>
    <div class="ns">Income Engine</div>
    <a onclick="sp('cashback',this)">🎁 Cashback Pool</a>
    <a onclick="sp('clubbonus',this)">🏆 Club Bonus</a>
    <a onclick="sp('roi',this)">💰 ROI Payout</a>
    <a onclick="sp('matching',this)">🤝 Matching</a>
    <a onclick="sp('voucher',this)">🎟 Gift Voucher</a>
    <div class="ns">System</div>
    <a onclick="sp('settings',this)">⚙ Global Settings</a>
    <a onclick="sp('ranks',this)">⭐ Ranks</a>
    <a onclick="sp('buttons',this)">🔘 Dashboard Buttons</a>
    <a onclick="sp('notices',this)">📢 Notices</a>
    <a onclick="sp('incomemgr',this)">💡 Income Manager</a>
    <a onclick="sp('reports',this)">📊 Reports</a>
    <a onclick="sp('backup',this)">💾 Backup & Restore</a>
    <div style="height:10px"></div>
    <a onclick="doLogout()" style="color:#ef4444">🚪 Logout</a>
  </nav>
</aside>

<div class="topbar">
  <div style="display:flex;align-items:center;gap:8px">
    <button class="menu-btn" onclick="toggleSB()">☰</button>
    <span style="font-size:.85rem;font-weight:700;color:#64748b" id="pgLbl">Overview</span>
  </div>
  <div class="tb-r">
    <span style="font-size:.72rem;color:#64748b" id="aEmail">—</span>
    <span style="background:#fee2e2;color:#991b1b;border-radius:6px;padding:2px 9px;font-size:.68rem;font-weight:700">SUPER ADMIN</span>
    <button class="btn btn-gray btn-sm" onclick="doLogout()">Logout</button>
  </div>
</div>

<main class="main">

<!-- OVERVIEW -->
<div class="pg active" id="pg-overview">
  <div class="pg-title">Dashboard Overview</div>
  <div class="cg">
    <div class="sc"><div class="sl">Total Users</div><div class="sv" id="ov-u">0</div><div class="ss" id="ov-ua">0 active</div><div class="si">👥</div></div>
    <div class="sc"><div class="sl">Revenue</div><div class="sv" id="ov-r">$0</div><div class="ss">Activation fees</div><div class="si">💵</div></div>
    <div class="sc"><div class="sl">Company Fund</div><div class="sv" id="ov-f">$0</div><div class="ss">$5 per activation</div><div class="si">🏦</div></div>
    <div class="sc"><div class="sl">Total Invested</div><div class="sv" id="ov-i">$0</div><div class="ss">ROI plans</div><div class="si">📈</div></div>
    <div class="sc"><div class="sl" style="color:#ef4444">Pending Act.</div><div class="sv" id="ov-pa" style="color:#ef4444">0</div><div class="ss">Awaiting approval</div><div class="si">⏳</div></div>
    <div class="sc"><div class="sl" style="color:#ef4444">Pending WD</div><div class="sv" id="ov-pw" style="color:#ef4444">0</div><div class="ss">Awaiting payment</div><div class="si">💸</div></div>
    <div class="sc"><div class="sl">Blocked</div><div class="sv" id="ov-bl">0</div><div class="ss">Users</div><div class="si">🚫</div></div>
    <div class="sc"><div class="sl">Vouchers</div><div class="sv" id="ov-vo">0</div><div class="ss">Active</div><div class="si">🎟</div></div>
  </div>
  <div class="two-col">
    <div class="card">
      <div class="ct">Quick Actions</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px">
        <button class="btn btn-blue" onclick="runCashback()">💰 Cashback</button>
        <button class="btn btn-yellow" onclick="runClub()">🏆 Club Bonus</button>
        <button class="btn btn-green" onclick="runROI()">📈 ROI Payout</button>
        <button class="btn btn-orange" onclick="runMatching()">🤝 Matching</button>
        <button class="btn btn-gray" onclick="sp('voucher',null)">🎟 Voucher</button>
        <button class="btn btn-gray" onclick="sp('backup',null)">💾 Backup</button>
      </div>
      <div style="font-size:.76rem">
        <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f1f5f9"><span style="color:#64748b">ROI Rate</span><span style="font-weight:700;color:#1e293b" id="ov-rr">10%</span></div>
        <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f1f5f9"><span style="color:#64748b">Matching %</span><span style="font-weight:700;color:#1e293b" id="ov-mp">5%</span></div>
        <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f1f5f9"><span style="color:#64748b">Cashback Pool</span><span style="font-weight:700;color:#3b82f6" id="ov-cb">$0</span></div>
        <div style="display:flex;justify-content:space-between;padding:4px 0"><span style="color:#64748b">Club Pool</span><span style="font-weight:700;color:#f59e0b" id="ov-cl">$0</span></div>
      </div>
    </div>
    <div class="card">
      <div class="ct">Latest Activations <button class="btn btn-gray btn-sm" onclick="sp('activations',null)">All →</button></div>
      <div class="tw"><table><thead><tr><th>User</th><th>Date</th><th>Status</th><th>Act</th></tr></thead><tbody id="ov-at"><tr><td colspan="4" style="text-align:center;color:#64748b;padding:12px">Loading…</td></tr></tbody></table></div>
    </div>
  </div>
  <div class="card">
    <div class="ct">Active Notices <button class="btn btn-blue btn-sm" onclick="sp('notices',null)">Manage →</button></div>
    <div id="ov-no" style="font-size:.77rem;color:#64748b">Loading…</div>
  </div>
</div>

<!-- ALL USERS -->
<div class="pg" id="pg-users">
  <div class="pg-title">All Users</div>
  <div class="sb2">
    <input type="text" id="u-s" placeholder="Search name, username, email, ID…" oninput="filterU()"/>
    <select id="u-f" onchange="filterU()">
      <option value="all">All Users</option><option value="active">Active</option>
      <option value="inactive">Inactive</option><option value="blocked">Blocked</option>
