    <div class="ct">Requests <small id="ac-c" style="color:#64748b;font-weight:400"></small></div>
    <div class="tw"><table>
      <thead><tr><th>#</th><th>UID</th><th>Name</th><th>Username</th><th>Email</th><th>Method</th><th>TxID</th><th>Amount</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody id="ac-tb"><tr><td colspan="11" style="text-align:center;color:#64748b;padding:20px">Loading…</td></tr></tbody>
    </table></div>
  </div>
</div>

<!-- EDIT USER -->
<div class="pg" id="pg-edituser">
  <div class="pg-title">Edit User</div>
  <div class="card" style="max-width:480px">
    <div class="fg">
      <label>Search (UID / Username / Email)</label>
      <div style="display:flex;gap:8px"><input type="text" id="eu-q" placeholder="Enter UID, username or email"/><button class="btn btn-blue btn-sm" onclick="searchEU()">Find</button></div>
