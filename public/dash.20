<div id="toast"></div>

<!-- Firebase -->
<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-firestore-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-database-compat.js"></script>
<script>
firebase.initializeApp({
  apiKey:"AIzaSyA3G2bMOJ_HSDYXJPuM70tVjfbkHlMftr4",
  authDomain:"livelinemeta.firebaseapp.com",
  databaseURL:"https://livelinemeta-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId:"livelinemeta",
  storageBucket:"livelinemeta.firebasestorage.app",
  messagingSenderId:"206900805598",
  appId:"1:206900805598:web:10e6b39100af201b4e674f"
});
const auth=firebase.auth(), fsdb=firebase.firestore(), rtdb=firebase.database();
let CU=null,UD=null,ALLU={},ST={};

const DEFS={activationFee:30,companyFund:5,sponsorCommission:4,cashbackLimit:60,
  matchingBonus:5,dailyCap:1000,cashbackPercent:3,clubBonusPercent:4,
  clubMinDirects:10,clubMinMatching:50,roiRate:13,roiMin:12,roiMax:15,
  roiSponsorBonus:5,lockMonths:6,capitalWdCharge:10,
  genBonus:{l1:20,l2:10,l3:8,l4:6,l5:4,l6:3,l7:2}};

const RANKS=[
  {name:'No Rank',icon:'☆',mReq:0,sReq:0},
  {name:'One Star',icon:'⭐',mReq:50,sReq:100},
  {name:'Two Star',icon:'⭐⭐',mReq:300,sReq:300},
  {name:'Three Star',icon:'⭐⭐⭐',mReq:1000,sReq:1000},
  {name:'Four Star',icon:'🌟',mReq:3000,sReq:10000},
  {name:'Five Star',icon:'💫',mReq:10000,sReq:100000},
  {name:'Six Star',icon:'🏆',mReq:30000,sReq:300000},
  {name:'Seven Star',icon:'👑',mReq:100000,sReq:10000000}
];

// ── AUTH ──
auth.onAuthStateChanged(async user=>{
  if(user){CU=user;showApp();await loadSettings();await loadUserData();setupListeners();}
  else showAuth();
});

// ── REGISTER ──
window.doRegister=async()=>{
  const name=v('rName'),user=v('rUser').toLowerCase().trim().replace(/\s+/g,''),
        email=v('rEmail'),phone=v('rPhone'),sponsor=v('rSponsor').trim(),
        pass=v('rPass'),pass2=v('rPass2');
  if(!name||!user||!email||!phone)return toast('Fill all required fields','err');
  if(pass.length<6)return toast('Password min 6 characters','err');
  if(pass!==pass2)return toast('Passwords do not match','err');
  try{
    const uc=await fsdb.collection('users').where('username','==',user).get();
    if(!uc.empty)return toast('Username already taken','err');
    const cred=await auth.createUserWithEmailAndPassword(email,pass);
    const uid=cred.user.uid;
    await fsdb.collection('users').doc(uid).set({
      uid,fullName:name,username:user,email,mobile:phone,
      sponsorId:sponsor||null,myRefCode:user,
      isActive:false,blocked:false,hasInvestment:false,
      walletBalance:0,totalInvested:0,totalWithdrawn:0,cashbackReceived:0,teamSales:0,
      createdAt:firebase.firestore.FieldValue.serverTimestamp(),signupMethod:'email'
    });
    await rtdb.ref(`users/${uid}/income`).set({sponsor:0,matching:0,cashback:0,club:0,roi:0,generation:0});
    await rtdb.ref(`users/${uid}/walletBalance`).set(0);
    toast('✅ Account created! Welcome!','ok');
    switchTab('login');
    document.getElementById('lEmail').value=email;
  }catch(e){
    if(e.code==='auth/email-already-in-use')toast('Email already registered','err');
    else toast(e.message,'err');
  }
};

// ── LOGIN ──
window.doLogin=async()=>{
  const email=v('lEmail'),pass=v('lPass');
  if(!email||!pass)return toast('Enter email and password','err');
  try{await auth.signInWithEmailAndPassword(email,pass);}
  catch(e){toast('Wrong email or password','err');}
};

// ── LOGOUT ──
window.doLogout=async()=>{await auth.signOut();};

// ── FORGOT ──
window.doForgot=async()=>{
  const email=v('lEmail');
  if(!email)return toast('Enter email first','info');
  try{await auth.sendPasswordResetEmail(email);toast('✅ Reset email sent!','ok');}
  catch(e){toast('Could not send reset email','err');}
};

// ── LOAD SETTINGS ──
async function loadSettings(){
  const s=await rtdb.ref('settings').get();
  ST=s.exists()?{...DEFS,...s.val()}:{...DEFS};
  updateSettingsUI();
}

function updateSettingsUI(){
  const gb=ST.genBonus||DEFS.genBonus;
  set('roiRateD',(ST.roiRate||13)+'%');
  set('roiRateShow',(ST.roiRate||13)+'%');
  set('csActFee','$'+(ST.activationFee||30));
  set('csSpComm','$'+(ST.sponsorCommission||4)+' / referral');
  set('csMatch',(ST.matchingBonus||5)+'%');
  set('csCap','$'+(ST.dailyCap||1000).toLocaleString());
  set('csROI',(ST.roiSponsorBonus||5)+'% of ROI');
  set('actSpComm','$'+(ST.sponsorCommission||4));
  set('actCompFund','$'+(ST.companyFund||5));
  set('actTotal','$'+(ST.activationFee||30));
  ['l1','l2','l3','l4','l5','l6','l7'].forEach((k,i)=>set('gb'+(i+1),(gb[k]||0)+'%'));
}

// ── LOAD USER ──
async function loadUserData(){
  if(!CU)return;
  try{
    const doc=await fsdb.collection('users').doc(CU.uid).get();
    if(!doc.exists)return toast('User data not found','err');
    UD={id:CU.uid,...doc.data()};
    const allS=await fsdb.collection('users').get();
    ALLU={};allS.forEach(d=>{ALLU[d.id]={id:d.id,...d.data()};});
    renderAll();
  }catch(e){toast('Load error: '+e.message,'err');}
}

function setupListeners(){
  if(!CU)return;
  rtdb.ref(`users/${CU.uid}/income`).on('value',s=>{if(s.exists()&&UD){UD.income=s.val();renderIncomeCards();}});
  rtdb.ref(`users/${CU.uid}/walletBalance`).on('value',s=>{if(s.exists()&&UD){UD.walletBalance=s.val();renderWalletCards();}});
  rtdb.ref(`transactions/${CU.uid}`).on('value',s=>{renderTransactions(s.exists()?s.val():{});});
  rtdb.ref(`investments/${CU.uid}`).on('value',s=>{renderROIPlans(s.exists()?s.val():{});});
  rtdb.ref('settings').on('value',s=>{if(s.exists()){ST={...DEFS,...s.val()};updateSettingsUI();}});
  // Vouchers
  rtdb.ref(`vouchers/${CU.uid}`).on('value',s=>{if(s.exists())renderVouchers(s.val());});
}

// ── RENDER ALL ──
function renderAll(){
  if(!UD)return;
  const name=UD.fullName||UD.username||'User';
  const init=(name[0]||'U').toUpperCase();
  const h=new Date().getHours();
  const greet=h<12?'Good Morning ☀️':h<17?'Good Afternoon 🌤':h<21?'Good Evening 🌆':'Good Night 🌙';

  // Sidebar
  set('sideInit',init);set('sideName',name);
  const statusDot=document.getElementById('sideStatusDot');
  if(UD.hasInvestment){statusDot.style.background='var(--pink)';set('sideStatus','💎 Investor');}
  else if(UD.isActive){statusDot.style.background='var(--green)';set('sideStatus','✅ Active');}
  else{statusDot.style.background='var(--gold)';set('sideStatus','⚠ Inactive');}

  // Overview
  set('greetMsg',greet+', '+name+'!');
  set('ovJoinDate',UD.createdAt?(UD.createdAt.toDate?UD.createdAt.toDate().toLocaleDateString():new Date(UD.createdAt).toLocaleDateString()):'—');
  set('ovSponsor',UD.sponsorId||'None (Root)');
  set('ovMemberID',UD.username||CU.uid.slice(0,8));
  set('ovUsername','@'+(UD.username||'—'));

  // Status badge
  let statusHTML='';
  if(UD.hasInvestment){
    statusHTML='<span class="status-badge status-investor"><span class="status-dot-m"></span>💎 Active Investor</span>';
  }else if(UD.isActive){
    statusHTML='<span class="status-badge status-active"><span class="status-dot-g"></span>✅ Active Member</span>';
  }else{
    statusHTML='<span class="status-badge status-free"><span class="status-dot-y"></span>⚠ Free (Not Activated)</span>';
  }
  const msb=document.getElementById('mainStatusBadge');if(msb)msb.innerHTML=statusHTML;
  const psb=document.getElementById('pfStatusBadge');if(psb)psb.innerHTML=statusHTML;

  // Activation banner + page
  document.getElementById('actBanner').style.display=UD.isActive?'none':'block';
  document.getElementById('activeCard').style.display=UD.isActive?'block':'none';
  document.getElementById('actFormCard').style.display=UD.isActive?'none':'block';

  // Profile
  set('pfAvatar',init);set('pfNameD',name);set('pfEmailD',UD.email||CU.email||'');
  document.getElementById('pfName').value=UD.fullName||'';
  document.getElementById('pfPhone').value=UD.mobile||'';
  document.getElementById('pfWallet').value=UD.paymentWallet||'';
  set('piUID',CU.uid);set('piUser',UD.username||'—');set('piSponsor',UD.sponsorId||'None');
  set('piJoined',UD.createdAt?(UD.createdAt.toDate?UD.createdAt.toDate().toLocaleDateString():new Date(UD.createdAt).toLocaleDateString()):'—');
  set('piStatus',UD.isActive?'✅ Active':'⚠ Inactive');

  // Referral link
  const base=window.location.href.split('?')[0];
  document.getElementById('refLinkInput').value=base+'?ref='+encodeURIComponent(UD.username||CU.uid);

  // Wallet ID
  set('wMemberID','ID: '+(UD.username||CU.uid.slice(0,8)));

  loadReferrals();
  renderIncomeCards();
  renderRanks();
  renderBinaryTree();
  renderUnilevelTree();
}

function renderIncomeCards(){
  const inc=(UD&&UD.income)||{};
  const sp=+(inc.sponsor||0),mt=+(inc.matching||0),cb=+(inc.cashback||0),
        cl=+(inc.club||0),ro=+(inc.roi||0),ge=+(inc.generation||0);
  const total=sp+mt+cb+cl+ro+ge;
  const wallet=+(UD&&UD.walletBalance||0);
  const wd=+(UD&&UD.totalWithdrawn||0);
  const invested=+(UD&&UD.totalInvested||0);
  const ts=+(UD&&UD.teamSales||0);
  const cap=ST.dailyCap||1000;

  // Overview
  set('ovTotal','$'+total.toFixed(2));
  set('ovWallet','$'+wallet.toFixed(2));
  set('ovInvested','$'+invested.toFixed(0));
  set('ibSp','$'+sp.toFixed(2));set('ibMt','$'+mt.toFixed(2));set('ibCb','$'+cb.toFixed(2));
  set('ibCl','$'+cl.toFixed(2));set('ibRo','$'+ro.toFixed(2));set('ibGe','$'+ge.toFixed(2));
  set('ovCapUsed','$'+Math.min(total,cap).toFixed(0)+' / $'+cap.toLocaleString());
  w('ovCapProg',Math.min((total/cap)*100,100)+'%');

  // Income page
  set('incAll','$'+total.toFixed(2));set('incWd','$'+wd.toFixed(2));
  set('itSp','$'+sp.toFixed(2));set('itMt','$'+mt.toFixed(2));set('itCb','$'+cb.toFixed(2));
  set('itCl','$'+cl.toFixed(2));set('itRo','$'+ro.toFixed(2));set('itGe','$'+ge.toFixed(2));
  set('itInv','$'+invested.toFixed(2));
  set('itCapUsed','$'+Math.min(total,cap).toFixed(0)+'/$'+cap);
  set('itCapLeft','$'+Math.max(0,cap-total).toFixed(2));
  const cbR=+(UD&&UD.cashbackReceived||0),cbLim=ST.cashbackLimit||60;
  set('itCBLimit','$'+cbR.toFixed(2)+'/$'+cbLim);

  // Cashback page
  set('cbEarned','$'+cb.toFixed(2));
  set('cbProgress','$'+cbR.toFixed(2)+' / $'+cbLim.toFixed(2));
  w('cbProg',Math.min((cb/cbLim)*100,100)+'%');
  w('cbProgFull',Math.min((cbR/cbLim)*100,100)+'%');
  const cbEl=document.getElementById('cbStatus');
  if(cbR>=cbLim)cbEl.innerHTML='<span style="color:var(--red)">🔒 Limit Reached</span>';
  else if(UD&&UD.isActive)cbEl.innerHTML='<span class="text-gr">✅ Eligible</span>';
  else cbEl.innerHTML='<span style="color:var(--muted)">Activate first</span>';

  // Club
  const dirCount=Object.values(ALLU).filter(u=>u.sponsorId===CU.uid).length;
  set('clubDir',dirCount+' / '+(ST.clubMinDirects||10));
  set('clubMatch','$'+mt.toFixed(0)+' / $'+(ST.clubMinMatching||50));
  set('clubEarned','$'+cl.toFixed(2));
  const clubOk=dirCount>=(ST.clubMinDirects||10)||mt>=(ST.clubMinMatching||50);
  const ce=document.getElementById('clubElig');
  if(ce)ce.innerHTML=clubOk?'<span class="pill pg">✅ Eligible</span>':'<span class="pill py">Not yet</span>';

  // Rank
  renderRankProgress(mt,ts);
  set('piRank',getCurrentRank(mt,ts).name);
}

function renderWalletCards(){
  const wallet=+(UD&&UD.walletBalance||0);
  const wd=+(UD&&UD.totalWithdrawn||0);
  const inc=(UD&&UD.income)||{};
  const total=Object.values(inc).reduce((s,v)=>s+(+v||0),0);
  set('wBal','$'+wallet.toFixed(2));
  set('wTotalEarned','$'+total.toFixed(2));
  set('wTotalWd','$'+wd.toFixed(2));
}

// ── REFERRALS ──
function loadReferrals(){
  const myRefs=Object.values(ALLU).filter(u=>u.sponsorId===CU.uid);
  const active=myRefs.filter(u=>u.isActive);
  const investors=myRefs.filter(u=>u.hasInvestment);
  set('ovDirects',myRefs.length);set('ovDirectsSub',active.length+' active');
  set('refCountLbl',myRefs.length+' total');
  set('tmTotal',myRefs.length);set('tmActive',active.length);
  set('tmVol','$'+(active.length*(ST.activationFee||30)));
  set('tmInvestors',investors.length);
  const rb=document.getElementById('refTb');
  rb.innerHTML=myRefs.length?myRefs.map(u=>{
    const isInv=u.hasInvestment,isAct=u.isActive;
    let badge=isInv?'<span class="pill pm">💎 Investor</span>':isAct?'<span class="pill pg">✅ Active</span>':'<span class="pill py">⚠ Free</span>';
    return`<tr>
      <td class="fw7">${u.fullName||'User'}</td>
      <td style="color:var(--muted)">@${u.username||'—'}</td>
      <td>${badge}</td>
      <td>${u.createdAt?(u.createdAt.toDate?u.createdAt.toDate().toLocaleDateString():new Date(u.createdAt).toLocaleDateString()):'—'}</td>
      <td class="text-acc">${u.totalInvested?'$'+(u.totalInvested).toFixed(0):'—'}</td>
      <td class="text-gr fw7">${u.isActive?'$'+(ST.sponsorCommission||4).toFixed(2):'$0.00'}</td>
    </tr>`;
  }).join(''):'<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:16px">No referrals yet. Share your link!</td></tr>';
}

// ── BINARY TREE ──
function renderBinaryTree(){
  const c=document.getElementById('binaryTreeContainer');
  if(!UD)return;
  const lc=UD.leftChild,rc=UD.rightChild;
  let lCount=0,rCount=0;
  function count(uid,side){
    if(!uid||!ALLU[uid])return;
    if(side==='l')lCount++;else rCount++;
    const u=ALLU[uid];
    if(u.leftChild)count(u.leftChild,side);
    if(u.rightChild)count(u.rightChild,side);
  }
  if(lc)count(lc,'l');if(rc)count(rc,'r');
  set('btLeft',lCount);set('btRight',rCount);
  set('btWeak',lCount<=rCount?'Left':'Right');

  function nodeBox(uid,label,isYou){
    if(!uid){
      return`<div class="t-node">
        <div class="t-box t-empty"><div class="t-name" style="color:var(--muted)">Empty</div><div class="t-status-icon">—</div></div>
        ${label?`<div class="fs7 mt1" style="color:var(--muted)">${label}</div>`:''}
      </div>`;
    }
    const u=ALLU[uid]||{};
    const isInv=u.hasInvestment,isAct=u.isActive;
    const cls=isYou?'t-you':isInv?'t-investor':isAct?'t-active':'';
    const si=isInv?'💎':isAct?'✅':'⚠';
    return`<div class="t-node">
      <div class="t-box ${cls}" title="${u.fullName||'User'}">
        ${isYou?'<div style="font-size:.55rem;color:var(--accent);margin-bottom:2px">YOU</div>':''}
        <div class="t-name">${u.fullName||u.username||'User'}</div>
        <div class="t-status-icon">${si} ${isInv?'Investor':isAct?'Active':'Free'}</div>
      </div>
      ${label?`<div class="fs7 mt1" style="color:var(--muted);text-align:center">${label}</div>`:''}
    </div>`;
  }

  function lvl2(uid){
    const u=uid&&ALLU[uid];
    const lc2=u?u.leftChild:null,rc2=u?u.rightChild:null;
    return`<div style="display:flex;gap:16px;position:relative">
      ${nodeBox(lc2,'L')} ${nodeBox(rc2,'R')}
    </div>`;
  }

  c.innerHTML=`<div class="tree-root">
    ${nodeBox(CU.uid,'',true)}
    <div class="tree-connector-v"></div>
    <div style="display:flex;gap:48px">
      <div class="t-node" style="align-items:center">
        ${nodeBox(lc,'LEFT')}
        <div class="tree-connector-v"></div>
        ${lvl2(lc)}
      </div>
      <div class="t-node" style="align-items:center">
        ${nodeBox(rc,'RIGHT')}
        <div class="tree-connector-v"></div>
        ${lvl2(rc)}
      </div>
    </div>
  </div>`;
}

// ── UNILEVEL TREE ──
function renderUnilevelTree(){
  const c=document.getElementById('unilevelTreeContainer');
  if(!UD){c.innerHTML='<div style="color:var(--muted)">Login to view</div>';return;}

  function buildLevel(sponsorUID,depth){
    if(depth>7)return'';
    const children=Object.values(ALLU).filter(u=>u.sponsorId===sponsorUID);
    if(!children.length)return'';
    return children.map(u=>{
      const isInv=u.hasInvestment,isAct=u.isActive;
      const color=isInv?'var(--pink)':isAct?'var(--green)':'var(--gold)';
      const icon=isInv?'💎':isAct?'✅':'⚠';
      return`<div class="uni-node">
        <div class="uni-node-box" style="border-color:${color}20">
          <span style="color:${color}">${icon}</span>
          <span class="fw7">${u.fullName||'User'}</span>
          <span style="color:var(--muted)">@${u.username||'—'}</span>
          <span class="pill fs7" style="background:${color}15;color:${color};border:none;padding:2px 6px">L${depth}</span>
        </div>
        <div class="uni-children">${buildLevel(u.id,depth+1)}</div>
      </div>`;
    }).join('');
  }
  const html=buildLevel(CU.uid,1);
  c.innerHTML=html||'<div style="color:var(--muted);font-size:.82rem;padding:10px">No downline yet</div>';
}

// ── RANK ──
function getCurrentRank(matching,teamSales){
  let r=RANKS[0];
  for(let i=1;i<RANKS.length;i++) if(matching>=RANKS[i].mReq&&teamSales>=RANKS[i].sReq)r=RANKS[i];
  return r;
}

function renderRankProgress(matching,teamSales){
  const cur=getCurrentRank(matching,teamSales);
  const curIdx=RANKS.findIndex(r=>r.name===cur.name);
  const next=RANKS[curIdx+1]||null;
  set('curRankIcon',cur.icon);set('curRankName',cur.name);
  set('piRank',cur.name);
  if(next){
    set('rankNextHint','Next: '+next.name+' — need $'+next.mReq+' matching & $'+next.sReq+' team sales');
    w('rankMatchF',Math.min((matching/next.mReq)*100,100)+'%');
    w('rankSalesF',Math.min((teamSales/next.sReq)*100,100)+'%');
    set('rankMatchV','$'+matching.toLocaleString()+' / $'+next.mReq.toLocaleString());
    set('rankSalesV','$'+teamSales.toLocaleString()+' / $'+next.sReq.toLocaleString());
  }else{
    set('rankNextHint','👑 Highest rank achieved!');
  }
}

function renderRanks(){
  const inc=(UD&&UD.income)||{};
  const mt=+(inc.matching||0),ts=+(UD&&UD.teamSales||0);
  const cur=getCurrentRank(mt,ts);
  const grid=document.getElementById('rankGrid');
  if(!grid)return;
  grid.innerHTML=RANKS.slice(1).map(r=>{
    const achieved=mt>=r.mReq&&ts>=r.sReq;
    const isCur=r.name===cur.name;
    return`<div class="rank-3d ${achieved?'achieved':''} ${isCur?'current-rank':''}">
      ${achieved?'<div class="rank-check">✓</div>':''}
      <div class="rank-icon-3d">${r.icon}</div>
      <div class="rank-name-3d">${r.name}</div>
      <div class="rank-req-3d">
        Match: $${r.mReq.toLocaleString()}<br>
        Sales: $${r.sReq.toLocaleString()}
      </div>
      ${achieved?'<div class="pill pg" style="margin-top:6px;font-size:.62rem">Achieved ✓</div>':''}
    </div>`;
  }).join('');
}

// ── TRANSACTIONS ──
function renderTransactions(txObj){
  const txns=Object.entries(txObj).sort(([,a],[,b])=>b.timestamp-a.timestamp);
  set('txCountLbl',txns.length+' records');
  const today=new Date();today.setHours(0,0,0,0);
  const ms=new Date(today.getFullYear(),today.getMonth(),1);
  let td=0,tm=0;
  const rows=txns.map(([id,t])=>{
    const d=new Date(t.timestamp);
    if(d>=today)td+=t.amount||0;if(d>=ms)tm+=t.amount||0;
    const dt=d.toLocaleDateString()+' '+d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
    return`<tr>
      <td style="color:var(--muted);font-size:.71rem">${dt}</td>
      <td>${t.type||'—'}</td>
      <td style="color:var(--muted);font-size:.73rem;max-width:120px;overflow:hidden;text-overflow:ellipsis">${t.note||'—'}</td>
      <td style="font-weight:700;color:${t.amount>0?'var(--green)':'var(--red)'}">
        ${t.amount>0?'+':''}$${Math.abs(t.amount||0).toFixed(2)}</td>
      <td style="color:var(--muted)">$${(t.balance||0).toFixed(2)}</td>
      <td><span class="pill ${t.status==='completed'?'pg':t.status==='pending'?'py':'pb'}">${t.status||'done'}</span></td>
    </tr>`;
  }).join('');
  document.getElementById('incTxTb').innerHTML=rows||'<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:16px">No transactions yet</td></tr>';
  set('incToday','$'+td.toFixed(2));set('incMonth','$'+tm.toFixed(2));
  document.getElementById('ovRecentTx').innerHTML=txns.slice(0,5).map(([,t])=>`
    <tr>
      <td style="font-size:.72rem;color:var(--muted)">${new Date(t.timestamp).toLocaleDateString()}</td>
      <td>${t.type||'—'}</td>
      <td style="font-weight:700;color:${t.amount>0?'var(--green)':'var(--red)'}">
        ${t.amount>0?'+':''}$${Math.abs(t.amount||0).toFixed(2)}</td>
    </tr>`).join('')||'<tr><td colspan="3" style="text-align:center;color:var(--muted)">None</td></tr>';
  // Wallet history
  document.getElementById('walHistTb').innerHTML=txns.slice(0,30).map(([,t])=>`<tr>
    <td>${new Date(t.timestamp).toLocaleDateString()}</td>
    <td>${t.type||'—'}</td>
    <td style="font-weight:700;color:${t.amount>0?'var(--green)':'var(--red)'}">
      ${t.amount>0?'+':''}$${Math.abs(t.amount||0).toFixed(2)}</td>
    <td><span class="pill ${t.status==='completed'?'pg':t.status==='pending'?'py':'pb'}">${t.status||'done'}</span></td>
  </tr>`).join('')||'<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:14px">No transactions</td></tr>';
}

// ── ROI PLANS ──
function renderROIPlans(plans){
  const tb=document.getElementById('roiPlansTb');
  const entries=Object.entries(plans).sort(([,a],[,b])=>b.createdAt-a.createdAt);
  let actCnt=0,nextD=null,totalInv=0,totalROI=0;

  // ROI schedule
  const totalInvestors=Object.values(ALLU).filter(u=>u.hasInvestment).length;
  const daysToROI=totalInvestors<=1?2:Math.min(30,totalInvestors);
  set('roiDay1','2 days');
  set('roiDay10','10 days');

  tb.innerHTML=entries.length?entries.map(([id,p],i)=>{
    if(p.status==='active'){actCnt++;totalInv+=p.amount||0;totalROI+=p.earnedROI||0;}
    const lockEnd=new Date(p.createdAt+(ST.lockMonths||6)*30*24*60*60*1000);
    const locked=Date.now()<lockEnd.getTime();
    if(!nextD&&p.status==='active')nextD=new Date(p.createdAt+daysToROI*24*60*60*1000);
    return`<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td class="text-acc fw7">$${p.amount}</td>
      <td>${new Date(p.createdAt).toLocaleDateString()}</td>
      <td class="text-gr">${p.roiRate||ST.roiRate||13}%</td>
      <td class="text-gld">$${(p.earnedROI||0).toFixed(2)}</td>
      <td>${lockEnd.toLocaleDateString()}</td>
      <td><span class="pill ${p.status==='active'?'pg':p.status==='pending'?'py':'pr'}">${p.status||'pending'}</span></td>
      <td>${!locked&&p.status==='active'
        ?`<button class="btn btn-r btn-sm" onclick="withdrawCapital('${id}')">Withdraw</button>`
        :`<span style="color:var(--muted);font-size:.7rem">${p.status==='pending'?'Awaiting':'Locked'}</span>`}</td>
    </tr>`;
  }).join(''):'<tr><td colspan="8" style="text-align:center;color:var(--muted);padding:16px">No investments yet</td></tr>';
  set('roiActivePlans',actCnt);
  set('roiTotalInv','$'+totalInv.toFixed(2));
  set('roiTotalEarned','$'+totalROI.toFixed(2));
  set('roiNextD',nextD?nextD.toLocaleDateString():'—');
  set('roiNextDate',nextD?nextD.toLocaleDateString():'—');
}

// ── VOUCHERS ──
function renderVouchers(vs){
  const arr=Object.entries(vs).sort(([,a],[,b])=>b.createdAt-a.createdAt);
  if(arr.length){
    const latest=arr[0][1];
    set('voucherCode',latest.code||'——————');
    set('voucherVal',latest.redeemed?'Redeemed':'Value: $'+(latest.value||0));
  }
  document.getElementById('voucherHistTb').innerHTML=arr.length?arr.map(([,v])=>`<tr>
    <td>${new Date(v.createdAt).toLocaleDateString()}</td>
    <td style="font-family:monospace;font-weight:700;color:var(--gold)">${v.code}</td>
    <td class="text-gr fw7">$${v.value||0}</td>
    <td><span class="pill ${v.redeemed?'pg':'pb'}">${v.redeemed?'Redeemed':'Active'}</span></td>
  </tr>`).join(''):'<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:14px">No vouchers yet</td></tr>';
}

// ── ACTIONS ──
window.saveProfile=async()=>{
  try{
    const up={fullName:document.getElementById('pfName').value.trim(),mobile:document.getElementById('pfPhone').value.trim(),paymentWallet:document.getElementById('pfWallet').value.trim(),updatedAt:new Date()};
    await fsdb.collection('users').doc(CU.uid).update(up);
    Object.assign(UD,up);set('sideName',UD.fullName||'User');
    toast('✅ Profile saved!','ok');
  }catch(e){toast('Error: '+e.message,'err');}
};

window.submitActivation=async()=>{
  if(UD&&UD.isActive)return toast('Already active!','info');
  const txid=document.getElementById('actTxid').value.trim();
  const method=document.getElementById('actMethod').value;
  if(!txid)return toast('Enter transaction hash','err');
  try{
    await rtdb.ref('activationRequests').push({
      uid:CU.uid,email:CU.email,name:UD?.fullName||'',username:UD?.username||'',
      txid,method,amount:ST.activationFee||30,status:'pending',createdAt:Date.now()
    });
    toast('✅ Submitted! Awaiting admin approval.','ok');
    document.getElementById('actTxid').value='';
  }catch(e){toast('Error: '+e.message,'err');}
};

window.submitInvestment=async()=>{
  if(!UD?.isActive)return toast('Activate account first!','err');
  const amt=parseFloat(document.getElementById('invAmt').value);
  const txid=document.getElementById('invTxid').value.trim();
  if(!amt||amt<100)return toast('Minimum investment is $100','err');
  if(!txid)return toast('Enter transaction hash','err');
  try{
    await rtdb.ref(`investments/${CU.uid}`).push({
      amount:amt,method:document.getElementById('invMethod').value,txid,
      roiRate:ST.roiRate||13,status:'pending',earnedROI:0,createdAt:Date.now()
    });
    await rtdb.ref(`users/${CU.uid}/totalInvested`).transaction(v=>(v||0)+amt);
    toast('✅ Investment submitted! Admin will activate shortly.','ok');
    document.getElementById('invAmt').value='';
    document.getElementById('invTxid').value='';
  }catch(e){toast('Error: '+e.message,'err');}
};

window.withdrawCapital=async pid=>{
  if(!confirm(`Withdraw capital? ${ST.capitalWdCharge||10}% fee will be deducted.`))return;
  await rtdb.ref(`investments/${CU.uid}/${pid}`).update({status:'withdrawal_requested',wdRequestAt:Date.now()});
  toast('Capital withdrawal requested!','ok');
};

window.submitWithdraw=async()=>{
  const amt=parseFloat(document.getElementById('wdAmt').value);
  const addr=document.getElementById('wdAddr').value.trim();
  if(!amt||amt<10)return toast('Min withdrawal $10','err');
  if(!addr)return toast('Enter wallet address','err');
  const bal=+(UD?.walletBalance||0);
  if(amt>bal)return toast('Insufficient balance','err');
  try{
    const newBal=bal-amt;
    await rtdb.ref(`withdrawals/${CU.uid}`).push({amount:amt,address:addr,status:'pending',createdAt:Date.now()});
    await rtdb.ref(`users/${CU.uid}/walletBalance`).set(newBal);
    await fsdb.collection('users').doc(CU.uid).update({walletBalance:newBal});
    await rtdb.ref(`transactions/${CU.uid}`).push({
      type:'Withdrawal Request',amount:-amt,note:'To: '+addr.slice(0,12)+'…',
      status:'pending',timestamp:Date.now(),balance:newBal
    });
    toast('✅ Withdrawal request submitted!','ok');
    hideWdForm();document.getElementById('wdAmt').value='';document.getElementById('wdAddr').value='';
  }catch(e){toast('Error: '+e.message,'err');}
};

window.redeemVoucher=async()=>{
  const code=document.getElementById('voucherInput').value.trim().toUpperCase();
  if(!code)return toast('Enter voucher code','err');
  try{
    const snap=await rtdb.ref('giftVouchers').orderByChild('code').equalTo(code).get();
    if(!snap.exists())return toast('Invalid voucher code','err');
    const entries=Object.entries(snap.val());
    const [key,v]=entries[0];
    if(v.redeemed)return toast('Voucher already used','err');
    if(v.assignedTo&&v.assignedTo!==CU.uid)return toast('This voucher is not for you','err');
    const newBal=(UD?.walletBalance||0)+(v.value||0);
    await rtdb.ref(`giftVouchers/${key}`).update({redeemed:true,redeemedBy:CU.uid,redeemedAt:Date.now()});
    await rtdb.ref(`users/${CU.uid}/walletBalance`).set(newBal);
    await fsdb.collection('users').doc(CU.uid).update({walletBalance:newBal});
    await rtdb.ref(`transactions/${CU.uid}`).push({
      type:'Gift Voucher Redeemed',amount:v.value||0,note:'Code: '+code,
      status:'completed',timestamp:Date.now(),balance:newBal
    });
    // Save to user vouchers
    await rtdb.ref(`vouchers/${CU.uid}/${key}`).set({...v,redeemed:true});
    toast('🎉 Voucher redeemed! $'+(v.value||0)+' added!','ok');
    document.getElementById('voucherInput').value='';
  }catch(e){toast('Error: '+e.message,'err');}
};

// ── HELPERS ──
window.copyRef=()=>{
  const v2=document.getElementById('refLinkInput').value;
  navigator.clipboard.writeText(v2).then(()=>toast('✅ Link copied!','ok')).catch(()=>{
    document.getElementById('refLinkInput').select();document.execCommand('copy');toast('✅ Copied!','ok');
  });
};
window.shareWA=()=>window.open('https://wa.me/?text=Join+Life+Line+Meta:+'+encodeURIComponent(document.getElementById('refLinkInput').value),'_blank');
window.shareTG=()=>window.open('https://t.me/share/url?url='+encodeURIComponent(document.getElementById('refLinkInput').value)+'&text=Join+Life+Line+Meta','_blank');
window.showWdForm=()=>document.getElementById('wdFormCard').style.display='block';
window.hideWdForm=()=>document.getElementById('wdFormCard').style.display='none';

function showApp(){document.getElementById('authWrap').style.display='none';document.getElementById('appWrap').style.display='block';}
function showAuth(){document.getElementById('authWrap').style.display='flex';document.getElementById('appWrap').style.display='none';}
const v=id=>(document.getElementById(id)?.value||'');
function set(id,val){const el=document.getElementById(id);if(el)el.textContent=val;}
function w(id,val){const el=document.getElementById(id);if(el)el.style.width=val;}

function toast(msg,type='info'){
  const wrap=document.getElementById('toast');
  const t=document.createElement('div');
  t.className=`toast-item t-${type==='err'?'err':type==='ok'?'ok':'info'}`;
  t.textContent=msg;wrap.appendChild(t);
  setTimeout(()=>t.remove(),3200);
}

window.sp=(page,el)=>{
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.sb-item').forEach(s=>s.classList.remove('active'));
  const target=document.getElementById('page-'+page);if(target)target.classList.add('active');
  if(el)el.classList.add('active');
  const labels={overview:'Overview',profile:'Profile',wallet:'Wallet',referral:'Referral',binary:'Binary Tree',unilevel:'Unilevel Tree',team:'My Team',income:'Income Report',roi:'ROI Investment',cashback:'Cashback Pool',club:'Club Bonus',rank:'Rank Progress',voucher:'Gift Voucher',activation:'Activation'};
  set('pgLabel',labels[page]||page);closeSidebar();
  if(page==='binary')renderBinaryTree();
  if(page==='unilevel')renderUnilevelTree();
};

window.toggleSidebar=()=>{document.getElementById('sidebar').classList.toggle('open');document.getElementById('overlay').classList.toggle('show');};
window.closeSidebar=()=>{document.getElementById('sidebar').classList.remove('open');document.getElementById('overlay').classList.remove('show');};
let _lt=false;
window.toggleTheme=()=>{_lt=!_lt;document.body.classList.toggle('light-mode',_lt);set('themeBtn',_lt?'🌙 Dark':'☀ Light');};

// URL ref param
const rp=new URLSearchParams(location.search).get('ref');
if(rp)document.getElementById('rSponsor').value=rp;
</script>
</body>
</html>
