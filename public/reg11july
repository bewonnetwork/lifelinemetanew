/* ── DUPLICATE CHECK: USERNAME ── */
let usernameTimer=null;
document.getElementById('username').addEventListener('input',function(){
  clearTimeout(usernameTimer);
  const val=this.value.trim();
  const msgEl=document.getElementById('usernameMsg');
  this.classList.remove('field-error','field-ok');
  if(!val){msgEl.textContent='';return;}
  usernameTimer=setTimeout(async function(){
    try{
      const snap=await db.collection('users').where('username','==',val).limit(1).get();
      if(!snap.empty){
        document.getElementById('username').classList.add('field-error');
        msgEl.style.color='#dc2626';
        msgEl.textContent='⚠ This username is already taken. Please try a different one.';
      }else{
        document.getElementById('username').classList.add('field-ok');
        msgEl.style.color='#16a34a';
        msgEl.textContent='✓ Username is available!';
      }
    }catch(e){msgEl.textContent='';}
  },600);
});

/* ── DUPLICATE CHECK: EMAIL ── */
let emailTimer=null;
document.getElementById('email').addEventListener('input',function(){
  clearTimeout(emailTimer);
  const val=this.value.trim();
  const msgEl=document.getElementById('emailMsg');
  this.classList.remove('field-error','field-ok');
  if(!val||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)){msgEl.textContent='';return;}
  emailTimer=setTimeout(async function(){
    try{
      const methods=await auth.fetchSignInMethodsForEmail(val);
