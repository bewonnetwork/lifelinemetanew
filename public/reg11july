/* ── MLM BINARY PLACEMENT ── */
async function getRootUserId(){
  try{
    const snap=await db.collection('settings').doc('global').get();
    if(snap.exists&&snap.data().rootUserId)return snap.data().rootUserId;
  }catch(e){}
  return null;
}
async function findUserBySponsorCode(code){
  if(!code)return null;
  try{const d=await db.collection('users').doc(code).get();if(d.exists)return{id:d.id,...d.data()};}catch(e){}
  try{const q=await db.collection('users').where('myRefCode','==',code).limit(1).get();if(!q.empty){const d=q.docs[0];return{id:d.id,...d.data()};}}catch(e){}
  try{const q=await db.collection('users').where('username','==',code).limit(1).get();if(!q.empty){const d=q.docs[0];return{id:d.id,...d.data()};}}catch(e){}
  return null;
}
async function findEmptySlot(startId,preferSide){
  const queue=[startId];const visited=new Set();
  while(queue.length){
    const cur=queue.shift();if(visited.has(cur))continue;visited.add(cur);
    const snap=await db.collection('users').doc(cur).get();
    if(!snap.exists)continue;const data=snap.data();
    const le=!data.leftChild,re=!data.rightChild;
    if(preferSide==='left'){if(le)return{parentId:cur,side:'left'};if(re)return{parentId:cur,side:'right'};}
    else if(preferSide==='right'){if(re)return{parentId:cur,side:'right'};if(le)return{parentId:cur,side:'left'};}
    else{if(le)return{parentId:cur,side:'left'};if(re)return{parentId:cur,side:'right'};}
    if(data.leftChild)queue.push(data.leftChild);
    if(data.rightChild)queue.push(data.rightChild);
  }
  return null;
}
async function resolvePlacement(refCodeInput,placementInput){
  const sponsor=await findUserBySponsorCode(refCodeInput);
  const side=(placementInput==='left'||placementInput==='right')?placementInput:null;
  let startId=sponsor?sponsor.id:await getRootUserId();
  if(!startId)return{sponsorId:null,parentId:null,side:null,isRoot:true};
  const slot=await findEmptySlot(startId,side);
  if(!slot){const rootId=await getRootUserId();if(rootId&&rootId!==startId){const rs=await findEmptySlot(rootId,side);if(rs)return{sponsorId:sponsor?sponsor.id:null,...rs,isRoot:false};}return{sponsorId:sponsor?sponsor.id:null,parentId:startId,side:side||'left',isRoot:false};}
  return{sponsorId:sponsor?sponsor.id:null,...slot,isRoot:false};
}

/* ── FORM SUBMIT ── */
document.getElementById('registerForm').addEventListener('submit',async function(e){
  e.preventDefault();
  const btn=document.getElementById('submitBtn');
  btn.disabled=true;
  setMsg('Creating your account… Please wait.','info');

  const fullName=document.getElementById('fullName').value.trim();
  const username=document.getElementById('username').value.trim();
  const country=document.getElementById('country').value;
  const countryCode=document.getElementById('countryCode').value.trim();
  const mobileRaw=document.getElementById('mobile').value.trim();
  const mobile=countryCode?(countryCode+' '+mobileRaw):mobileRaw;
  const refCodeInput=document.getElementById('refCode').value.trim();
  const placementInput=document.getElementById('placement').value;

  if(!fullName||!username||!country||!mobileRaw){
    setMsg('Please fill in all required fields.','error');
    btn.disabled=false;return;
  }
  if(!document.getElementById('agreeTerms').checked){
    setMsg('Please agree to the Terms & Conditions.','error');
    btn.disabled=false;return;
  }

  // Check username duplicate (final server-side)
  try{
    const usnap=await db.collection('users').where('username','==',username).limit(1).get();
    if(!usnap.empty){
      setMsg('⚠ Username "'+username+'" is already taken. Please choose a different username.','error');
      document.getElementById('username').classList.add('field-error');
      btn.disabled=false;return;
    }
  }catch(err){}

  try{
    let uid,email;

    if(signupMethod==='google'){
      if(!googleUser)throw new Error('Google session expired. Please try again.');
      uid=googleUser.uid;email=googleUser.email;

      // Check if this Google account already exists in Firestore
      const existing=await db.collection('users').doc(uid).get();
      if(existing.exists){
        setMsg('⚠ This Google account is already registered. Please sign in instead.','error');
        btn.disabled=false;return;
      }

    }else{
      email=document.getElementById('email').value.trim();
      const p=document.getElementById('password').value;
      const p2=document.getElementById('password2').value;
      if(!email){setMsg('Please enter your email address.','error');btn.disabled=false;return;}
      if(p!==p2){setMsg('Passwords do not match!','error');btn.disabled=false;return;}
      if(p.length<6){setMsg('Password must be at least 6 characters.','error');btn.disabled=false;return;}

      // Check email duplicate via Firebase Auth
      try{
        const methods=await auth.fetchSignInMethodsForEmail(email);
        if(methods&&methods.length>0){
          setMsg('⚠ This email is already registered. Please sign in or use a different email.','error');
          document.getElementById('email').classList.add('field-error');
          btn.disabled=false;return;
        }
      }catch(err){}

      const cred=await auth.createUserWithEmailAndPassword(email,p);
      uid=cred.user.uid;
    }

    const placement=await resolvePlacement(refCodeInput,placementInput);

    const userDoc={
      fullName,username,email,country,mobile,mobileCode:countryCode,
      signupMethod,refCode:refCodeInput||'',myRefCode:username||uid,
      sponsorId:placement.sponsorId||null,
      parentId:placement.parentId||null,
      side:placement.side||null,
      leftChild:null,rightChild:null,
      isRoot:!!placement.isRoot,
      createdAt:new Date(),
      balance:0
    };

    await db.collection('users').doc(uid).set(userDoc,{merge:true});

    if(placement.parentId&&placement.side){
      const field=placement.side==='left'?'leftChild':'rightChild';
      await db.collection('users').doc(placement.parentId).update({[field]:uid});
    }
    if(placement.isRoot){
      await db.collection('settings').doc('global').set({rootUserId:uid},{merge:true});
    }

    document.getElementById('successId').textContent='Member ID: '+uid.substring(0,12).toUpperCase();
    document.getElementById('successOverlay').classList.add('show');

    // Sign out so user must login fresh — redirect with uid in URL only (no localStorage)
    await auth.signOut();

    // Auto redirect to login after 3 seconds — uid passed via URL for auto-fill
    setTimeout(function(){
      window.location.href='login.html?uid='+encodeURIComponent(uid);
    },3000);

  }catch(err){
    console.error(err);
    // Handle common Firebase errors with friendly messages
    let friendlyMsg=err.message;
    if(err.code==='auth/email-already-in-use'){
      friendlyMsg='⚠ This email is already registered. Please sign in or use a different email.';
      document.getElementById('email').classList.add('field-error');
    }else if(err.code==='auth/invalid-email'){
      friendlyMsg='Please enter a valid email address.';
    }else if(err.code==='auth/weak-password'){
      friendlyMsg='Password is too weak. Please use at least 6 characters.';
    }
    setMsg(friendlyMsg,'error');
    btn.disabled=false;
  }
});
</script>
