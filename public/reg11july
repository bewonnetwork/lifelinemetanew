function isoToFlag(iso){
  if(!iso||iso.length!==2)return'';
  return String.fromCodePoint(...[...iso.toUpperCase()].map(c=>127397+c.charCodeAt(0)));
}

(function populateCountries(){
  const sel=document.getElementById('country');
  sel.innerHTML='<option value="" disabled selected>Select your country</option>'+
    COUNTRIES.map(c=>'<option value="'+c.name+'" data-code="'+c.code+'" data-iso="'+c.iso+'">'+c.name+'</option>').join('');
})();

document.getElementById('country').addEventListener('change',function(){
  const opt=this.options[this.selectedIndex];
  const code=opt.getAttribute('data-code')||'';
  const iso=opt.getAttribute('data-iso')||'';
  document.getElementById('countryCode').value=code;

  const flagSpan=document.getElementById('countryFlagDisplay');
  const wrap=document.getElementById('countryWrap');
  const flag=isoToFlag(iso);
  if(flag){
    flagSpan.textContent=flag;
    flagSpan.style.display='flex';
    wrap.classList.add('has-flag');
  }else{
    flagSpan.textContent='';
    flagSpan.style.display='none';
    wrap.classList.remove('has-flag');
  }
});

/* ── STEP NAVIGATION ── */
let signupMethod=null,googleUser=null;

function goToStep(id){
  document.querySelectorAll('.page-step').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

