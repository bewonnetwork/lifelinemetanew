/* ── PASSWORD STRENGTH & MATCH ── */
const passEl=document.getElementById('password');
const pass2El=document.getElementById('password2');

passEl.addEventListener('input',function(){
  const v=passEl.value;
  const box=document.getElementById('strength');
  if(!v){box.textContent='';return;}
  if(v.length>=8&&/[A-Z]/.test(v)&&/\d/.test(v)&&/[^A-Za-z0-9]/.test(v)){
    box.innerHTML='<span style="color:#16a34a">● Strong</span>';
  }else if(v.length>=6){
    box.innerHTML='<span style="color:#d97706">● Medium</span>';
  }else{
    box.innerHTML='<span style="color:#dc2626">● Weak</span>';
  }
  checkMatch();
});
pass2El.addEventListener('input',checkMatch);

function checkMatch(){
  const box=document.getElementById('match');
  if(!pass2El.value){box.textContent='';return;}
  if(passEl.value===pass2El.value){
    box.innerHTML='<span style="color:#16a34a">✓ Passwords match</span>';
  }else{
    box.innerHTML='<span style="color:#dc2626">✗ Passwords do not match</span>';
  }
}

