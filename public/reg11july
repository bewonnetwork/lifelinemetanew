<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>LIFELINEMETA – Register</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{
      min-height:100vh;
      background:linear-gradient(160deg,#dbeafe 0%,#eff6ff 45%,#e0e7ff 100%);
      font-family:system-ui,sans-serif;
      display:flex;flex-direction:column;align-items:center;
    }

    /* ── BLUE PAGE BORDER ── */
    body::before{
      content:'';
      position:fixed;inset:0;
      border:3px solid rgba(30,58,138,0.18);
      border-radius:0;
      pointer-events:none;
      z-index:1000;
      box-shadow:inset 0 0 40px rgba(30,58,138,0.07);
    }

    .header{
      width:100%;max-width:500px;padding:30px 20px 6px;
      display:flex;flex-direction:column;align-items:center;gap:10px;
    }
    .logo{
      width:72px;height:72px;border-radius:50%;object-fit:cover;
      border:3px solid #1e3a8a;background:#fff;
      box-shadow:0 6px 20px -4px rgba(30,58,138,0.4);
    }
    .title{font-size:24px;font-weight:900;color:#1e3a8a;letter-spacing:.8px;}

    .container{width:100%;max-width:500px;padding:10px 16px 50px;}

    /* ── 3D CARD ── */
    .card{
      background:#fff;border-radius:22px;padding:34px 30px;
      border:2px solid rgba(30,58,138,0.22);
      box-shadow:
        0 1px 0 rgba(255,255,255,.9) inset,
        0 4px 0 rgba(30,58,138,0.08) inset,
        0 6px 0 rgba(30,58,138,0.22),
        0 12px 0 rgba(30,58,138,0.12),
        0 18px 0 rgba(30,58,138,0.06),
        0 28px 60px -10px rgba(30,58,138,0.35),
        0 10px 20px -6px rgba(30,58,138,0.2);
      position:relative;
    }

    h1{
      text-align:center;color:#111827;margin-bottom:6px;
      font-size:22px;font-weight:900;
      display:flex;align-items:center;justify-content:center;gap:8px;
    }
    .subtitle{
      text-align:center;color:#6b7280;font-size:13px;
      margin-bottom:22px;font-weight:600;
    }

    /* ── METHOD BUTTONS ── */
    .method-options{display:flex;flex-direction:column;gap:12px;margin-top:4px;}
    .method-btn{
      width:100%;padding:16px 18px;border:2px solid #1e3a8a;border-radius:14px;
      background:#fff;display:flex;align-items:center;gap:14px;
      cursor:pointer;font-size:15px;font-weight:800;color:#111827;
      transition:.18s;text-align:left;
      box-shadow:0 8px 20px -6px rgba(30,58,138,0.3),0 2px 4px rgba(0,0,0,0.04);
    }
    .method-btn:hover{background:#eff6ff;transform:translateY(-2px);box-shadow:0 14px 26px -6px rgba(30,58,138,0.4);}
    .method-btn.google-btn{border-color:#dadce0;}
    .method-btn.google-btn:hover{background:#f8f9fb;border-color:#bfdbfe;}
    .method-btn .m-icon{
      width:42px;height:42px;flex-shrink:0;border-radius:10px;
      background:#1e3a8a;display:flex;align-items:center;justify-content:center;
    }
    .method-btn.google-btn .m-icon{background:#fff;border:1px solid #e5e7eb;}
    .method-btn .m-icon svg{width:22px;height:22px;stroke:#fff;fill:none;stroke-width:1.8;}
    .method-btn .m-text small{display:block;font-weight:600;color:#6b7280;font-size:12px;margin-top:2px;}

    /* ── GOOGLE EMAIL BOX ── */
    .google-email-box{
      display:flex;align-items:center;gap:10px;
      background:#eff6ff;border:1.5px solid #1e3a8a;border-radius:12px;
      padding:13px 14px;margin-bottom:18px;
      box-shadow:0 4px 10px -4px rgba(30,58,138,0.18);
    }
    .google-email-box svg{width:20px;height:20px;stroke:#1e3a8a;fill:none;stroke-width:1.8;flex-shrink:0;}
    .google-email-box .ge-text{font-size:14px;color:#111827;font-weight:700;word-break:break-all;}
    .google-email-box .ge-label{font-size:11px;color:#6b7280;font-weight:600;display:block;}

    /* ── FORM FIELDS ── */
    .form-group{margin-bottom:16px;position:relative;}
    label{font-size:13.5px;font-weight:800;color:#111827;margin-bottom:5px;display:block;}
    input,select{
      width:100%;padding:13px 14px 13px 44px;
      border:1.5px solid #93c5fd;
      border-radius:10px;font-size:15px;background:#f8faff;
      font-weight:600;color:#111827;outline:none;
      transition:border-color .2s,box-shadow .2s;
    }
    input:focus,select:focus{
      border-color:#1e3a8a;
      box-shadow:0 0 0 3px rgba(30,58,138,0.14);
      background:#fff;
    }
    input:read-only{background:#e5e7eb;color:#374151;}
    input::placeholder{font-weight:500;color:#9ca3af;}
    input.field-error{border-color:#ef4444;box-shadow:0 0 0 3px rgba(239,68,68,0.12);}
    input.field-ok{border-color:#22c55e;box-shadow:0 0 0 3px rgba(34,197,94,0.1);}

    /* ── FIELD ICON (left) ── */
    .f-icon{
      position:absolute;left:13px;top:37px;
      width:20px;height:20px;
      display:flex;align-items:center;justify-content:center;
      pointer-events:none;
    }
    .f-icon svg{width:18px;height:18px;stroke:#1e3a8a;fill:none;stroke-width:2;}

    /* ── EYE TOGGLE ── */
    .eye{
      position:absolute;right:12px;top:35px;cursor:pointer;
      width:24px;height:24px;display:flex;align-items:center;justify-content:center;
    }
    .eye svg{width:20px;height:20px;stroke:#1e3a8a;fill:none;stroke-width:1.8;}

    /* ── MOBILE ROW ── */
    .mobile-row{display:flex;gap:8px;}
    .mobile-row .code-box{width:100px;flex-shrink:0;position:relative;}
    .mobile-row .code-box input{padding-left:12px;text-align:center;font-weight:800;background:#eff6ff;border-color:#1e3a8a;}
    .mobile-row .phone-box{flex:1;position:relative;}
    .mobile-row .phone-box .f-icon{left:13px;top:15px;}
    .mobile-row .phone-box input{padding-left:44px;}

    /* ── COUNTRY FLAG (original system restored) ── */
    .country-wrap{position:relative;}
    .country-wrap select{padding-left:44px;}
    .country-flag-display{
      position:absolute;
      left:44px;
      top:50%;
      transform:translateY(-50%);
      font-size:20px;
      line-height:1;
      pointer-events:none;
      z-index:2;
      display:none;
    }
    .country-wrap.has-flag select{padding-left:72px;}

    /* ── STRENGTH & MATCH ── */
    .strength,.match{font-size:12.5px;margin-top:4px;font-weight:700;}
    .hint{font-size:12px;color:#6b7280;margin-top:4px;font-weight:600;}

    /* ── TERMS ── */
    .terms-row{
      display:flex;align-items:flex-start;gap:8px;
      margin:14px 0 6px;font-size:13px;color:#111827;font-weight:600;
    }
    .terms-row input[type=checkbox]{
      width:17px;height:17px;padding:0;accent-color:#1e3a8a;
      margin-top:2px;border:none;flex-shrink:0;
    }

    /* ── SUBMIT BUTTON with seed symbol ── */
    .submit-btn{
      width:100%;padding:16px 20px;
      background:linear-gradient(135deg,#1e3a8a,#2563eb);
      color:#fff;border:none;border-radius:12px;
      font-size:16px;font-weight:900;letter-spacing:.4px;
      margin-top:10px;cursor:pointer;
      display:flex;align-items:center;justify-content:center;gap:10px;
      box-shadow:0 8px 20px -4px rgba(30,58,138,0.55),0 2px 4px rgba(0,0,0,0.08);
      transition:.18s;
    }
    .submit-btn:hover{
      background:linear-gradient(135deg,#1d4ed8,#3b82f6);
      transform:translateY(-2px);
      box-shadow:0 14px 28px -4px rgba(29,78,216,0.6);
    }
    .submit-btn:active{transform:translateY(0);}
    .submit-btn:disabled{background:#9ca3af;cursor:not-allowed;box-shadow:none;transform:none;}
    /* seed symbol inside button */
    .btn-seed{
      width:26px;height:26px;background:rgba(255,255,255,0.2);
      border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;
    }
    .btn-seed svg{width:16px;height:16px;stroke:#fff;fill:none;stroke-width:2;}

    .back-link{
      display:inline-flex;align-items:center;gap:6px;
      font-size:13px;color:#1e3a8a;font-weight:800;cursor:pointer;
      margin-bottom:16px;background:none;border:none;padding:0;
      box-shadow:none;width:auto;
    }
    .back-link svg{width:16px;height:16px;stroke:#1e3a8a;fill:none;stroke-width:2.5;}
    .back-link:hover{background:none;transform:none;box-shadow:none;text-decoration:underline;}

    /* ── MESSAGE AREA ── */
    #message{
      text-align:center;margin:12px 0 4px;font-weight:700;
      min-height:24px;font-size:13.5px;border-radius:8px;padding:0 4px;
    }
    .msg-error{color:#dc2626;background:#fef2f2;border:1px solid #fecaca;padding:9px 14px!important;border-radius:8px;}
    .msg-info{color:#1e3a8a;background:#eff6ff;border:1px solid #bfdbfe;padding:9px 14px!important;border-radius:8px;}

    .signin-row{
      text-align:center;margin-top:18px;font-size:14px;color:#374151;font-weight:600;
    }
    .signin-row a{color:#1e3a8a;font-weight:900;text-decoration:none;}
    .signin-row a:hover{text-decoration:underline;}

    /* ── SUCCESS OVERLAY ── */
    .success-overlay{
      position:fixed;inset:0;background:rgba(239,246,255,0.97);
      display:none;align-items:center;justify-content:center;
      flex-direction:column;z-index:999;gap:16px;text-align:center;padding:20px;
    }
    .success-overlay.show{display:flex;}
    .success-circle{
      width:90px;height:90px;border-radius:50%;background:#1e3a8a;
      display:flex;align-items:center;justify-content:center;
      animation:popIn .45s cubic-bezier(.34,1.56,.64,1);
      box-shadow:0 10px 30px -6px rgba(30,58,138,0.45);
    }
    .success-circle svg{width:46px;height:46px;stroke:#fff;fill:none;stroke-width:2.2;}
    @keyframes popIn{0%{transform:scale(0);opacity:0;}100%{transform:scale(1);opacity:1;}}
    .success-title{font-size:22px;font-weight:900;color:#111827;}
    .success-sub{font-size:14px;color:#6b7280;max-width:320px;font-weight:600;line-height:1.6;}
    .success-id{
      font-size:13px;color:#1e3a8a;font-weight:800;
      background:#eff6ff;padding:10px 20px;border-radius:10px;
      border:1px solid #bfdbfe;letter-spacing:.5px;
    }
    .success-loader{
      width:28px;height:28px;border:3px solid #dbeafe;
      border-top-color:#1e3a8a;border-radius:50%;
      animation:spin .8s linear infinite;
    }
    @keyframes spin{to{transform:rotate(360deg)}}

    .page-step{display:none;}
    .page-step.active{display:block;}
  </style>
</head>
<body>

<div class="header">
  <img src="assets/images/logo.jpeg" alt="LIFELINEMETA" class="logo"
       onerror="this.onerror=null;this.src='assets/logo/livelinemeta.png';">
  <div class="title">LIFELINEMETA</div>
</div>

<div class="container">
  <div class="card">

    <!-- =========================================================
         STEP 0 — CHOOSE METHOD
    ========================================================== -->
    <div class="page-step active" id="step-method">
      <h1>
        <svg width="22" height="22" viewBox="0 0 24 24" style="stroke:#1e3a8a;fill:none;stroke-width:2;flex-shrink:0;">
          <path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/>
        </svg>
        CREATE ACCOUNT
      </h1>
      <div class="subtitle">Choose how you'd like to register</div>

      <div class="method-options">
        <button type="button" class="method-btn google-btn" id="chooseGoogleBtn">
          <span class="m-icon">
            <svg viewBox="0 0 48 48" style="width:24px;height:24px;stroke:none;">
              <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
              <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/>
              <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 35.091 26.715 36 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/>
              <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
            </svg>
          </span>
          <span class="m-text">Continue with Google
            <small>Use your Google account email</small>
          </span>
        </button>

        <button type="button" class="method-btn" id="chooseEmailBtn">
          <span class="m-icon">
            <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
          </span>
          <span class="m-text">Continue with Email
            <small>Sign up using your own email address</small>
          </span>
        </button>
      </div>

      <div class="signin-row">Already have an account? <a href="login.html">Sign In</a></div>
    </div>

    <!-- =========================================================
         STEP 1 — REGISTRATION FORM
    ========================================================== -->
    <div class="page-step" id="step-form">
      <button type="button" class="back-link" id="backToMethodBtn">
        <svg viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>
        Back
      </button>

      <h1>
        <svg width="22" height="22" viewBox="0 0 24 24" style="stroke:#1e3a8a;fill:none;stroke-width:2;flex-shrink:0;">
          <path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/>
        </svg>
        CREATE ACCOUNT
      </h1>

      <!-- Google email display -->
      <div class="google-email-box" id="googleEmailBox" style="display:none">
        <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        <div>
          <span class="ge-label">Signed in with Google</span>
          <span class="ge-text" id="googleEmailText">—</span>
        </div>
      </div>

      <form id="registerForm" novalidate>

        <!-- FULL NAME -->
        <div class="form-group">
          <label>Full Name</label>
          <span class="f-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></span>
          <input type="text" id="fullName" placeholder="Full Name" autocomplete="off" required>
        </div>

        <!-- USERNAME with live duplicate check -->
        <div class="form-group">
          <label>Username</label>
          <span class="f-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M16 15v-3a4 4 0 1 0-1.5 3.1"/></svg></span>
          <input type="text" id="username" placeholder="Username" autocomplete="off" required>
          <div id="usernameMsg" class="hint"></div>
        </div>

        <!-- EMAIL (email method only) -->
        <div class="form-group" id="emailFieldGroup">
          <label>Email</label>
          <span class="f-icon"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></span>
          <input type="email" id="email" placeholder="Email Address" autocomplete="off">
          <div id="emailMsg" class="hint"></div>
        </div>

        <!-- COUNTRY -->
        <div class="form-group">
          <label>Country</label>
          <div class="country-wrap" id="countryWrap">
            <span class="f-icon" style="top:50%;transform:translateY(-50%);">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18a14 14 0 0 1 0-18Z"/></svg>
            </span>
            <span class="country-flag-display" id="countryFlagDisplay"></span>
            <select id="country" required></select>
          </div>
        </div>

        <!-- MOBILE NUMBER -->
        <div class="form-group">
          <label>Mobile Number</label>
          <div class="mobile-row">
            <div class="code-box">
              <input type="text" id="countryCode" placeholder="+0" readonly>
            </div>
            <div class="phone-box">
              <span class="f-icon">
                <svg viewBox="0 0 24 24"><rect x="6" y="2" width="12" height="20" rx="2"/><path d="M11 18h2"/></svg>
              </span>
              <input type="tel" id="mobile" placeholder="Mobile Number" autocomplete="off" required>
            </div>
          </div>
          <div class="hint">Select your country — the dial code fills in automatically.</div>
        </div>

        <!-- REFERRAL CODE -->
        <div class="form-group">
          <label>Referral Code <span style="font-weight:500;color:#9ca3af">(Optional)</span></label>
          <span class="f-icon"><svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.07 0l1.93-1.93a5 5 0 0 0-7.07-7.07L10.5 5.5"/><path d="M14 11a5 5 0 0 0-7.07 0l-1.93 1.93a5 5 0 0 0 7.07 7.07L13.5 18.5"/></svg></span>
          <input type="text" id="refCode" placeholder="Leave empty for auto-placement" autocomplete="off">
          <div class="hint">No sponsor? Leave empty — you'll be auto-placed.</div>
        </div>

        <!-- PLACEMENT SIDE -->
        <div class="form-group">
          <label>Placement Side <span style="font-weight:500;color:#9ca3af">(Optional)</span></label>
          <span class="f-icon"><svg viewBox="0 0 24 24"><path d="M3 12h18"/><path d="m12 5-7 7 7 7"/><path d="m12 5 7 7-7 7"/></svg></span>
          <select id="placement">
            <option value="">Auto (system will choose)</option>
            <option value="left">Left</option>
            <option value="right">Right</option>
          </select>
        </div>

        <!-- PASSWORD FIELDS (email method only) -->
        <div id="passwordFieldsGroup">
          <div class="form-group">
            <label>Password</label>
            <span class="f-icon"><svg viewBox="0 0 24 24"><rect x="4" y="11" width="16" height="9" rx="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4"/></svg></span>
            <input type="password" id="password" placeholder="Password" autocomplete="new-password">
            <span class="eye" id="eye1">
              <svg viewBox="0 0 24 24"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </span>
            <div id="strength" class="strength"></div>
          </div>

          <div class="form-group">
            <label>Confirm Password</label>
            <span class="f-icon"><svg viewBox="0 0 24 24"><rect x="4" y="11" width="16" height="9" rx="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4"/></svg></span>
            <input type="password" id="password2" placeholder="Confirm Password" autocomplete="new-password">
            <span class="eye" id="eye2">
              <svg viewBox="0 0 24 24"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </span>
            <div id="match" class="match"></div>
          </div>
        </div>

        <!-- TERMS -->
        <label class="terms-row">
          <input type="checkbox" id="agreeTerms">
          <span>I agree to the <a href="#" style="color:#1e3a8a;font-weight:800;">Terms &amp; Conditions</a></span>
        </label>

        <!-- SUBMIT with seed symbol inside -->
        <button type="submit" class="submit-btn" id="submitBtn">
          <span class="btn-seed">
            <svg viewBox="0 0 24 24">
              <!-- seed / sprout symbol -->
              <path d="M12 22V12"/>
              <path d="M12 12C12 12 8 8 4 10c-2 1-2 4 0 5 3 2 8-3 8-3z"/>
              <path d="M12 12c0 0 4-4 8-2 2 1 2 4 0 5-3 2-8-3-8-3z"/>
            </svg>
          </span>
          REGISTER NOW
        </button>
      </form>

      <div id="message"></div>
      <div class="signin-row">Already have an account? <a href="login.html">Sign In</a></div>
    </div>

  </div>
</div>

<!-- =========================================================
     SUCCESS OVERLAY
========================================================== -->
<div class="success-overlay" id="successOverlay">
  <div class="success-circle">
    <svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>
  </div>
  <div class="success-title">Registration Successful!</div>
  <div class="success-sub">Your account has been created.<br>Redirecting to login page…</div>
  <div class="success-id" id="successId">ID: —</div>
  <div class="success-loader"></div>
</div>

<!-- Firebase -->
<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-firestore-compat.js"></script>

<script>
/* ── FIREBASE CONFIG ── */
const firebaseConfig = {
