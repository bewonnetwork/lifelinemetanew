        document.getElementById('email').classList.add('field-error');
        msgEl.style.color='#dc2626';
        msgEl.textContent='⚠ This email is already registered. Please sign in or use a different email.';
      }else{
        document.getElementById('email').classList.add('field-ok');
        msgEl.style.color='#16a34a';
        msgEl.textContent='✓ Email is available!';
      }
    }catch(e){msgEl.textContent='';}
