// ── RANK ─────────────────────────────────────────────
const RANKS=[
  {n:'One Star',st:'⭐',m:50,s:100},{n:'Two Star',st:'⭐⭐',m:300,s:300},
  {n:'Three Star',st:'⭐⭐⭐',m:1000,s:1000},{n:'Four Star',st:'⭐⭐⭐⭐',m:3000,s:10000},
  {n:'Five Star',st:'⭐⭐⭐⭐⭐',m:10000,s:100000},{n:'Six Star',st:'6⭐',m:30000,s:300000},
  {n:'Seven Star',st:'7⭐',m:100000,s:10000000}
];
function getRank(){
  const matching=+(UD.income?.matching||0);
  const saved=S.ranks||{};
  let current={name:'No Rank',st:'☆'};
  RANKS.forEach((r,i)=>{
    const sr=saved['rank'+(i+1)]||{};
    const minM=sr.minMatching||r.m;
    if(matching>=minM)current={name:r.n,st:r.st};
  });
  return current;
}
function renderRank(){
  const matching=+(UD.income?.matching||0);
  const saved=S.ranks||{};
  const rk=getRank();
  sv('rkStars',rk.st);sv('rkName',rk.name);
  // Find next rank
  let nextRk=null;
  for(let i=0;i<RANKS.length;i++){
    const sr=saved['rank'+(i+1)]||{};
    const minM=sr.minMatching||RANKS[i].m;
    if(matching<minM){nextRk={...RANKS[i],minM,need:minM-matching};break;}
  }
  sv('rkNext',nextRk?'Next: '+nextRk.n+' (need $'+fmtN(nextRk.need)+' more matching)':'🏆 Highest Rank!');
  // Rank bars
  el('rkBars').innerHTML=RANKS.map((r,i)=>{
    const sr=saved['rank'+(i+1)]||{};
    const minM=sr.minMatching||r.m;
    const pct=Math.min(100,Math.round(matching/minM*100));
    const done=matching>=minM;
    return`<div style="margin-bottom:9px;text-align:left">
      <div style="display:flex;justify-content:space-between;font-size:.74rem;margin-bottom:3px">
        <span style="font-weight:700;color:${done?'var(--grn)':'var(--tex)'}">${r.st} ${r.n}</span>
        <span style="color:var(--mut)">$${fmtN(matching)} / $${fmtN(minM)}</span>
      </div>
      <div class="prog"><div class="prog-f" style="width:${pct}%;${done?'background:var(--grn)':''}"></div></div>
    </div>`;
  }).join('');
  sv('rkTb',RANKS.map((r,i)=>{
    const sr=saved['rank'+(i+1)]||{};
    return`<tr>
      <td style="font-weight:700">${r.st} ${r.n}</td>
      <td style="color:var(--blue);font-weight:700">$${fmtN(sr.minMatching||r.m)}</td>
      <td style="color:var(--mut)">$${fmtN(sr.minSales||r.s)}</td>
    </tr>`;
  }).join(''));
}

// ── MONTHLY SALARY ────────────────────────────────────
function renderSalary(){
  const inc=UD.income||{};
  const sponsor=+(inc.sponsor||0),matching=+(inc.matching||0);
  const cashback=+(inc.cashback||0),club=+(inc.club||0);
  const roi=+(inc.roi||0),gen=+(inc.generation||0);
  // Monthly estimate based on total
  const total=sponsor+matching+cashback+club+roi+gen;
  sv('salTotal','$'+fmtN(total));
  const items=[
    {name:'Sponsor Commission',val:sponsor,ico:'🤝'},
    {name:'Matching Bonus',val:matching,ico:'⚖'},
    {name:'Cashback',val:cashback,ico:'🎁'},
    {name:'Club Bonus',val:club,ico:'🏆'},
    {name:'ROI Returns (50%)',val:roi,ico:'📈'},
    {name:'Generation Bonus',val:gen,ico:'🔗'},
  ];
  el('salBreakdown').innerHTML=items.map(item=>`
    <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid #f1f5f9">
      <div style="display:flex;align-items:center;gap:10px">
        <div style="width:34px;height:34px;border-radius:9px;background:var(--bluelt);display:flex;align-items:center;justify-content:center;font-size:.95rem">${item.ico}</div>
        <span style="font-size:.82rem;font-weight:600;color:var(--tex)">${item.name}</span>
      </div>
      <span style="font-weight:800;color:var(--blue);font-size:.9rem">$${fmtN(item.val)}</span>
    </div>`).join('');
  // History (by month from transactions)
  const months={};
  TX.forEach(t=>{
    if(!t.timestamp)return;
    const d=new Date(t.timestamp);
    const mk=d.getFullYear()+'-'+(d.getMonth()+1);
    if(!months[mk])months[mk]={sp:0,mt:0,roi:0,oth:0};
    const a=+(t.amount||0);
    if(a<=0)return;
    if((t.type||'').includes('Sponsor'))months[mk].sp+=a;
    else if((t.type||'').includes('Matching'))months[mk].mt+=a;
    else if((t.type||'').includes('ROI'))months[mk].roi+=a;
    else months[mk].oth+=a;
  });
  const mEntries=Object.entries(months).sort(([a],[b])=>b.localeCompare(a));
  sv('salHistTb',mEntries.length?mEntries.map(([mk,m])=>{
    const tot=m.sp+m.mt+m.roi+m.oth;
    return`<tr>
      <td style="font-weight:700">${mk}</td>
      <td>$${fmtN(m.sp)}</td><td>$${fmtN(m.mt)}</td>
      <td>$${fmtN(m.roi)}</td><td>$${fmtN(m.oth)}</td>
      <td style="font-weight:800;color:var(--blue)">$${fmtN(tot)}</td>
    </tr>`;
  }).join(''):'<tr><td colspan="6" style="text-align:center;color:var(--mut);padding:14px">No salary history yet</td></tr>');
}

