let p2pTargetUID=null;
window.findP2PUser=async()=>{
  const q=(el('p2pTo').value||'').trim().toLowerCase();
  if(!q){toast('Enter username or UID');return;}
  if(q===UD.username?.toLowerCase()||q===CU){toast('Cannot send to yourself');return;}
  const found=Object.values(AU).find(u=>
