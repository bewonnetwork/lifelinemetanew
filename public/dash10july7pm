<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0"/>
<title>Life Line Meta</title>
<style>
:root{
  --bg:#f0f4f8;--sur:#fff;--card:#fff;--bor:#e2e8f0;
  --blue:#1d4ed8;--blue2:#2563eb;--bluelt:#dbeafe;--bluedk:#1e40af;
  --tex:#1e293b;--mut:#64748b;--grn:#16a34a;--red:#dc2626;--gol:#b45309;
  --shadow:0 2px 12px rgba(30,64,175,.08);
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--tex);min-height:100vh;max-width:480px;margin:0 auto;position:relative}
button{cursor:pointer;font-family:inherit}
input,select,textarea{font-family:inherit}
::-webkit-scrollbar{width:0}

/* NOTICE BAR - below header */
.nbar{background:var(--bluedk);overflow:hidden;position:fixed;top:56px;left:50%;transform:translateX(-50%);width:100%;max-width:480px;z-index:98;display:none}
.ntrack{display:inline-block;animation:marq 35s linear infinite;font-size:.72rem;white-space:nowrap;padding:6px 16px;color:#fff}
.ntrack:hover{animation-play-state:paused}
@keyframes marq{0%{transform:translateX(100%)}100%{transform:translateX(-100%)}}
.nitem-urgent{color:#fde68a;font-weight:700}

/* HEADER */
.hdr{position:fixed;top:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;height:56px;background:var(--blue);z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 16px;box-shadow:0 2px 8px rgba(30,64,175,.18)}
.hdr-logo{font-size:.88rem;font-weight:900;color:#fff;letter-spacing:.3px}
.hdr-logo span{font-size:.65rem;color:#bfdbfe;display:block;font-weight:400}
.hdr-bal{text-align:center;cursor:pointer}
.hdr-bal .lbl{font-size:.6rem;color:#bfdbfe;display:block}
.hdr-bal .amt{font-size:1rem;font-weight:800;color:#fff}
.hdr-right{display:flex;align-items:center;gap:8px}
.hdr-av{width:32px;height:32px;border-radius:50%;background:#1e40af;border:2px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:800;color:#fff;flex-shrink:0;cursor:pointer}

/* UPGRADE BADGE */
.upg-btn{background:#fff;color:var(--blue);border:none;border-radius:20px;padding:3px 10px;font-size:.66rem;font-weight:800;cursor:pointer;white-space:nowrap}

/* MAIN */
.main{padding-top:56px;min-height:100vh;padding-bottom:70px}
.notice-space{height:0;transition:height .2s}
.page{display:none;padding:14px}
.page.active{display:block}
.pg-title{font-size:1.05rem;font-weight:800;margin-bottom:13px;color:var(--tex)}

/* BOTTOM NAV */
.bnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:var(--sur);border-top:1px solid var(--bor);display:flex;z-index:200;box-shadow:0 -2px 10px rgba(0,0,0,.07)}
.bnav a{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 2px;cursor:pointer;color:var(--mut);font-size:.59rem;font-weight:600;gap:3px;transition:.15s;text-decoration:none}
.bnav a.active{color:var(--blue)}
.bnav a .ico{width:26px;height:26px;display:flex;align-items:center;justify-content:center;transition:.2s}
.bnav a.active .ico{transform:scale(1.15)}

/* DRAWER MENU */
.drawer-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:299}
.drawer-bg.show{display:block}
.drawer{position:fixed;top:0;right:-280px;height:100vh;width:270px;background:var(--sur);z-index:300;transition:right .28s;overflow-y:auto;box-shadow:-4px 0 20px rgba(0,0,0,.12)}
.drawer.open{right:0}
.drawer-head{background:var(--blue);padding:20px 16px 16px;color:#fff}
.drawer-head h3{font-size:1rem;font-weight:800}
.drawer-head p{font-size:.72rem;color:#bfdbfe;margin-top:2px}
.dm{display:block;padding:13px 16px;font-size:.82rem;color:var(--tex);cursor:pointer;border-bottom:1px solid var(--bor);display:flex;align-items:center;gap:12px;text-decoration:none}
.dm:hover{background:var(--bluelt)}
.dm .dic{width:34px;height:34px;border-radius:10px;background:linear-gradient(145deg,#1d4ed8,#1e40af);display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;box-shadow:0 3px 8px rgba(29,78,216,.25)}
.dm .dtxt{font-weight:600;color:var(--tex);display:block;font-size:.8rem}
.dm .dsub{font-size:.67rem;color:var(--mut);display:block;margin-top:1px}

/* CARDS */
.cg{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.cg3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:14px}
.sc{background:var(--sur);border-radius:14px;padding:14px;box-shadow:var(--shadow);border:1px solid var(--bor);position:relative;overflow:hidden}
.sc-ico{width:40px;height:40px;border-radius:12px;background:var(--bluelt);display:flex;align-items:center;justify-content:center;font-size:1.1rem;margin-bottom:9px;box-shadow:0 3px 8px rgba(30,64,175,.12)}
.sc-lbl{font-size:.65rem;color:var(--mut);text-transform:uppercase;letter-spacing:.3px;margin-bottom:3px}
.sc-val{font-size:1.25rem;font-weight:900;color:var(--tex)}
.sc-sub{font-size:.63rem;color:var(--mut);margin-top:2px}

/* WALLET CARD (hero) */
.wallet-hero{background:linear-gradient(135deg,var(--blue),var(--bluedk));border-radius:18px;padding:20px;color:#fff;margin-bottom:14px;position:relative;overflow:hidden;box-shadow:0 6px 24px rgba(30,64,175,.22)}
.wallet-hero::before{content:'';position:absolute;top:-30px;right:-30px;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,.06)}
.wallet-hero::after{content:'';position:absolute;bottom:-20px;left:-20px;width:80px;height:80px;border-radius:50%;background:rgba(255,255,255,.04)}
.wh-lbl{font-size:.68rem;color:rgba(255,255,255,.7);margin-bottom:3px}
.wh-amt{font-size:2rem;font-weight:900;letter-spacing:.5px}
.wh-usdt{display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.12);border-radius:20px;padding:3px 10px;font-size:.72rem;margin-top:6px}
.wh-btns{display:flex;gap:9px;margin-top:14px}
.wh-btn{flex:1;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.2);color:#fff;border-radius:10px;padding:8px;font-size:.74rem;font-weight:700;cursor:pointer;text-align:center;transition:.2s}
.wh-btn:hover{background:rgba(255,255,255,.25)}

/* QUICK ACTIONS */
.qa-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.qa{display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;padding:12px 4px;background:var(--sur);border-radius:16px;box-shadow:0 4px 12px rgba(30,64,175,.10);border:1px solid var(--bor);transition:.18s}
.qa:hover{background:var(--bluelt);transform:translateY(-2px);box-shadow:0 6px 18px rgba(30,64,175,.16)}
.qa:active{transform:scale(.95)}
.qa-ico{width:46px;height:46px;border-radius:14px;background:linear-gradient(145deg,#1d4ed8,#2563eb);display:flex;align-items:center;justify-content:center;font-size:1.15rem;box-shadow:0 4px 10px rgba(29,78,216,.30),0 1px 2px rgba(255,255,255,.8) inset,inset 0 -2px 4px rgba(0,0,0,.15)}
.qa-lbl{font-size:.64rem;font-weight:700;color:var(--tex);text-align:center}

/* CARDS */
.card{background:var(--sur);border:1px solid var(--bor);border-radius:14px;padding:14px;margin-bottom:12px;box-shadow:var(--shadow)}
.ct{font-size:.85rem;font-weight:700;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;color:var(--tex)}

/* TABLE */
.tw{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:.75rem}
th{color:var(--mut);font-weight:600;padding:7px 8px;text-align:left;border-bottom:2px solid var(--bor);font-size:.65rem;text-transform:uppercase;white-space:nowrap}
td{padding:9px 8px;border-bottom:1px solid #f1f5f9;vertical-align:middle;white-space:nowrap;color:var(--tex)}
tr:last-child td{border-bottom:none}
tr:hover td{background:#f8fafc}

/* PILLS */
.pill{display:inline-block;padding:2px 8px;border-radius:20px;font-size:.65rem;font-weight:700}
.pg{background:#dcfce7;color:#166534}
.py{background:#fef9c3;color:#854d0e}
.pr{background:#fee2e2;color:#991b1b}
.pb{background:#dbeafe;color:#1d4ed8}

/* BUTTONS */
.btn{padding:10px 18px;border-radius:10px;font-size:.82rem;font-weight:700;border:none;cursor:pointer;transition:.15s;white-space:nowrap}
.btn:hover{opacity:.88}
.btn:active{transform:scale(.97)}
.btn-p{background:var(--blue);color:#fff}
.btn-gr{background:var(--grn);color:#fff}
.btn-r{background:var(--red);color:#fff}
.btn-o{background:#f1f5f9;color:var(--tex);border:1px solid var(--bor)}
.btn-sm{padding:5px 11px;font-size:.72rem}
.btn-full{width:100%}

/* FORM */
.fg{margin-bottom:13px}
.fg label{display:block;font-size:.73rem;color:var(--mut);margin-bottom:5px;font-weight:600}
.fg input,.fg select,.fg textarea{width:100%;background:#f8fafc;border:1.5px solid var(--bor);border-radius:10px;padding:11px 13px;color:var(--tex);font-size:.85rem;outline:none;transition:.2s}
.fg input:focus,.fg select:focus{border-color:var(--blue);background:#fff;box-shadow:0 0 0 3px rgba(29,78,216,.08)}

/* INCOME TABLE */
.inc-row{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid #f1f5f9}
.inc-row:last-child{border-bottom:none}
.inc-ico{width:36px;height:36px;border-radius:10px;background:var(--bluelt);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.inc-info{flex:1;margin-left:11px}
.inc-name{font-size:.8rem;font-weight:700;color:var(--tex)}
.inc-sub{font-size:.68rem;color:var(--mut);margin-top:1px}
.inc-amt{font-size:.9rem;font-weight:800;color:var(--blue)}

/* P2P */
.p2p-tab{display:flex;background:#f1f5f9;border-radius:10px;padding:3px;margin-bottom:14px}
.p2p-tab button{flex:1;padding:8px;border:none;background:none;font-size:.78rem;font-weight:700;color:var(--mut);border-radius:8px;cursor:pointer;transition:.2s}
.p2p-tab button.active{background:var(--sur);color:var(--blue);box-shadow:0 1px 4px rgba(0,0,0,.1)}

/* TREE */
.tree-wrap{overflow-x:auto;padding:10px 0;min-height:160px}
.tree-node{border-radius:12px;padding:9px 13px;min-width:90px;text-align:center;font-size:.72rem;cursor:pointer;transition:.2s;border:2px solid transparent;display:inline-flex;flex-direction:column;align-items:center;gap:2px;box-shadow:0 2px 8px rgba(0,0,0,.06)}
.tree-node:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.1)}
.tn-you{border-color:var(--blue);background:var(--bluelt)}
.tn-act{border-color:var(--grn);background:#dcfce7}
.tn-ina{border-color:var(--bor);background:#f8fafc}
.tn-emp{border-color:var(--bor);background:#f8fafc;opacity:.5}
.tn-nm{font-weight:800;font-size:.74rem;color:var(--tex);max-width:70px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tn-un{font-size:.62rem;color:var(--mut)}
.tn-inv{font-size:.6rem;color:var(--blue);font-weight:600}
.tree-line{width:1px;height:18px;background:var(--bor);margin:0 auto}
.tree-row{display:flex;justify-content:center;gap:18px}

/* PROGRESS */
.prog{height:5px;background:#e2e8f0;border-radius:3px;overflow:hidden;margin-top:6px}
.prog-f{height:100%;background:var(--blue);border-radius:3px;transition:width .5s}

/* SECTION HEADER */
.sec-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.sec-title{font-size:.78rem;font-weight:800;color:var(--mut);text-transform:uppercase;letter-spacing:.5px}

/* BANNER */
.ban{border-radius:12px;padding:12px 14px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.ban-w{background:#fffbeb;border:1px solid #fde68a}
.ban-r{background:#fef2f2;border:1px solid #fecaca}
.ban-g{background:#f0fdf4;border:1px solid #bbf7d0}

/* REF LINK */
.ref-box{background:#f8fafc;border:1.5px solid var(--bor);border-radius:10px;padding:10px 13px;display:flex;align-items:center;gap:8px}
.ref-box input{flex:1;background:none;border:none;color:var(--tex);font-size:.76rem;outline:none}

/* MODAL */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;align-items:flex-end;justify-content:center}
.modal-bg.show{display:flex}
.modal{background:var(--sur);border-radius:20px 20px 0 0;padding:20px;width:100%;max-width:480px;max-height:85vh;overflow-y:auto}
.modal-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.modal-hdr h3{font-size:.92rem;font-weight:800;color:var(--tex)}

/* SALARY */
.sal-card{background:linear-gradient(135deg,#1d4ed8,#1e40af);border-radius:16px;padding:16px;color:#fff;margin-bottom:12px;text-align:center}

.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(12px);background:#1e293b;color:#fff;border-radius:10px;padding:10px 18px;font-size:.78rem;z-index:9999;opacity:0;transition:.3s;pointer-events:none;max-width:300px;text-align:center;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

@media(min-width:481px){body{box-shadow:0 0 40px rgba(0,0,0,.1)}}
</style>
</head>
