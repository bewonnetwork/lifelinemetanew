window.goPage=(page,el2)=>{
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const pg=el('page-'+page);if(pg)pg.classList.add('active');
  document.querySelectorAll('.bnav a').forEach(a=>a.classList.remove('active'));
  const bn=el('bn-'+page);if(bn)bn.classList.add('active');
  sv('pgLbl',PAGES[page]||page);
  window.scrollTo(0,0);
  if(page==='p2p')showP2PTab('send');
  if(page==='tree')renderTree();
};
