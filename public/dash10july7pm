// ── BINARY TREE ───────────────────────────────────────
function renderTree(rootUID){
  const uid=rootUID||CU;
  const u=AU[uid];if(!u)return;

  // Count legs
  function legCount(startUID,side){
    let cnt=0,inv=0;
    const q=[startUID];const vis=new Set();
    while(q.length){
      const c=q.shift();if(!c||vis.has(c))continue;vis.add(c);
      const n=AU[c];if(!n)continue;
      if(c!==startUID){cnt++;inv+=(n.totalInvested||0);}
      if(n.leftChild)q.push(n.leftChild);
      if(n.rightChild)q.push(n.rightChild);
    }
    return{cnt,inv};
  }
  const ll=u.leftChild?legCount(u.leftChild):{cnt:0,inv:0};
  const rl=u.rightChild?legCount(u.rightChild):{cnt:0,inv:0};
  sv('trL',ll.cnt);sv('trLInv','$'+fmtN(ll.inv)+' invested');
  sv('trR',rl.cnt);sv('trRInv','$'+fmtN(rl.inv)+' invested');

  // Render tree nodes
  function nH(nid,lbl,isRoot){
    if(!nid)return`<div style="display:flex;flex-direction:column;align-items:center"><div class="tree-node tn-emp"><div class="tn-nm" style="color:var(--mut)">Empty</div><div class="tn-un">${lbl}</div></div></div>`;
    const n=AU[nid];
    const nm=n?n.fullName||n.username||nid.slice(0,8):nid.slice(0,8);
    const act=n?n.isActive:false;
    const inv=n?parseFloat(n.totalInvested||0):0;
    const cls=isRoot?'tn-you':act?'tn-act':'tn-ina';
    return`<div style="display:flex;flex-direction:column;align-items:center">
      <div class="tree-node ${cls}" onclick="renderTree('${nid}')">
        ${isRoot?'<div style="font-size:.6rem;color:var(--blue);font-weight:700;margin-bottom:2px">YOU</div>':''}
        <div class="tn-nm">${nm}</div>
        <div class="tn-un">@${n?n.username||'—':'?'}</div>
        <div class="tn-inv">$${fmtN(inv)} invested</div>
        <span class="pill ${act?'pg':'py'}" style="font-size:.6rem;margin-top:3px">${act?'Act':'Inact'}</span>
        <div style="font-size:.58rem;color:var(--mut);margin-top:2px">${lbl}</div>
      </div>
    </div>`;
  }

  function lvl2(pid){
    const n=pid?AU[pid]:null;
    const lc=n?n.leftChild:null,rc=n?n.rightChild:null;
    return`<div class="tree-row" style="gap:12px">${nH(lc,'L')}${nH(rc,'R')}</div>`;
  }

  const lc=u.leftChild,rc=u.rightChild;
  const treeHTML=`
    <div style="display:flex;flex-direction:column;align-items:center;padding:8px">
      ${nH(uid,uid===CU?'YOU':'ROOT',true)}
      ${(lc||rc)?`<div class="tree-line" style="height:18px;width:1px"></div>
      <div style="display:flex;gap:28px">
        <div style="display:flex;flex-direction:column;align-items:center">
          ${nH(lc,'LEFT')}
          ${lc?`<div class="tree-line" style="height:14px;width:1px"></div>${lvl2(lc)}`:''}
        </div>
        <div style="display:flex;flex-direction:column;align-items:center">
          ${nH(rc,'RIGHT')}
          ${rc?`<div class="tree-line" style="height:14px;width:1px"></div>${lvl2(rc)}`:''}
        </div>
      </div>`:'<div style="text-align:center;color:var(--mut);padding:20px;font-size:.8rem">No downline yet. Share your referral link!</div>'}
    </div>`;
  sv('treeView',treeHTML);

  // Downline table
  const downline=[];
  function getDownline(pUID,level,side){
    const p=AU[pUID];if(!p)return;
    if(p.leftChild&&AU[p.leftChild])downline.push({...AU[p.leftChild],level,side:'left'});
    if(p.rightChild&&AU[p.rightChild])downline.push({...AU[p.rightChild],level,side:'right'});
    if(p.leftChild)getDownline(p.leftChild,level+1,side==='left'?'left':side);
    if(p.rightChild)getDownline(p.rightChild,level+1,side==='right'?'right':side);
  }
  getDownline(uid,1,'');
  sv('downTb',downline.length?downline.map(d=>{
    const inv=+(d.totalInvested||0);
    const jd=d.createdAt?(d.createdAt.toDate?d.createdAt.toDate().toLocaleDateString():new Date(d.createdAt).toLocaleDateString()):'—';
    return`<tr>
      <td style="font-weight:700">${d.fullName||d.username||'User'}</td>
      <td><span class="pill ${d.side==='left'?'pb':'pp'}">${d.side==='left'?'Left':'Right'}</span></td>
      <td style="color:var(--blue);font-weight:700">${d.level}</td>
      <td><span class="pill ${d.isActive?'pg':'py'}">${d.isActive?'Active':'Inactive'}</span></td>
      <td style="font-weight:700;color:var(--blue)">$${fmtN(inv)}</td>
      <td style="font-size:.72rem;color:var(--mut)">${jd}</td>
    </tr>`;
  }).join(''):'<tr><td colspan="6" style="text-align:center;color:var(--mut);padding:14px">No downline yet</td></tr>');
}

// ── JOINING HISTORY ───────────────────────────────────
let JHData=[];
function renderJH(){
  const allUsers=Object.values(AU);
  JHData=[];
  // BFS to find all downline with level and side
  function getAll(pUID,level,side){
    const p=AU[pUID];if(!p)return;
    const proc=(childUID,s)=>{
      if(!childUID||!AU[childUID])return;
      const c=AU[childUID];
      const sp=AU[c.sponsorId]||{};
      JHData.push({...c,level,side:s,sponsorName:sp.fullName||sp.username||c.sponsorId||'—'});
      getAll(childUID,level+1,s);
    };
    proc(p.leftChild,'left');
    proc(p.rightChild,'right');
  }
  getAll(CU,1,'');
  JHData.sort((a,b)=>{
    const at=a.createdAt?(a.createdAt.toDate?a.createdAt.toDate():new Date(a.createdAt)):0;
    const bt=b.createdAt?(b.createdAt.toDate?b.createdAt.toDate():new Date(b.createdAt)):0;
    return bt-at;
  });
  sv('jhCnt',JHData.length+' members');
  filterJH();

  // Upline chain
  const chain=[];let cur=UD.sponsorId;
  for(let i=0;i<7;i++){
    if(!cur||!AU[cur])break;
    chain.push(AU[cur].username||AU[cur].fullName||cur.slice(0,8));
    cur=AU[cur].sponsorId;
  }
  sv('jhUpline',chain.length?chain.join(' → '):'Root');
}

window.filterJH=()=>{
  const side=el('jhSide').value,status=el('jhStatus').value;
  let list=JHData;
  if(side!=='all')list=list.filter(u=>u.side===side);
  if(status!=='all')list=list.filter(u=>status==='active'?u.isActive:!u.isActive);
  const tb=el('jhTb');
  if(!list.length){tb.innerHTML='<tr><td colspan="8" style="text-align:center;color:var(--mut);padding:14px">No records</td></tr>';return;}
  tb.innerHTML=list.map((u,i)=>{
    const dt=u.createdAt?(u.createdAt.toDate?u.createdAt.toDate():new Date(u.createdAt)):null;
    return`<tr>
      <td style="color:var(--mut)">${i+1}</td>
      <td style="font-weight:700">${u.fullName||u.username||'User'}</td>
      <td style="font-size:.72rem;color:var(--mut)">${u.sponsorName}</td>
      <td style="font-size:.72rem">${dt?dt.toLocaleDateString():'—'}</td>
      <td style="font-size:.72rem;color:var(--mut)">${dt?dt.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'—'}</td>
      <td><span class="pill ${u.side==='left'?'pb':'pp'}">${u.side==='left'?'Left':'Right'}</span></td>
      <td style="font-weight:700;color:var(--blue)">${u.level}</td>
      <td><span class="pill ${u.isActive?'pg':'py'}">${u.isActive?'Active':'Inactive'}</span></td>
    </tr>`;
  }).join('');
};

