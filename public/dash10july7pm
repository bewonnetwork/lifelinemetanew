// ── HELPERS ──────────────────────────────────────────
function el(id){return document.getElementById(id);}
function sv(id,val){const e=el(id);if(e)e.innerHTML=val;}
function fmtN(n){return parseFloat(n||0).toFixed(2);}
function toast(msg){const t=el('toast');t.textContent=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),3200);}
function todayIncome(){
  const today=new Date().toDateString();
  return TX.filter(t=>t.timestamp&&new Date(t.timestamp).toDateString()===today&&(t.amount||0)>0).reduce((s,t)=>s+(t.amount||0),0);
}
function monthIncome(){
  const now=new Date();
  return TX.filter(t=>t.timestamp&&new Date(t.timestamp).getMonth()===now.getMonth()&&new Date(t.timestamp).getFullYear()===now.getFullYear()&&(t.amount||0)>0).reduce((s,t)=>s+(t.amount||0),0);
}

