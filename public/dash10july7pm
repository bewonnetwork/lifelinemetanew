  if(otp!=='123456'){toast('Wrong OTP. Demo code: 123456');return;}
  await db.ref('tfa/'+CU).set({enabled:true,phone:tfaPhone,createdAt:Date.now()});
  el('tfaVerify').style.display='none';el('tfaDisable').style.display='block';
  sv('tfaIcon','🔐');sv('tfaStatus','2FA Enabled');
  toast('✅ 2FA enabled!');
};
window.disable2FA=async()=>{
  if(!confirm('Disable 2FA?'))return;
  await db.ref('tfa/'+CU).remove();
  el('tfaDisable').style.display='none';el('tfaEnable').style.display='block';
  sv('tfaIcon','🔓');sv('tfaStatus','2FA Disabled');
  toast('2FA disabled');
};
window.otpN=(cur,nxtId)=>{if(cur.value&&nxtId){const n=el(nxtId);if(n)n.focus();}};

// ── WEB3 ─────────────────────────────────────────────
window.connectMM=async()=>{
  if(!window.ethereum){toast('MetaMask not installed. Use mobile app DApps browser.');return;}
  try{
    const accounts=await window.ethereum.request({method:'eth_requestAccounts'});
    const addr=accounts[0];
    el('w3dis').style.display='none';el('w3con').style.display='block';
    sv('w3addr',addr);
    const chainId=await window.ethereum.request({method:'eth_chainId'});
    const nets={1:'Ethereum','0x38':'BNB Chain','0x89':'Polygon'};
    sv('w3net',nets[chainId]||'Chain: '+chainId);
    const bal=await window.ethereum.request({method:'eth_getBalance',params:[addr,'latest']});
    sv('w3ethb',(parseInt(bal,16)/1e18).toFixed(4)+' ETH');
    sv('w3usdtb','Connect to check USDT');
    await db.ref('web3Transactions/'+CU+'/connect').set({address:addr,network:chainId,timestamp:Date.now()});
    toast('✅ MetaMask connected!');
  }catch(e){toast('Error: '+e.message);}
};
window.connectTW=()=>toast('Open Trust Wallet → DApps → Enter site URL');
window.discW3=()=>{el('w3dis').style.display='block';el('w3con').style.display='none';sv('w3addr','—');toast('Disconnected');};
window.copyAddr=()=>{const a=S.companyUSDTAddress||'';if(!a||a==='Not set — Contact admin'){toast('Not set');return;}navigator.clipboard.writeText(a).then(()=>toast('✅ Copied!'));};
window.sendUSDT=async()=>{
  if(!window.ethereum){toast('Connect wallet first');return;}
  const amt=parseFloat(el('w3amt').value||0);
  if(!amt||amt<=0){toast('Enter amount');return;}
  const type=el('w3type').value;
  const txHash='0x'+Math.random().toString(16).slice(2,34)+(Date.now()).toString(16);
  await db.ref('web3Transactions/'+CU+'/'+Date.now()).set({type,amount:amt,network:el('w3netsel').value,txHash,status:'pending',timestamp:Date.now()});
  toast('✅ Transaction submitted! TxHash: '+txHash.slice(0,20)+'…');
};

