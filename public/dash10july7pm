  );
  if(!found){toast('User not found: '+q);return;}
  p2pTargetUID=found.id;
  el('p2pUserInfo').style.display='block';
  sv('p2pUserName',found.fullName||found.username||'User');
  sv('p2pUserEmail',found.email||found.id.slice(0,16)+'…');
  toast('✅ Found: '+(found.fullName||found.username));
};

window.sendP2P=async()=>{
  if(!p2pTargetUID){toast('Find recipient first');return;}
  const amt=parseFloat(el('p2pAmt').value||0);
  const note=(el('p2pNote').value||'').trim();
  if(amt<1){toast('Minimum $1');return;}
  if(amt>UD.p2pBalance){toast('Insufficient P2P balance ($'+fmtN(UD.p2pBalance)+')');return;}
  if(!confirm('Send $'+fmtN(amt)+' P2P to '+(AU[p2pTargetUID]?.fullName||AU[p2pTargetUID]?.username||p2pTargetUID.slice(0,12))+'?'))return;
  try{
    // Deduct from sender
    const newSenderP2P=UD.p2pBalance-amt;
    await db.ref('users/'+CU+'/p2pBalance').set(newSenderP2P);
    await db.ref('transactions/'+CU).push({
      type:'P2P Send',amount:-amt,note:'To: '+(AU[p2pTargetUID]?.username||p2pTargetUID.slice(0,10))+(note?' | '+note:''),
      toUser:AU[p2pTargetUID]?.username||p2pTargetUID.slice(0,10),
      timestamp:Date.now(),status:'completed',balance:newSenderP2P
    });
    // Add to receiver's main wallet (P2P send goes to their main wallet)
    const recWR=db.ref('users/'+p2pTargetUID+'/walletBalance');
    const recWS=await recWR.get();
    const recNewBal=parseFloat(recWS.exists()?recWS.val():0)+amt;
    await recWR.set(recNewBal);
    await db.ref('transactions/'+p2pTargetUID).push({
      type:'P2P Receive',amount:amt,note:'From: '+(UD.username||CU.slice(0,10))+(note?' | '+note:''),
      fromUser:UD.username||CU.slice(0,10),
      timestamp:Date.now(),status:'completed',balance:recNewBal
    });
    UD.p2pBalance=newSenderP2P;
    el('p2pAmt').value='';el('p2pNote').value='';
    el('p2pUserInfo').style.display='none';p2pTargetUID=null;
    await loadRTDB();renderAll();
    toast('✅ $'+fmtN(amt)+' sent via P2P!');
  }catch(e){toast('Error: '+e.message);}
};

