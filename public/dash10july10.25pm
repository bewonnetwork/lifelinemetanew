<!-- ===== WALLET ===== -->
<div class="page" id="page-wallet">
  <div class="pg-title">Wallet</div>

  <div class="two-col" style="max-width:900px">
    <div class="wallet-card wc-main">
      <div class="wc-lbl">💳 Main Wallet</div>
      <div class="wc-val" id="walMainD">$0.00</div>
      <div class="wc-sub">Withdrawable • Invest • Activate — সব এখান থেকেই</div>
    </div>
    <div class="wallet-card wc-income">
      <div class="wc-lbl">🎯 Income Wallet</div>
      <div class="wc-val" id="walIncomeD">$0.00</div>
      <div class="wc-sub">All commissions land here</div>
    </div>
  </div>
  <div class="two-col" style="max-width:900px">
    <div class="wallet-card wc-p2b">
      <div class="wc-lbl">📦 P2B Wallet</div>
      <div class="wc-val" id="walP2BD">$0.00</div>
      <div class="wc-sub">Legacy — শুধু user-to-user P2P transfer এর জন্য</div>
    </div>
    <div class="card" style="margin-bottom:0">
      <div class="card-title">Quick Stats</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:9px">
        <div style="background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:10px;text-align:center">
          <div style="font-size:.65rem;color:var(--muted)">Total Earned</div>
          <div style="font-size:.95rem;font-weight:800;color:var(--green)" id="wTotalEarned">$0.00</div>
        </div>
        <div style="background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:10px;text-align:center">
          <div style="font-size:.65rem;color:var(--muted)">Withdrawn</div>
          <div style="font-size:.95rem;font-weight:800;color:var(--red)" id="wTotalWd">$0.00</div>
        </div>
      </div>
    </div>
  </div>

  <div class="card" style="max-width:900px">
    <div class="card-title">Wallet Transfer</div>
    <div class="wal-tabs">
      <button class="wtab active" id="wtab_i2p" onclick="switchWTab('i2p')">Income → P2B (Won)</button>
      <button class="wtab" id="wtab_m2p" onclick="switchWTab('m2p')">Main → P2B (any User)</button>
      <button class="wtab" id="wtab_p2m" onclick="switchWTab('p2m')">P2B → Main (won)</button>
      <button class="wtab" id="wtab_m2m" onclick="switchWTab('m2m')">Main → Main (P2P)</button>
      <button class="wtab" id="wtab_i2m" onclick="switchWTab('i2m')">Income → Main</button>
    </div>

    <div id="wform_i2p">
      <div class="info-box">Income Wallet to won P2B Wallet  — no condiction, any amount, free transfer</div>
      <div class="fg"><label>Amount (USD)</label><input type="number" id="i2pAmt" placeholder="Any amount" min="0.01"/></div>
      <button class="btn btn-p" onclick="transferIncomeToP2B()" style="width:100%">Transfer Income → P2B</button>
    </div>

    <div id="wform_m2p" style="display:none">
      <div class="info-box">Main Wallet  to any user P2B Wallet  — free, no fee but won to P2B  User ID will blank</div>
      <div class="fg"><label>Receiver User ID / Username (blank won)</label><input type="text" id="m2pTarget" placeholder="Receiver's User ID / Username — if won keep blank"/></div>
      <div class="fg"><label>Amount (USD)</label><input type="number" id="m2pAmt" placeholder="Amount" min="0.01"/></div>
      <button class="btn btn-p" onclick="transferMainToP2B()" style="width:100%">Transfer Main → P2B</button>
    </div>

    <div id="wform_p2m" style="display:none">
      <div class="info-box">⚠️P2B Wallet funds cannot be transferred directly to another user's P2B Wallet. First, transfer the balance from your P2B Wallet to your Main Wallet. Then, use the **Main → P2B (Any User)** option to send it to another user's P2B Wallet. This transfer is free of charge.
      </div>
      <div class="fg"><label>Amount (USD)</label><input type="number" id="p2mAmt" placeholder="Amount" min="0.01"/></div>
      <button class="btn btn-p" onclick="transferP2BToMain()" style="width:100%">Transfer P2B → Main (won)</button>
    </div>

    <div id="wform_m2m" style="display:none">
      <div class="info-box">Main Wallet to any user এর Main Wallet এ — free transfer</div>
      <div class="fg"><label>Receiver User ID / Username</label><input type="text" id="m2mTarget" placeholder="User ID or Username"/></div>
      <div class="fg"><label>Amount (USD)</label><input type="number" id="m2mAmt" placeholder="Amount" min="0.01"/></div>
      <button class="btn btn-p" onclick="transferMainToMain()" style="width:100%">Send to User (Main → Main)</button>
    </div>

    <div id="wform_i2m" style="display:none">
      <div class="info-box" id="i2mChargeInfo">Income Wallet to Main Wallet do service charge</div>
      <div class="fg"><label>Amount (USD)</label><input type="number" id="i2mAmt" placeholder="Amount" min="0.01" oninput="calcI2MPreview()"/></div>
      <div id="i2mPreview" style="background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:11px;margin-bottom:11px;font-size:.78rem;display:none">
        <div style="display:flex;justify-content:space-between;padding:3px 0"><span style="color:var(--muted)">Amount</span><span id="i2mPrevAmt"></span></div>
        <div style="display:flex;justify-content:space-between;padding:3px 0"><span style="color:var(--muted)">Service Charge</span><span id="i2mPrevCharge" style="color:var(--red)"></span></div>
        <div style="display:flex;justify-content:space-between;padding:3px 0;border-top:1px solid var(--border);margin-top:4px"><span style="font-weight:700">You Get</span><span id="i2mPrevNet" style="color:var(--green);font-weight:800"></span></div>
      </div>
      <button class="btn btn-p" onclick="transferIncomeToMain()" style="width:100%">Transfer Income → Main</button>
    </div>
  </div>

  <div class="card" style="max-width:900px" id="wdFormCard2">
    <div class="card-title">Withdraw <small id="wdChargeInfo"></small></div>
    <div id="wdLockNotice" style="display:none" class="info-box">🔒 ID Activate না করলে Withdraw করা যাবে না। আগে Activation করুন।</div>
    <div class="fg"><label>Amount (USD)</label><input type="number" id="wdAmt" placeholder="Min $10"/></div>
    <div class="fg"><label>USDT TRC20 Address</label><input type="text" id="wdAddr" placeholder="Your TRC20 wallet address"/></div>
    <div id="wdPreview" style="background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:11px;margin-bottom:11px;font-size:.78rem;display:none">
      <div style="display:flex;justify-content:space-between;padding:3px 0"><span style="color:var(--muted)">Amount</span><span id="wdPrevAmt"></span></div>
      <div style="display:flex;justify-content:space-between;padding:3px 0"><span style="color:var(--muted)">Withdraw Charge</span><span id="wdPrevCharge" style="color:var(--red)"></span></div>
      <div style="display:flex;justify-content:space-between;padding:3px 0;border-top:1px solid var(--border);margin-top:4px"><span style="font-weight:700">You Receive</span><span id="wdPrevNet" style="color:var(--green);font-weight:800"></span></div>
    </div>
    <button class="btn btn-p" onclick="submitWithdraw()" style="width:100%">Submit Withdraw Request (Main Wallet)</button>
  </div>

  <div class="card" style="max-width:900px">
    <div class="card-title">Wallet History</div>
    <div class="tw">
      <table>
        <thead><tr><th>Date</th><th>Type</th><th>Amount</th><th>Status</th></tr></thead>
        <tbody id="walHistTb">
          <tr><td colspan="4" style="text-align:center;color:var(--muted);padding:16px">No transactions</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ===== LEADERSHIP INCOME (new: monthly, based on Left+Right+Personal sales) ===== -->
<div class="page" id="page-leadership">
  <div class="pg-title">Leadership Income <span>Monthly — Left + Right + Personal Sales ভিত্তিক</span></div>
