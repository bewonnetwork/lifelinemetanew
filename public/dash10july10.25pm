<div class="bottom-nav" id="bottomNav">
  <div class="bn-item" onclick="showPage('roi',null)"><span class="bn-ic">📈</span><span>Invest Now</span></div>
  <div class="bn-item" onclick="showPage('wallet',null)"><span class="bn-ic">💸</span><span>Withdraw</span></div>
  <div class="bn-item" onclick="showPage('tree',null)"><span class="bn-ic">🌳</span><span>Binary Tree</span></div>
  <div class="bn-item" onclick="showPage('income',null)"><span class="bn-ic">🧾</span><span>Transaction History</span></div>
</div>

<div class="toast" id="toast"></div>

<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-firestore-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.10/firebase-database-compat.js"></script>

<script>
// ── FIREBASE CONFIG ──────────────────────────────────
const firebaseConfig = {
  apiKey: "AIzaSyA3G2bMOJ_HSDYXJPuM70tVjfbkHlMftr4",
  authDomain: "livelinemeta.firebaseapp.com",
  databaseURL: "https://livelinemeta-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId: "livelinemeta",
  storageBucket: "livelinemeta.firebasestorage.app",
  messagingSenderId: "206900805598",
  appId: "1:206900805598:web:10e6b39100af201b4e674f"
};

firebase.initializeApp(firebaseConfig);
const auth   = firebase.auth();
const fsdb   = firebase.firestore();
const rtdb   = firebase.database();

let CU   = null;
let UD   = null;
let ALLU = {};
let SETTINGS = {};

// ── AUTH GUARD ───────────────────────────────────────
auth.onAuthStateChanged(async user => {
  if (!user) { window.location.href = 'login.html'; return; }
  CU = user;
  await loadAll();
});

async function loadAll() {
  try {
    const docSnap = await fsdb.collection('users').doc(CU.uid).get();
    if (!docSnap.exists) { toast('User data not found. Please re-login.'); return; }
    UD = { id: CU.uid, ...docSnap.data() };

    const allSnap = await fsdb.collection('users').get();
    allSnap.forEach(d => { ALLU[d.id] = { id: d.id, ...d.data() }; });

    await loadSettings();
    renderAll();
    loadRTDBData();
    loadNoticeBar();
    loadMyVouchers();

    rtdb.ref('users/' + CU.uid + '/income').on('value', snap => {
      if (snap.exists() && UD) { UD.income = snap.val(); renderIncomeCards(); }
    });
    rtdb.ref('users/' + CU.uid + '/walletBalance').on('value', snap => {
      if (UD) { UD.walletBalance = snap.exists()?snap.val():0; renderWalletCards(); }
    });
    rtdb.ref('users/' + CU.uid + '/incomeWallet').on('value', snap => {
      if (UD) { UD.incomeWallet = snap.exists()?snap.val():0; renderWalletCards(); }
    });
    rtdb.ref('users/' + CU.uid + '/p2bWallet').on('value', snap => {
      if (UD) { UD.p2bWallet = snap.exists()?snap.val():0; renderWalletCards(); }
    });
    rtdb.ref('users/' + CU.uid + '/isActive').on('value', snap => {
      if (UD) { UD.isActive = snap.exists()?snap.val():false; renderActivationState(); }
    });
    rtdb.ref('transactions/' + CU.uid).on('value', snap => {
      if (snap.exists()) renderTransactions(snap.val());
      else renderTransactions({});
    });
    rtdb.ref('notices').on('value', () => loadNoticeBar());
    rtdb.ref('giftVouchers').on('value', () => loadMyVouchers());

  } catch(e) { toast('Error: ' + e.message); }
}

async function loadSettings() {
  const snap = await rtdb.ref('settings').get();
  SETTINGS = snap.exists() ? snap.val() : {};
}

async function loadRTDBData() {
  const incSnap = await rtdb.ref('users/' + CU.uid + '/income').get();
  if (incSnap.exists()) { UD.income = incSnap.val(); renderIncomeCards(); }

  const walSnap = await rtdb.ref('users/' + CU.uid + '/walletBalance').get();
  UD.walletBalance = walSnap.exists() ? walSnap.val() : 0;

  const incWSnap = await rtdb.ref('users/' + CU.uid + '/incomeWallet').get();
  UD.incomeWallet = incWSnap.exists() ? incWSnap.val() : 0;

  const p2bSnap = await rtdb.ref('users/' + CU.uid + '/p2bWallet').get();
  UD.p2bWallet = p2bSnap.exists() ? p2bSnap.val() : 0;

  renderWalletCards();

  const invSnap = await rtdb.ref('investments/' + CU.uid).get();
  if (invSnap.exists()) { renderROIPlans(invSnap.val()); renderInvestHistory(invSnap.val()); }

  const wdSnap = await rtdb.ref('withdrawals/' + CU.uid).get();
  if (wdSnap.exists()) renderWalletHistory(wdSnap.val());

  renderLeadershipIncome();
}

// ── RENDER ALL ────────────────────────────────────────
function renderAll() {
  const u    = UD;
  const name = u.fullName || u.username || (CU.email ? CU.email.split('@')[0] : 'User');
  const init = name[0].toUpperCase();

  document.getElementById('avInit').textContent   = init;
  document.getElementById('sbName').textContent   = name;
  document.getElementById('sbStatus').textContent = u.isActive ? '✅ Active' : '⚠️ Inactive';

  const h = new Date().getHours();
  const g = h<12?'Good Morning':h<17?'Good Afternoon':'Good Evening';
  document.getElementById('greetMsg').textContent = g + ', ' + name + '!';

  renderActivationState();

  document.getElementById('pfAv').textContent         = init;
  document.getElementById('pfNameD').textContent       = name;
  document.getElementById('pfEmailD').textContent      = u.email || CU.email || '';
  document.getElementById('pfName').value              = u.fullName || '';
  document.getElementById('pfUsername').value          = u.username || '';
  document.getElementById('pfPhone').value             = u.mobile || '';
  document.getElementById('pfCountry').value           = u.country || '';
  document.getElementById('pfWallet').value            = u.paymentWallet || '';
  document.getElementById('pfBadge').innerHTML         = u.isActive
    ? '<span class="pill pg">✅ Active</span>'
    : '<span class="pill py">⚠️ Inactive</span>';

  document.getElementById('infoUID').textContent      = CU.uid;
  document.getElementById('infoUsername').textContent = u.username || '—';
  document.getElementById('infoSponsor').textContent  = u.sponsorId || 'None (Root)';
  document.getElementById('infoJoined').textContent   = u.createdAt
    ? (u.createdAt.toDate ? u.createdAt.toDate().toLocaleDateString('en-BD') : new Date(u.createdAt).toLocaleDateString())
    : '—';
  document.getElementById('infoStatus').textContent   = u.isActive ? '✅ Active' : '⚠️ Inactive';
  document.getElementById('infoMethod').textContent   = u.signupMethod || 'email';

  const refCode = u.myRefCode || u.username || CU.uid;
  const refLink = window.location.origin + '/register.html?ref=' + encodeURIComponent(refCode);
  document.getElementById('refLinkInput').value = refLink;

  const myId = u.memberId || CU.uid;
  const uplineId = u.sponsorId || 'Root (No Upline)';
  set('myIdVal', myId);
  set('uplineIdVal', uplineId);
  set('refMyIdVal', myId);
  set('refUplineIdVal', uplineId);

  set('actFeeD', '$'+(SETTINGS.activationFee||30));

  renderIncomeCards();
  loadReferrals();
  renderBinaryTree();
  renderWalletCards();
  applyDynamicChargeLabels();
}

function renderActivationState() {
  if (!UD) return;
  document.getElementById('actBanner').style.display = UD.isActive ? 'none' : 'flex';
  document.getElementById('sbStatus').textContent = UD.isActive ? '✅ Active' : '⚠️ Inactive';
  if (UD.isActive) {
    document.getElementById('activeCard').style.display   = 'block';
    document.getElementById('actFormCard').style.display  = 'none';
    document.getElementById('wdLockNotice').style.display = 'none';
  } else {
    document.getElementById('activeCard').style.display   = 'none';
    document.getElementById('actFormCard').style.display  = 'block';
    document.getElementById('wdLockNotice').style.display = 'block';
  }
}

// ── DYNAMIC CHARGE LABELS (admin controlled) ──────────
function applyDynamicChargeLabels() {
  const i2mCharge = parseFloat(SETTINGS.incomeToMainCharge != null ? SETTINGS.incomeToMainCharge : 5);
  const wdCharge   = parseFloat(SETTINGS.withdrawalFee != null ? SETTINGS.withdrawalFee : 5);
  const cbLimit    = parseFloat(SETTINGS.cashbackLimit || 60);
  set('i2mChargeInfo', 'Income Wallet থেকে Main Wallet এ — '+i2mCharge+'% সার্ভিস চার্জ কাটা হবে।');
  set('wdChargeInfo', '('+wdCharge+'% withdraw charge)');
  set('cbLimitD', '$'+cbLimit.toFixed(2));
  set('cbLimitTxt', cbLimit.toFixed(0));
  const leadRate = parseFloat(SETTINGS.leadershipPct || 2);
  set('ldRateLbl', 'Rate: '+leadRate+'%');
}

// ── INCOME CARDS ──────────────────────────────────────
function renderIncomeCards() {
  const inc     = (UD && UD.income) || {};
  const sponsor = parseFloat(inc.sponsor    || 0);
  const match   = parseFloat(inc.matching   || 0);
  const cb      = parseFloat(inc.cashback   || 0);
  const club    = parseFloat(inc.club       || 0);
  const roi     = parseFloat(inc.roi        || 0);
  const gen     = parseFloat(inc.generation || 0);
  const lead    = parseFloat(inc.leadership || 0);
  const vch     = parseFloat(inc.voucher    || 0);
  const total   = sponsor + match + cb + club + roi + gen + lead + vch;
  const wallet  = parseFloat((UD && UD.walletBalance) || 0);
  const wd      = parseFloat((UD && UD.totalWithdrawn) || 0);
  const invested= parseFloat((UD && UD.totalInvested)  || 0);
  const teamSales = parseFloat((UD && UD.teamSales) || 0);

  set('ovTotal',   '$'+total.toFixed(2));
  set('ovTotalIncomeBig', '$'+total.toFixed(2));
  set('incAllTableTotal', '$'+total.toFixed(2));
  set('ovWallet',  '$'+wallet.toFixed(2));
  set('ovIncomeWallet', '$'+parseFloat((UD&&UD.incomeWallet)||0).toFixed(2));

  set('ibSponsor',  '$'+sponsor.toFixed(2));
  set('ibMatch',    '$'+match.toFixed(2));
  set('ibCashback', '$'+cb.toFixed(2));
  set('ibClub',     '$'+club.toFixed(2));
  set('ibRoi',      '$'+roi.toFixed(2));
  set('ibGen',      '$'+gen.toFixed(2));
  set('ibLead',     '$'+lead.toFixed(2));
  set('ibVoucher',  '$'+vch.toFixed(2));

  set('incAll',           '$'+total.toFixed(2));
  set('incWd',            '$'+wd.toFixed(2));
  set('incTotalInv',      '$'+invested.toFixed(2));
  set('incTypeSponsor',   '$'+sponsor.toFixed(2));
  set('incTypeMatch',     '$'+match.toFixed(2));
  set('incTypeCB',        '$'+cb.toFixed(2));
  set('incTypeClub',      '$'+club.toFixed(2));
  set('incTypeROI',       '$'+roi.toFixed(2));
  set('incTypeGen',       '$'+gen.toFixed(2));
  set('incTypeLead',      '$'+lead.toFixed(2));
  set('incTypeVoucher',   '$'+vch.toFixed(2));

  set('roiTotalInv',    '$'+invested.toFixed(2));
  set('roiTotalEarned', '$'+roi.toFixed(2));
  set('ldTotalEarned',  '$'+lead.toFixed(2));

  const cbLimit = parseFloat(SETTINGS.cashbackLimit || 60);
  set('cbEarned', '$'+cb.toFixed(2));
  const cbPct = Math.min((cb/cbLimit)*100,100);
  setW('cbProg', cbPct+'%');
  const cbEl = document.getElementById('cbStatus');
  const cbUpgradeCard = document.getElementById('cbUpgradeCard');
  if(cb >= cbLimit) {
    cbEl.innerHTML = '<span style="color:var(--red)">Limit Reached ($'+cbLimit.toFixed(2)+')</span>';
    if (cbUpgradeCard) cbUpgradeCard.style.display = 'block';
  } else if(UD && UD.isActive) {
    cbEl.innerHTML = '<span style="color:var(--green)">✅ Eligible</span>';
    if (cbUpgradeCard) cbUpgradeCard.style.display = 'none';
  } else {
    cbEl.innerHTML = '<span style="color:var(--muted)">Not Activated</span>';
    if (cbUpgradeCard) cbUpgradeCard.style.display = 'none';
  }

  const dirCount = Object.values(ALLU).filter(u=>u.sponsorId===CU.uid).length;
  set('clubDir',   dirCount+' / 10');
  set('clubMatch', '$'+match.toFixed(0)+' / $50');
  set('clubEarned','$'+club.toFixed(2));
  const clubOk = dirCount>=10 || match>=50;
  document.getElementById('clubEligBadge').innerHTML = clubOk
    ? '<span class="pill pg">✅ Eligible</span>'
    : '<span class="pill py">Not yet</span>';

  renderRank(match, teamSales);
  renderLeadershipIncome();
}

// ── LEADERSHIP INCOME (new: monthly Left+Right+Personal sales based) ──
function renderLeadershipIncome() {
  if (!UD) return;
  const leftSales  = parseFloat(UD.leftSales  || 0);
  const rightSales = parseFloat(UD.rightSales || 0);
  const personalSales = parseFloat(UD.totalInvested || 0);
  set('ldLeftSales', '$'+leftSales.toFixed(0));
  set('ldRightSales', '$'+rightSales.toFixed(0));
  set('ldPersonalSales', '$'+personalSales.toFixed(0));
  const rate = parseFloat(SETTINGS.leadershipPct || 2)/100;
  const eligible = (leftSales+rightSales+personalSales)*rate;
  set('ldEligible', '$'+eligible.toFixed(2));
  const lastClaim = UD.lastLeadershipClaim || 0;
  const now = new Date();
  const sameMonth = lastClaim && new Date(lastClaim).getMonth()===now.getMonth() && new Date(lastClaim).getFullYear()===now.getFullYear();
  set('ldLastClaim', lastClaim ? ('Last claim: '+new Date(lastClaim).toLocaleDateString()+(sameMonth?' (এই মাসে ইতিমধ্যে claim হয়েছে)':'')) : 'Last claim: Never');
}

window.claimLeadershipIncome = async () => {
  if (!UD) return;
  const lastClaim = UD.lastLeadershipClaim || 0;
  const now = new Date();
  if (lastClaim && new Date(lastClaim).getMonth()===now.getMonth() && new Date(lastClaim).getFullYear()===now.getFullYear()) {
    toast('❌ এই মাসে ইতিমধ্যে Leadership Income claim করা হয়েছে। পরের মাসে আবার আসুন।');
    return;
  }
  const leftSales  = parseFloat(UD.leftSales  || 0);
  const rightSales = parseFloat(UD.rightSales || 0);
  const personalSales = parseFloat(UD.totalInvested || 0);
  const rate = parseFloat(SETTINGS.leadershipPct || 2)/100;
  const amount = (leftSales+rightSales+personalSales)*rate;
  if (amount <= 0) { toast('এখনো কোনো Leadership Income eligible নেই।'); return; }
  try {
    const iRef  = rtdb.ref('users/'+CU.uid+'/income/leadership');
    const iSnap = await iRef.get();
    await iRef.set(parseFloat(iSnap.exists()?iSnap.val():0)+amount);
    const wRef  = rtdb.ref('users/'+CU.uid+'/walletBalance');
    const wSnap = await wRef.get();
    const newBal = parseFloat(wSnap.exists()?wSnap.val():0)+amount;
    await wRef.set(newBal);
    await rtdb.ref('users/'+CU.uid+'/lastLeadershipClaim').set(Date.now());
    await fsdb.collection('users').doc(CU.uid).update({ lastLeadershipClaim: Date.now() });
    UD.lastLeadershipClaim = Date.now();
    await rtdb.ref('transactions/'+CU.uid).push({
      type:'Leadership Income', amount: amount,
      note:'Monthly claim — Left+Right+Personal Sales', timestamp:Date.now(), status:'completed', balance:newBal
    });
    toast('✅ Leadership Income claimed: $'+amount.toFixed(2));
    renderLeadershipIncome();
  } catch(e) { toast('Error: '+e.message); }
};

// ── WALLET CARDS (Main / Income / P2B) ───────────────
function renderWalletCards() {
  const main   = parseFloat((UD&&UD.walletBalance)||0);
  const income = parseFloat((UD&&UD.incomeWallet)||0);
  const p2b    = parseFloat((UD&&UD.p2bWallet)||0);
  set('walMainD',   '$'+main.toFixed(2));
  set('walIncomeD', '$'+income.toFixed(2));
  set('walP2BD',    '$'+p2b.toFixed(2));
  set('ovWallet',   '$'+main.toFixed(2));
  set('ovIncomeWallet', '$'+income.toFixed(2));
  set('invMainBal',  '$'+main.toFixed(2));
  set('actMainBal',  '$'+main.toFixed(2));

  const inc = (UD && UD.income) || {};
  const total = ['sponsor','matching','cashback','club','roi','generation','leadership','voucher'].reduce((s,k)=>s+parseFloat(inc[k]||0),0);
  set('wTotalEarned', '$'+total.toFixed(2));
  set('wTotalWd', '$'+parseFloat((UD&&UD.totalWithdrawn)||0).toFixed(2));
}

// ── REFERRALS ────────────────────────────────────────
function loadReferrals() {
  const myRefs    = Object.values(ALLU).filter(u => u.sponsorId === CU.uid);
  const activeRef = myRefs.filter(u => u.isActive);

  set('ovDirRef',    myRefs.length);
  set('ovDirRefSub', activeRef.length+' active');
  set('refCountLbl', myRefs.length+' total');
  set('tmDirRef',    myRefs.length);
  set('tmTotal',     myRefs.length);
  set('tmActive',    activeRef.length);
  set('tmVol',       '$'+(activeRef.length*30));

  const rb = document.getElementById('refTbody');
  rb.innerHTML = myRefs.length === 0
    ? '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:16px">No referrals yet. Share your link!</td></tr>'
    : myRefs.map(u => `<tr>
        <td style="font-weight:700">${u.fullName||'User'}</td>
        <td style="color:var(--muted)">@${u.username||'—'}</td>
        <td style="color:var(--muted)">${u.email||'—'}</td>
        <td>${u.createdAt ? (u.createdAt.toDate?u.createdAt.toDate().toLocaleDateString():new Date(u.createdAt).toLocaleDateString()) : '—'}</td>
        <td><span class="pill ${u.isActive?'pg':'py'}">${u.isActive?'Active':'Inactive'}</span></td>
      </tr>`).join('');

  renderJoiningHistory(myRefs);
}

// ── JOINING HISTORY ──────────────────────────────────
function renderJoiningHistory(myRefs) {
  const tb = document.getElementById('joiningHistTb');
  if (!tb) return;
  set('joinCountLbl', myRefs.length+' entries');
  if (!myRefs.length) { tb.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:18px">No joining history yet</td></tr>'; return; }
  const sorted = [...myRefs].sort((a,b)=>{
    const ta = a.createdAt ? (a.createdAt.toDate?a.createdAt.toDate().getTime():new Date(a.createdAt).getTime()) : 0;
    const tb2 = b.createdAt ? (b.createdAt.toDate?b.createdAt.toDate().getTime():new Date(b.createdAt).getTime()) : 0;
    return tb2-ta;
  });
  tb.innerHTML = sorted.map(u=>{
    const side = u.id===UD.leftChild?'LEFT':u.id===UD.rightChild?'RIGHT':'Direct';
    const joined = u.createdAt ? (u.createdAt.toDate?u.createdAt.toDate().toLocaleDateString():new Date(u.createdAt).toLocaleDateString()) : '—';
    return `<tr>
      <td style="font-size:.72rem">${joined}</td>
      <td style="font-weight:700">${u.fullName||'User'}</td>
      <td style="color:var(--muted)">@${u.username||'—'}</td>
      <td style="font-family:monospace;font-size:.68rem">${u.sponsorId||'—'}</td>
      <td><span class="pill ${side==='LEFT'?'pb':side==='RIGHT'?'pp':'py'}">${side}</span></td>
      <td><span class="pill ${u.isActive?'pg':'py'}">${u.isActive?'Active':'Inactive'}</span></td>
    </tr>`;
  }).join('');
}

// ── INVESTMENT HISTORY (commission from new IDs/sales) ─
function renderInvestHistory(plans) {
  const tb = document.getElementById('investHistTb');
  if (!tb) return;
  rtdb.ref('transactions/'+CU.uid).get().then(snap=>{
    if (!snap.exists()) {
      tb.innerHTML='<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:18px">No history yet</td></tr>';
      renderOwnPayHistory([]);
      return;
    }
    const allTx = Object.values(snap.val());
    const txs = allTx.filter(t=>
      (t.type||'').toLowerCase().includes('generation') ||
      (t.type||'').toLowerCase().includes('sponsor') ||
      (t.type||'').toLowerCase().includes('roi referral')
    ).sort((a,b)=>b.timestamp-a.timestamp);
    let totalComm=0;
    tb.innerHTML = txs.length ? txs.map(t=>{
      totalComm += (t.amount||0);
      return `<tr>
        <td style="font-size:.72rem">${new Date(t.timestamp).toLocaleDateString()}</td>
        <td style="color:var(--muted);font-size:.75rem">${t.note||'—'}</td>
        <td>—</td>
        <td style="color:var(--green);font-weight:700">$${(t.amount||0).toFixed(2)}</td>
        <td><span class="pill pb">${t.type||'—'}</span></td>
      </tr>`;
    }).join('') : '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:18px">No history yet</td></tr>';
    set('ihTotalCount', txs.length);
    set('ihTotalComm', '$'+totalComm.toFixed(2));

    const ownPay = allTx.filter(t=>
      (t.type||'').toLowerCase().includes('activation payment') ||
      (t.type||'').toLowerCase().includes('investment payment')
    ).sort((a,b)=>b.timestamp-a.timestamp);
    renderOwnPayHistory(ownPay);
  });
  const invEntries = Object.values(plans||{});
  const totalAmt = invEntries.reduce((s,p)=>s+(p.amount||0),0);
  set('ihTotalAmt', '$'+totalAmt.toFixed(0));
}

function renderOwnPayHistory(list) {
  const tb = document.getElementById('ownPayHistTb');
  if (!tb) return;
  set('ownPayCountLbl', list.length+' entries');
  tb.innerHTML = list.length ? list.map(t=>{
    const isAct = (t.type||'').toLowerCase().includes('activation');
    return `<tr>
      <td style="font-size:.72rem">${new Date(t.timestamp).toLocaleDateString()+' '+new Date(t.timestamp).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</td>
      <td><span class="pill ${isAct?'pg':'pb'}">${isAct?'Activation':'Investment'}</span></td>
      <td style="font-weight:700;color:var(--red)">$${Math.abs(t.amount||0).toFixed(2)}</td>
      <td style="color:var(--muted);font-size:.72rem">Main Wallet</td>
      <td><span class="pill ${t.status==='completed'?'pg':'py'}">${t.status||'completed'}</span></td>
    </tr>`;
  }).join('') : '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:18px">No history yet</td></tr>';
}

// ── BINARY TREE (enhanced: active count / carry / invested / withdrawn) ──
function renderBinaryTree() {
  const container = document.getElementById('treeContainer');
  const downlineTb = document.getElementById('downlineTbody');
  if (!UD) return;

  const leftChild  = UD.leftChild;
  const rightChild = UD.rightChild;
  let leftCount = 0, rightCount = 0, leftActive=0, rightActive=0;
  let leftInvested = 0, rightInvested = 0, leftWithdrawn = 0, rightWithdrawn = 0;

  const allDownline = [];
  function bfsCount(uid, side, level) {
    if (!uid || !ALLU[uid]) return;
    const u = ALLU[uid];
    const inv = parseFloat(u.totalInvested||0);
    const wd  = parseFloat(u.totalWithdrawn||0);
    if (side === 'left') { leftCount++; if(u.isActive) leftActive++; leftInvested+=inv; leftWithdrawn+=wd; }
    else if (side === 'right') { rightCount++; if(u.isActive) rightActive++; rightInvested+=inv; rightWithdrawn+=wd; }
    allDownline.push({ u, side, level });
    if (u.leftChild)  bfsCount(u.leftChild,  side||'left',  level+1);
    if (u.rightChild) bfsCount(u.rightChild, side||'right', level+1);
  }
  if (leftChild)  bfsCount(leftChild,  'left',  1);
  if (rightChild) bfsCount(rightChild, 'right', 1);

  // Carry = business volume net of withdrawals (withdraw করলে carry কমে যায়)
  const leftCarryVol  = Math.max(0, leftInvested  - leftWithdrawn);
  const rightCarryVol = Math.max(0, rightInvested - rightWithdrawn);
  const leftCarry  = Math.max(0, leftCount - rightCount);
  const rightCarry = Math.max(0, rightCount - leftCount);
  const totalInvested = leftInvested + rightInvested;

  // Persist for Leadership Income + Matching calc
  if (UD) {
    UD.leftSales  = leftCarryVol;
    UD.rightSales = rightCarryVol;
    rtdb.ref('users/'+CU.uid+'/leftSales').set(leftCarryVol).catch(()=>{});
    rtdb.ref('users/'+CU.uid+'/rightSales').set(rightCarryVol).catch(()=>{});
  }

  const circle = document.getElementById('treeSummaryCircle');
  if (circle) {
    circle.innerHTML = `
      <div style="display:flex;align-items:center;gap:24px;flex-wrap:wrap;justify-content:center">
        <div style="text-align:center">
          <div style="font-size:.7rem;color:var(--muted);margin-bottom:4px">LEFT</div>
          <div style="font-weight:800;color:var(--accent)">${leftCount}</div>
          <div style="font-size:.65rem;color:var(--green)">${leftActive} active</div>
          <div style="font-size:.62rem;color:var(--gold)">$${leftCarryVol.toFixed(0)} carry</div>
        </div>
        <div style="width:150px;height:150px;border-radius:50%;background:radial-gradient(circle at 30% 30%, rgba(0,198,255,.25), rgba(124,58,237,.25));border:3px solid var(--accent);display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:0 0 30px rgba(0,198,255,.25)">
          <div style="font-size:.65rem;color:var(--muted)">TOTAL TEAM</div>
          <div style="font-size:1.5rem;font-weight:900">${leftCount+rightCount}</div>
          <div style="font-size:.65rem;color:var(--green)">${leftActive+rightActive} active</div>
          <div style="font-size:.63rem;color:var(--gold);margin-top:2px">$${totalInvested.toFixed(0)} invested</div>
        </div>
        <div style="text-align:center">
          <div style="font-size:.7rem;color:var(--muted);margin-bottom:4px">RIGHT</div>
          <div style="font-weight:800;color:var(--accent2)">${rightCount}</div>
          <div style="font-size:.65rem;color:var(--green)">${rightActive} active</div>
          <div style="font-size:.62rem;color:var(--gold)">$${rightCarryVol.toFixed(0)} carry</div>
        </div>
      </div>
      <div style="display:flex;gap:20px;justify-content:center;margin-top:14px;font-size:.72rem;color:var(--muted)">
        <span>Left Count-Carry: <strong style="color:var(--accent)">${leftCarry}</strong></span>
        <span>Right Count-Carry: <strong style="color:var(--accent2)">${rightCarry}</strong></span>
      </div>
      <div style="text-align:center;font-size:.65rem;color:var(--muted);margin-top:6px">⚠️ কেউ fund withdraw করলে carry volume সাথে সাথে কমে যাবে</div>`;
  }

  function makeNode(uid, label, isYou) {
    const u = uid && ALLU[uid];
    if (!uid) {
      return `<div class="tree-node">
        <div class="tree-box empty-node">
          <div class="tree-name" style="color:var(--muted)">Empty</div>
          <div class="tree-status" style="color:var(--muted)">— slot —</div>
        </div>
        ${label ? `<div style="font-size:.64rem;color:var(--muted);margin-top:4px">${label}</div>` : ''}
      </div>`;
    }
    const name   = u ? (u.fullName||u.username||'User') : '?';
    const active = u ? u.isActive : false;
    const inv    = u ? parseFloat(u.totalInvested||0) : 0;
    const wd     = u ? parseFloat(u.totalWithdrawn||0) : 0;
    const cls    = isYou ? 'you-node' : (active ? 'active-node' : '');
    return `<div class="tree-node">
      <div class="tree-box ${cls}" title="${name}">
        <div class="tree-name">${isYou ? '👤 '+name : name}</div>
        <div class="tree-status"><span class="pill ${active?'pg':'py'}" style="font-size:.6rem">${active?'Active':'Inactive'}</span></div>
        ${!isYou ? `<div class="tree-extra">Inv: $${inv.toFixed(0)} | WD: $${wd.toFixed(0)}</div>` : ''}
      </div>
      ${label ? `<div style="font-size:.64rem;color:var(--muted);margin-top:4px">${label}</div>` : ''}
    </div>`;
  }
  function lvl2(uid) {
    const u = uid && ALLU[uid];
    const lc = u ? u.leftChild  : null;
    const rc = u ? u.rightChild : null;
    return `<div style="display:flex;gap:16px;position:relative">
      <div style="position:absolute;top:0;left:25%;right:25%;height:1px;background:var(--border)"></div>
      ${makeNode(lc,'L')}${makeNode(rc,'R')}
    </div>`;
  }

  container.innerHTML = `
    <div style="display:flex;flex-direction:column;align-items:center;gap:0">
      ${makeNode(CU.uid,'You',true)}
      <div style="width:1px;height:20px;background:var(--border)"></div>
      <div style="position:relative;width:200px;height:1px;background:${(leftChild||rightChild)?'var(--border)':'transparent'}"></div>
      <div style="display:flex;gap:40px;position:relative">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0">
          <div style="width:1px;height:0px"></div>
          ${makeNode(leftChild,'LEFT')}
          <div style="width:1px;height:16px;background:${leftChild?'var(--border)':'transparent'}"></div>
          ${lvl2(leftChild)}
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:0">
          <div style="width:1px;height:0px"></div>
          ${makeNode(rightChild,'RIGHT')}
          <div style="width:1px;height:16px;background:${rightChild?'var(--border)':'transparent'}"></div>
          ${lvl2(rightChild)}
        </div>
      </div>
    </div>`;

  downlineTb.innerHTML = allDownline.length === 0
    ? '<tr><td colspan="8" style="text-align:center;color:var(--muted);padding:16px">No downline yet</td></tr>'
    : allDownline.map(({u,side,level}) => `<tr>
        <td style="font-weight:700">${u.fullName||'User'}</td>
        <td style="color:var(--muted)">@${u.username||'—'}</td>
        <td><span class="pill pb">Level ${level}</span></td>
        <td><span class="pill ${side==='left'?'pb':'pp'}">${side.toUpperCase()}</span></td>
        <td><span class="pill ${u.isActive?'pg':'py'}">${u.isActive?'Active':'Inactive'}</span></td>
        <td style="color:var(--green)">$${parseFloat(u.totalInvested||0).toFixed(0)}</td>
        <td style="color:var(--red)">$${parseFloat(u.totalWithdrawn||0).toFixed(0)}</td>
        <td>${u.createdAt?(u.createdAt.toDate?u.createdAt.toDate().toLocaleDateString():new Date(u.createdAt).toLocaleDateString()):'—'}</td>
      </tr>`).join('');
}

// ── RANK ─────────────────────────────────────────────
function renderRank(matching, teamSales) {
  const ranks = [
    {name:'No Rank',    stars:'☆',         mReq:0,      sReq:0},
    {name:'One Star',   stars:'⭐',         mReq:50,     sReq:100},
    {name:'Two Star',   stars:'⭐⭐',       mReq:300,    sReq:300},
    {name:'Three Star', stars:'⭐⭐⭐',     mReq:1000,   sReq:1000},
    {name:'Four Star',  stars:'⭐⭐⭐⭐',   mReq:3000,   sReq:10000},
    {name:'Five Star',  stars:'⭐⭐⭐⭐⭐', mReq:10000,  sReq:100000},
    {name:'Six Star',   stars:'6⭐',        mReq:30000,  sReq:300000},
    {name:'Seven Star', stars:'7⭐',        mReq:100000, sReq:10000000}
  ];
  let idx = 0;
  for(let i=1;i<ranks.length;i++) {
    if(matching>=ranks[i].mReq && teamSales>=ranks[i].sReq) idx=i;
  }
  const cur  = ranks[idx];
  const next = ranks[idx+1]||null;
  set('rankStarsD', cur.stars);
  set('rankNameD',  cur.name);
  set('infoRank',   cur.name);
  if(next){
    set('rankNextHint', 'Next: '+next.name);
    setW('rankMatchF', Math.min((matching/next.mReq)*100,100)+'%');
    setW('rankSalesF', Math.min((teamSales/next.sReq)*100,100)+'%');
    set('rankMatchV', matching+'/'+next.mReq);
    set('rankSalesV', '$'+teamSales+'/$'+next.sReq);
  } else {
    set('rankNextHint','🏆 Highest rank achieved!');
  }
}

// ── TRANSACTIONS ─────────────────────────────────────
function renderTransactions(txObj) {
  const txns = Object.entries(txObj).sort(([,a],[,b])=>b.timestamp-a.timestamp);
  set('txCountLbl', txns.length+' records');

  const today = new Date(); today.setHours(0,0,0,0);
  const monthStart = new Date(today.getFullYear(),today.getMonth(),1);
  let todayTotal=0, monthTotal=0;

  const rows = txns.map(([id,t]) => {
    const d = new Date(t.timestamp);
    if(d >= today) todayTotal += t.amount||0;
    if(d >= monthStart) monthTotal += t.amount||0;
    const dt = d.toLocaleDateString()+' '+d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
    return `<tr>
      <td style="color:var(--muted);font-size:.72rem">${dt}</td>
      <td>${t.type||'—'}</td>
      <td style="color:var(--muted);font-size:.75rem">${t.note||'—'}</td>
      <td style="font-weight:700;color:${t.amount>0?'var(--green)':'var(--red)'}">
        ${t.amount>0?'+':''}$${Math.abs(t.amount||0).toFixed(2)}
      </td>
      <td><span class="pill ${t.status==='completed'?'pg':t.status==='pending'?'py':'pb'}">${t.status||'done'}</span></td>
    </tr>`;
  }).join('');

  document.getElementById('incTxTable').innerHTML = rows ||
    '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:18px">No transactions yet</td></tr>';
  set('incToday', '$'+todayTotal.toFixed(2));
  set('incMonth', '$'+monthTotal.toFixed(2));

  document.getElementById('ovRecentTx').innerHTML = txns.slice(0,5).map(([id,t])=>`
    <tr>
      <td>${new Date(t.timestamp).toLocaleDateString()}</td>
      <td>${t.type||'—'}</td>
      <td style="color:${t.amount>0?'var(--green)':'var(--red)'};font-weight:700">
        ${t.amount>0?'+':''}$${Math.abs(t.amount||0).toFixed(2)}
      </td>
    </tr>`).join('') ||
    '<tr><td colspan="3" style="text-align:center;color:var(--muted)">None</td></tr>';

  renderWalletHistory(txObj);
  renderInvestHistory({});
}

function renderWalletHistory(txObj) {
  const txns = Object.entries(txObj).sort(([,a],[,b])=>b.timestamp-a.timestamp);
  document.getElementById('walHistTb').innerHTML = txns.length
    ? txns.slice(0,30).map(([id,t])=>`<tr>
        <td>${new Date(t.timestamp).toLocaleDateString()}</td>
        <td>${t.type||'—'}</td>
        <td style="font-weight:700;color:${t.amount>0?'var(--green)':'var(--red)'}">
          ${t.amount>0?'+':''}$${Math.abs(t.amount||0).toFixed(2)}
        </td>
        <td><span class="pill ${t.status==='completed'?'pg':t.status==='pending'?'py':'pb'}">${t.status||'done'}</span></td>
      </tr>`).join('')
    : '<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:14px">No transactions</td></tr>';
}

function renderROIPlans(plans) {
  const tb = document.getElementById('roiPlansTb');
  const entries = Object.entries(plans).sort(([,a],[,b])=>b.createdAt-a.createdAt);
  let activeCnt=0, nextD=null;
  const lockMonths = parseFloat(SETTINGS.invLockMonths||6);
  tb.innerHTML = entries.length
    ? entries.map(([id,p],i)=>{
        if(p.status==='active') activeCnt++;
        const lockEnd  = new Date(p.createdAt + lockMonths*30*24*60*60*1000);
        const locked   = Date.now() < lockEnd.getTime();
        if(!nextD && p.status==='active') nextD = new Date(p.createdAt+30*24*60*60*1000);
        return `<tr>
          <td style="color:var(--muted)">${i+1}</td>
          <td style="color:var(--accent);font-weight:700">$${p.amount}</td>
          <td>${new Date(p.createdAt).toLocaleDateString()}</td>
          <td style="color:var(--gold)">$${(p.earnedROI||0).toFixed(2)}</td>
          <td>${lockEnd.toLocaleDateString()}</td>
          <td><span class="pill ${p.status==='active'?'pg':p.status==='pending'?'py':'pb'}">${p.status||'pending'}</span></td>
          <td>${!locked&&p.status==='active'
            ?'<button class="btn btn-r btn-sm" onclick="withdrawCapital(\''+id+'\')">Withdraw</button>'
            :'<span style="color:var(--muted);font-size:.7rem">'+(p.status==='pending'?'Awaiting':'Locked')+'</span>'}</td>
        </tr>`;
      }).join('')
    : '<tr><td colspan="7" style="text-align:center;color:var(--muted);padding:18px">No investments yet</td></tr>';
  set('roiActivePlans', activeCnt);
  set('roiNextDate', nextD ? nextD.toLocaleDateString() : '—');
}

// ── NOTICE MARQUEE (new: slow scrolling ticker under header) ──
async function loadNoticeBar() {
  try {
    const snap = await rtdb.ref('notices').get();
    const bar = document.getElementById('noticeBar');
    const track = document.getElementById('noticeTrack');
    const mainWrap = document.getElementById('mainWrap');
    if (!snap.exists()) { bar.classList.add('hide'); mainWrap.classList.remove('with-notice'); return; }
    const now = Date.now();
    const isActive = UD ? !!UD.isActive : false;
    const list = Object.values(snap.val()).filter(n=>{
      if (n.expiry && n.expiry < now) return false;
      if (n.target==='active' && !isActive) return false;
      if (n.target==='inactive' && isActive) return false;
      return true;
    }).sort((a,b)=>b.createdAt-a.createdAt);
    if (!list.length) { bar.classList.add('hide'); mainWrap.classList.remove('with-notice'); return; }
    const typeIcon = {info:'ℹ️',warning:'⚠️',success:'✅',urgent:'🚨'};
    track.innerHTML = list.map(n=>`<span><b>${typeIcon[n.type]||'📢'} ${n.title}:</b>${n.message}</span>`).join('') +
                       list.map(n=>`<span><b>${typeIcon[n.type]||'📢'} ${n.title}:</b>${n.message}</span>`).join('');
    bar.classList.remove('hide');
    mainWrap.classList.add('with-notice');
  } catch(e) { /* silent */ }
}

// ── GIFT VOUCHER (new) ────────────────────────────────
async function loadMyVouchers() {
  const listEl = document.getElementById('vchList');
  const badge  = document.getElementById('vchBadge');
  if (!listEl || !CU) return;
  try {
    const snap = await rtdb.ref('giftVouchers').get();
    if (!snap.exists()) { listEl.innerHTML='<div style="text-align:center;color:var(--muted);padding:16px">No vouchers yet</div>'; if(badge) badge.style.display='none'; return; }
    const entries = Object.entries(snap.val()).filter(([id,v])=>{
      const targetOk = !v.targetUid || v.targetUid==='all' || v.targetUid===CU.uid;
      return targetOk;
    }).sort(([,a],[,b])=>b.createdAt-a.createdAt);
    set('vchCountLbl', entries.length+' vouchers');
    const claimable = entries.filter(([id,v])=> v.status==='active' && (!v.usedBy || (v.usedByMulti && !(v.usedByMulti||{})[CU.uid])) );
    if (badge) { const c = claimable.length; badge.style.display = c>0?'inline':'none'; badge.textContent = c; }
    listEl.innerHTML = entries.length ? entries.map(([id,v])=>{
      const usedByMe = v.usedBy===CU.uid || (v.usedByMulti && v.usedByMulti[CU.uid]);
      const canClaim = v.status==='active' && !usedByMe && (v.targetUid===CU.uid || v.targetUid==='all' || !v.targetUid);
      return `<div class="voucher-card">
        <div>
          <div class="vc-code">${v.code||id.slice(0,10)}</div>
          <div style="font-size:.68rem;opacity:.85">${v.note||'Gift Voucher'}</div>
        </div>
        <div style="text-align:right">
          <div class="vc-amt">$${v.amount||0}</div>
          ${canClaim
            ? `<button class="btn btn-g btn-sm" onclick="claimVoucher('${id}')">🎁 Claim</button>`
            : `<span class="pill ${usedByMe?'pg':'pr'}" style="background:rgba(255,255,255,.25);color:#fff">${usedByMe?'Claimed':'Not available'}</span>`}
        </div>
      </div>`;
    }).join('') : '<div style="text-align:center;color:var(--muted);padding:16px">No vouchers for you yet</div>';
  } catch(e) { listEl.innerHTML = '<div style="text-align:center;color:var(--red);padding:16px">Error loading vouchers</div>'; }
}

window.claimVoucher = async (id) => {
  try {
    const ref  = rtdb.ref('giftVouchers/'+id);
    const snap = await ref.get();
    if (!snap.exists()) { toast('Voucher not found'); return; }
    const v = snap.val();
    if (v.status !== 'active') { toast('This voucher is no longer active'); return; }
    if (v.targetUid && v.targetUid!=='all' && v.targetUid!==CU.uid) { toast('This voucher is not for you'); return; }
    const usedByMe = v.usedBy===CU.uid || (v.usedByMulti && v.usedByMulti[CU.uid]);
    if (usedByMe) { toast('আপনি ইতিমধ্যে এই voucher claim করেছেন'); return; }

    const amount = parseFloat(v.amount||0);
    const wRef  = rtdb.ref('users/'+CU.uid+'/walletBalance');
    const wSnap = await wRef.get();
    const newBal = parseFloat(wSnap.exists()?wSnap.val():0)+amount;
    await wRef.set(newBal);

    const iRef  = rtdb.ref('users/'+CU.uid+'/income/voucher');
    const iSnap = await iRef.get();
    await iRef.set(parseFloat(iSnap.exists()?iSnap.val():0)+amount);

    if (v.targetUid==='all') {
      await ref.child('usedByMulti/'+CU.uid).set(true);
    } else {
      await ref.update({ status:'used', usedBy:CU.uid, usedAt:Date.now() });
    }

    await rtdb.ref('transactions/'+CU.uid).push({
      type:'Gift Voucher', amount: amount,
      note:'Voucher '+(v.code||id)+' claimed', timestamp:Date.now(), status:'completed', balance:newBal
    });
    toast('✅ Voucher claimed! $'+amount.toFixed(2)+' Main Wallet এ যোগ হয়েছে');
    loadMyVouchers();
  } catch(e) { toast('Error: '+e.message); }
};

window.redeemVoucherCode = async () => {
  const code = document.getElementById('vchCodeInput').value.trim();
  if (!code) { toast('Voucher code দিন'); return; }
  try {
    const snap = await rtdb.ref('giftVouchers').orderByChild('code').equalTo(code).get();
    if (!snap.exists()) { toast('❌ Invalid voucher code'); return; }
    const [id] = Object.keys(snap.val());
    await claimVoucher(id);
    document.getElementById('vchCodeInput').value='';
  } catch(e) { toast('Error: '+e.message); }
};

// ── DYNAMIC CHARGE LABELS ─────────────────────────────

// ── ACTIONS ──────────────────────────────────────────
window.saveProfile = async () => {
  try {
    const updates = {
      fullName:      document.getElementById('pfName').value.trim(),
      mobile:        document.getElementById('pfPhone').value.trim(),
      paymentWallet: document.getElementById('pfWallet').value.trim(),
      updatedAt:     new Date()
    };
    await fsdb.collection('users').doc(CU.uid).update(updates);
    Object.assign(UD, updates);
    document.getElementById('sbName').textContent = UD.fullName||'User';
    toast('✅ Profile saved!');
  } catch(e) { toast('Error: '+e.message); }
};

// Activation — now pays from MAIN WALLET (no P2B involved)
window.submitActivation = async () => {
  if (UD && UD.isActive) { toast('Already active!'); return; }
  const fee  = parseFloat(SETTINGS.activationFee||30);
  const main = parseFloat(UD.walletBalance||0);
  if (main < fee) { toast('❌ Main Wallet এ পর্যাপ্ত ব্যালেন্স নেই। প্রয়োজন $'+fee.toFixed(2)); return; }
  try {
    const mRef = rtdb.ref('users/'+CU.uid+'/walletBalance');
    const newMain = main - fee;
    await mRef.set(newMain);
    UD.walletBalance = newMain;
    await rtdb.ref('transactions/'+CU.uid).push({
      type:'Activation Payment', amount:-fee,
      note:'Paid from Main Wallet', timestamp:Date.now(), status:'completed'
    });
    await rtdb.ref('activationRequests').push({
      uid:       CU.uid,
      email:     CU.email,
      name:      UD?.fullName || UD?.username || '',
      username:  UD?.username || '',
      txid:      'MAIN-WALLET-PAYMENT', method:'Main Wallet', amount: fee,
      status:    'pending',
      createdAt: Date.now()
    });
    toast('✅ Payment done from Main Wallet. Admin will approve soon. Approve হলে Withdraw খুলে যাবে।');
    renderWalletCards();
  } catch(e) { toast('Error: '+e.message); }
};

// Investment — now pays from MAIN WALLET, no fee, full amount invested
window.submitInvestment = async () => {
  if (!UD?.isActive) { toast('Activate your account first!'); return; }
  const amt  = parseFloat(document.getElementById('invAmt').value);
  const minInv = parseFloat(SETTINGS.minInvestment||100);
  if (!amt || amt < minInv) { toast('Minimum investment is $'+minInv); return; }
  const main = parseFloat(UD.walletBalance||0);
  if (main < amt) { toast('❌ Main Wallet এ পর্যাপ্ত ব্যালেন্স নেই।'); return; }
  try {
    const mRef = rtdb.ref('users/'+CU.uid+'/walletBalance');
    const newMain = main - amt;
    await mRef.set(newMain);
    UD.walletBalance = newMain;
    await rtdb.ref('investments/'+CU.uid).push({
      amount:    amt,
      method:    'Main Wallet',
      txid:      'MAIN-WALLET-PAYMENT',
      roiRate:   SETTINGS.roiRate||12,
      status:    'pending',
      earnedROI: 0,
      createdAt: Date.now()
    });
    const newInv = (UD.totalInvested||0) + amt;
    await rtdb.ref('users/'+CU.uid+'/totalInvested').set(newInv);
    await fsdb.collection('users').doc(CU.uid).update({ totalInvested:newInv });
    UD.totalInvested = newInv;
    await rtdb.ref('transactions/'+CU.uid).push({
      type:'Investment Payment', amount:-amt,
      note:'Paid from Main Wallet — no fee, full amount invested', timestamp:Date.now(), status:'completed'
    });
    toast('✅ পুরো $'+amt.toFixed(2)+' Invest হয়েছে Main Wallet থেকে (No Fee)! Admin will activate shortly.');
    document.getElementById('invAmt').value  = '';
    renderWalletCards();
    const invSnap = await rtdb.ref('investments/'+CU.uid).get();
    if(invSnap.exists()) { renderROIPlans(invSnap.val()); renderInvestHistory(invSnap.val()); }
  } catch(e) { toast('Error: '+e.message); }
};

window.withdrawCapital = async pid => {
  if (!confirm('Withdraw capital? Fee will be deducted as per admin settings.')) return;
  await rtdb.ref('investments/'+CU.uid+'/'+pid).update({
    status:'withdrawal_requested', wdRequestAt: Date.now()
  });
  toast('Capital withdrawal requested!');
  const invSnap = await rtdb.ref('investments/'+CU.uid).get();
  if(invSnap.exists()) renderROIPlans(invSnap.val());
};

window.requestCashbackUpgrade = async () => {
  try {
    await rtdb.ref('cashbackUpgradeRequests').push({
      uid: CU.uid, email: CU.email, name: UD?.fullName||UD?.username||'',
      currentEarned: (UD.income&&UD.income.cashback)||0,
      status:'pending', createdAt: Date.now()
    });
    toast('✅ Upgrade request পাঠানো হয়েছে। Admin অনুমোদন দিলে নতুন limit পাবে (খরচ সব active user এর distribution pool থেকে কাটা হবে)।');
  } catch(e){ toast('Error: '+e.message); }
};

// ── WALLET TRANSFER ACTIONS ──────────────────────────
window.switchWTab = (tab) => {
  ['i2p','m2p','p2m','m2m','i2m'].forEach(t=>{
    document.getElementById('wtab_'+t).classList.toggle('active', t===tab);
    document.getElementById('wform_'+t).style.display = t===tab ? 'block':'none';
  });
};

window.transferIncomeToP2B = async () => {
  const amt = parseFloat(document.getElementById('i2pAmt').value);
  if (!amt || amt<=0) { toast('সঠিক amount দাও'); return; }
  const income = parseFloat(UD.incomeWallet||0);
  if (amt > income) { toast('❌ Income Wallet এ পর্যাপ্ত ব্যালেন্স নেই'); return; }
  try {
    const newIncome = income - amt;
    const newP2B    = parseFloat(UD.p2bWallet||0) + amt;
    await rtdb.ref('users/'+CU.uid+'/incomeWallet').set(newIncome);
    await rtdb.ref('users/'+CU.uid+'/p2bWallet').set(newP2B);
    UD.incomeWallet = newIncome; UD.p2bWallet = newP2B;
    await rtdb.ref('transactions/'+CU.uid).push({ type:'Transfer Income→P2B', amount:amt, note:'Free transfer', timestamp:Date.now(), status:'completed' });
    toast('✅ Transfer সম্পন্ন!');
    document.getElementById('i2pAmt').value='';
    renderWalletCards();
  } catch(e){ toast('Error: '+e.message); }
};

window.transferMainToP2B = async () => {
  const targetRaw = document.getElementById('m2pTarget').value.trim();
  const amt = parseFloat(document.getElementById('m2pAmt').value);
  if (!amt || amt<=0) { toast('সঠিক amount দাও'); return; }
  const main = parseFloat(UD.walletBalance||0);
  if (amt > main) { toast('❌ Main Wallet এ পর্যাপ্ত ব্যালেন্স নেই'); return; }

  let targetId = CU.uid;
  let targetLabel = 'নিজের P2B Wallet';
  if (targetRaw) {
    const target = Object.values(ALLU).find(u => u.id===targetRaw || u.memberId===targetRaw || u.username===targetRaw);
    if (!target) { toast('❌ User খুঁজে পাওয়া যায়নি'); return; }
    targetId = target.id;
    targetLabel = target.fullName || target.username || target.id;
  }

  try {
    const newMain = main - amt;
    await rtdb.ref('users/'+CU.uid+'/walletBalance').set(newMain);
    UD.walletBalance = newMain;

    const tRef  = rtdb.ref('users/'+targetId+'/p2bWallet');
    const tSnap = await tRef.get();
    const tNewP2B = parseFloat(tSnap.exists()?tSnap.val():0)+amt;
    await tRef.set(tNewP2B);
    if (targetId === CU.uid) UD.p2bWallet = tNewP2B;

    await rtdb.ref('transactions/'+CU.uid).push({ type:'Transfer Main→P2B', amount:-amt, note:(targetId===CU.uid?'নিজের P2B Wallet এ':'To '+targetLabel+' P2B Wallet')+' (Free)', timestamp:Date.now(), status:'completed' });
    if (targetId !== CU.uid) {
      await rtdb.ref('transactions/'+targetId).push({ type:'Received Main→P2B', amount:amt, note:'From '+(UD.fullName||UD.username||CU.uid), timestamp:Date.now(), status:'completed' });
    }

    toast('✅ $'+amt.toFixed(2)+' পাঠানো হয়েছে '+targetLabel+' এর P2B Wallet এ!');
    document.getElementById('m2pTarget').value='';
    document.getElementById('m2pAmt').value='';
    renderWalletCards();
  } catch(e){ toast('Error: '+e.message); }
};

window.transferP2BToMain = async () => {
  const amt = parseFloat(document.getElementById('p2mAmt').value);
  if (!amt || amt<=0) { toast('সঠিক amount দাও'); return; }
  const p2b = parseFloat(UD.p2bWallet||0);
  if (amt > p2b) { toast('❌ P2B Wallet এ পর্যাপ্ত ব্যালেন্স নেই'); return; }
  try {
    const newP2B  = p2b - amt;
    const newMain = parseFloat(UD.walletBalance||0) + amt;
    await rtdb.ref('users/'+CU.uid+'/p2bWallet').set(newP2B);
    await rtdb.ref('users/'+CU.uid+'/walletBalance').set(newMain);
    UD.p2bWallet = newP2B; UD.walletBalance = newMain;
    await rtdb.ref('transactions/'+CU.uid).push({ type:'Transfer P2B→Main', amount:amt, note:'Free transfer', timestamp:Date.now(), status:'completed' });
    toast('✅ Transfer সম্পন্ন! এখন Main → P2B (যেকোনো User) ট্যাব দিয়ে অন্যকে পাঠাতে পারো।');
    document.getElementById('p2mAmt').value='';
    renderWalletCards();
  } catch(e){ toast('Error: '+e.message); }
};

window.transferMainToMain = async () => {
  const targetRaw = document.getElementById('m2mTarget').value.trim();
  const amt = parseFloat(document.getElementById('m2mAmt').value);
  if (!targetRaw) { toast('Receiver ID/Username দাও'); return; }
  if (!amt || amt<=0) { toast('সঠিক amount দাও'); return; }
  const main = parseFloat(UD.walletBalance||0);
  if (amt > main) { toast('❌ Main Wallet এ পর্যাপ্ত ব্যালেন্স নেই'); return; }

  const target = Object.values(ALLU).find(u => u.id===targetRaw || u.memberId===targetRaw || u.username===targetRaw);
  if (!target) { toast('❌ User খুঁজে পাওয়া যায়নি'); return; }
  if (target.id === CU.uid) { toast('নিজেকে transfer করা যাবে না'); return; }

  try {
    const newMain = main - amt;
    await rtdb.ref('users/'+CU.uid+'/walletBalance').set(newMain);
    UD.walletBalance = newMain;
    const tRef  = rtdb.ref('users/'+target.id+'/walletBalance');
    const tSnap = await tRef.get();
    const tNewBal = parseFloat(tSnap.exists()?tSnap.val():0)+amt;
    await tRef.set(tNewBal);

    await rtdb.ref('transactions/'+CU.uid).push({ type:'P2P Transfer Sent', amount:-amt, note:'To '+(target.fullName||target.username||target.id), timestamp:Date.now(), status:'completed' });
    await rtdb.ref('transactions/'+target.id).push({ type:'P2P Transfer Received', amount:amt, note:'From '+(UD.fullName||UD.username||CU.uid), timestamp:Date.now(), status:'completed' });

    toast('✅ '+(target.fullName||target.username)+' কে $'+amt.toFixed(2)+' পাঠানো হয়েছে!');
    document.getElementById('m2mTarget').value=''; document.getElementById('m2mAmt').value='';
    renderWalletCards();
  } catch(e){ toast('Error: '+e.message); }
};

window.calcI2MPreview = () => {
  const amt = parseFloat(document.getElementById('i2mAmt').value);
  const prev = document.getElementById('i2mPreview');
  if (!amt || amt<=0) { prev.style.display='none'; return; }
  const chargePct = parseFloat(SETTINGS.incomeToMainCharge != null ? SETTINGS.incomeToMainCharge : 5)/100;
  const charge = amt*chargePct;
  const net = amt-charge;
  set('i2mPrevAmt', '$'+amt.toFixed(2));
  set('i2mPrevCharge', '-$'+charge.toFixed(2));
  set('i2mPrevNet', '$'+net.toFixed(2));
  prev.style.display='block';
};

window.transferIncomeToMain = async () => {
  const amt = parseFloat(document.getElementById('i2mAmt').value);
  if (!amt || amt<=0) { toast('সঠিক amount দাও'); return; }
  const income = parseFloat(UD.incomeWallet||0);
  if (amt > income) { toast('❌ Income Wallet এ পর্যাপ্ত ব্যালেন্স নেই'); return; }
  const chargePct = parseFloat(SETTINGS.incomeToMainCharge != null ? SETTINGS.incomeToMainCharge : 5)/100;
  const charge = amt*chargePct;
  const net = amt-charge;
  try {
    const newIncome = income - amt;
    const newMain   = parseFloat(UD.walletBalance||0) + net;
    await rtdb.ref('users/'+CU.uid+'/incomeWallet').set(newIncome);
    await rtdb.ref('users/'+CU.uid+'/walletBalance').set(newMain);
    UD.incomeWallet = newIncome; UD.walletBalance = newMain;
    await rtdb.ref('transactions/'+CU.uid).push({ type:'Transfer Income→Main', amount:net, note:'Charge: $'+charge.toFixed(2)+' ('+(chargePct*100)+'%)', timestamp:Date.now(), status:'completed' });
    toast('✅ Transfer সম্পন্ন! $'+net.toFixed(2)+' Main Wallet এ যোগ হয়েছে।');
    document.getElementById('i2mAmt').value='';
    document.getElementById('i2mPreview').style.display='none';
    renderWalletCards();
  } catch(e){ toast('Error: '+e.message); }
};

// Withdraw — এখন ID Active না হলে বন্ধ থাকবে
window.submitWithdraw = async () => {
  if (!UD?.isActive) { toast('❌ Withdraw করতে হলে আগে ID Activate করতে হবে!'); showPage('activation', null); return; }
  const amt  = parseFloat(document.getElementById('wdAmt').value);
  const addr = document.getElementById('wdAddr').value.trim();
  const minWd = parseFloat(SETTINGS.minWithdrawal||10);
  if (!amt || amt<minWd)  { toast('Min withdrawal $'+minWd); return; }
  if (!addr)           { toast('Enter wallet address'); return; }
  const bal = parseFloat(UD?.walletBalance||0);
  if (amt > bal)       { toast('Insufficient Main Wallet balance'); return; }
  try {
    await rtdb.ref('withdrawals/'+CU.uid).push({
      amount:    amt,
      address:   addr,
      status:    'pending',
      createdAt: Date.now()
    });
    toast('✅ Withdrawal request submitted!');
    document.getElementById('wdAmt').value  = '';
    document.getElementById('wdAddr').value = '';
    document.getElementById('wdPreview').style.display='none';
  } catch(e) { toast('Error: '+e.message); }
};

document.addEventListener('input', (e)=>{
  if (e.target && e.target.id==='wdAmt') {
    const amt = parseFloat(e.target.value);
    const prev = document.getElementById('wdPreview');
    if (!amt || amt<=0) { prev.style.display='none'; return; }
    const chargePct = parseFloat(SETTINGS.withdrawalFee != null ? SETTINGS.withdrawalFee : 5)/100;
    const charge = amt*chargePct;
    const net = amt-charge;
    set('wdPrevAmt', '$'+amt.toFixed(2));
    set('wdPrevCharge', '-$'+charge.toFixed(2));
    set('wdPrevNet', '$'+net.toFixed(2));
    prev.style.display='block';
  }
});

window.copyText = (elId) => {
  const el = document.getElementById(elId);
  const val = el.textContent;
  navigator.clipboard.writeText(val)
    .then(()=>toast('✅ Copied: '+val))
    .catch(()=>toast('Copy failed'));
};

window.copyRef = () => {
  const v = document.getElementById('refLinkInput').value;
  navigator.clipboard.writeText(v)
    .then(()=>toast('✅ Referral link copied!'))
    .catch(()=>{ document.getElementById('refLinkInput').select(); document.execCommand('copy'); toast('✅ Copied!'); });
};
window.shareWA = () => {
  const l=document.getElementById('refLinkInput').value;
  window.open('https://wa.me/?text=Join+Life+Line+Meta+with+my+link:+'+encodeURIComponent(l),'_blank');
};
window.shareTG = () => {
  const l=document.getElementById('refLinkInput').value;
  window.open('https://t.me/share/url?url='+encodeURIComponent(l)+'&text=Join+Life+Line+Meta','_blank');
};

window.doLogout = async ()=>{ await auth.signOut(); window.location.href='login.html'; };

// ── HELPERS ──────────────────────────────────────────
function set(id,val){ const el=document.getElementById(id); if(el) el.textContent=val; }
function setW(id,val){ const el=document.getElementById(id); if(el) el.style.width=val; }

function toast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.classList.add('show');
  clearTimeout(t._t);
  t._t=setTimeout(()=>t.classList.remove('show'),3200);
}

// ── NAV ──────────────────────────────────────────────
window.showPage = (page, el) => {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const target = document.getElementById('page-'+page);
  if(target) target.classList.add('active');
  document.querySelectorAll('nav a').forEach(a=>a.classList.remove('active'));
  if(el) el.classList.add('active');
  const labels={
    overview:'Overview', profile:'Profile', referral:'Referral', tree:'Binary Tree',
    team:'My Team', income:'Income Report', roi:'ROI Investment', investhist:'Investment History',
    joining:'Joining History', wallet:'Wallet', leadership:'Leadership Income',
    rank:'Rank Progress', cashback:'Cashback Pool', club:'Club Bonus', voucher:'Gift Voucher', activation:'Activation',
    fundrequest:'Fund Request'
  };
  document.getElementById('pgLabel').textContent = labels[page]||page;
  closeSidebar();
  if(page==='tree' && UD) renderBinaryTree();
  if(page==='fundrequest') loadFundRequestPage();
  if(page==='joining' && UD) loadReferrals();
  if(page==='voucher') loadMyVouchers();
  if(page==='leadership') renderLeadershipIncome();

  // Bottom-nav active state sync
  const bnMap = { roi:0, wallet:1, tree:2, income:3 };
  document.querySelectorAll('.bn-item').forEach((b,i)=>b.classList.toggle('active', bnMap[page]===i));
};

window.toggleSidebar = ()=>{
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('overlay').classList.toggle('show');
};
window.closeSidebar = ()=>{
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
};

let isLight=false;
window.toggleTheme = ()=>{
  isLight=!isLight;
  document.body.classList.toggle('light',isLight);
  document.getElementById('themeBtn').textContent=isLight?'🌙 Dark':'☀️ Light';
};

// ── FUND REQUEST PAGE (credits MAIN WALLET on approval) ─
async function loadFundRequestPage() {
  if (!CU) return;

  try {
    const trcSnap = await rtdb.ref('settings/adminWalletTRC').get();
    const bepSnap = await rtdb.ref('settings/adminWalletBEP').get();
    document.getElementById('adminWalletAddrTRC').textContent = trcSnap.exists() ? trcSnap.val() : 'Contact admin for wallet address';
    document.getElementById('adminWalletAddrBEP').textContent = bepSnap.exists() ? bepSnap.val() : 'Contact admin for wallet address';
  } catch(e) {
    document.getElementById('adminWalletAddrTRC').textContent = 'Contact admin for wallet address';
    document.getElementById('adminWalletAddrBEP').textContent = 'Contact admin for wallet address';
  }

  try {
    const snap = await rtdb.ref('fundRequests').get();
    const allReqs = snap.exists() ? snap.val() : {};
    const list = Object.entries(allReqs)
      .filter(([,f]) => f.uid === CU.uid)
      .sort(([,a],[,b]) => b.createdAt - a.createdAt);

    const pending = list.find(([,f]) => f.status === 'pending');
    const banner  = document.getElementById('frPendingBanner');
    if (pending) {
      banner.style.display = 'block';
      document.getElementById('frPendingInfo').textContent =
        `$${pending[1].amount} request pending approval — TxHash: ${(pending[1].txHash||'—').slice(0,20)}…`;
      const badge = document.getElementById('frPendingBadge');
      if (badge) { badge.style.display='inline'; badge.textContent='1'; }
    } else {
      banner.style.display = 'none';
      const badge = document.getElementById('frPendingBadge');
      if (badge) badge.style.display = 'none';
    }

    const tb = document.getElementById('frHistTb');
    tb.innerHTML = list.length ? list.map(([id,f]) => {
      const sc = f.status==='approved'?'pg':f.status==='rejected'?'pr':'py';
      return `<tr>
        <td style="font-weight:700;color:var(--accent)">$${Number(f.amount||0).toFixed(2)}</td>
        <td style="font-size:.73rem">${f.network||'TRC-20'}</td>
        <td style="color:var(--green);font-weight:700">${f.status==='approved'?'$'+Number(f.netCredited!=null?f.netCredited:f.amount||0).toFixed(2):'—'}</td>
        <td><span class="pill ${sc}">${f.status||'pending'}</span></td>
        <td style="font-size:.72rem;color:var(--muted)">${f.createdAt?new Date(f.createdAt).toLocaleDateString():'—'}</td>
      </tr>`;
    }).join('')
    : '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:18px">No requests yet</td></tr>';
  } catch(e) {
    document.getElementById('frHistTb').innerHTML =
      '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:18px">Error: ' + e.message + '</td></tr>';
  }
}

window.copyAdminWallet = (net) => {
  const elId = net==='bep' ? 'adminWalletAddrBEP' : 'adminWalletAddrTRC';
  const addr = document.getElementById(elId).textContent;
  if (!addr || addr === 'Loading…' || addr.includes('Contact')) return toast('Wallet address not set by admin yet');
  navigator.clipboard.writeText(addr)
    .then(()=>toast('✅ Wallet address copied!'))
    .catch(()=>toast('Copy failed'));
};

// ── WALLET CONNECT (BEP-20 via MetaMask/Trust, TRC-20 via TronLink) ──
let WALLET_MODE = null;
let WALLET_ADDR = null;
const USDT_BEP20_CONTRACT = "0x55d398326f99059fF775485246999027B3197955";

window.connectMetaMask = async () => {
  if (typeof window.ethereum === 'undefined') {
    toast('❌ MetaMask/Trust Wallet পাওয়া যায়নি। মোবাইলে Trust Wallet browser থেকে এই পেজ খোলো।');
    return;
  }
  try {
    const accounts = await window.ethereum.request({ method:'eth_requestAccounts' });
    WALLET_ADDR = accounts[0];
    WALLET_MODE = 'evm';
    try {
      await window.ethereum.request({ method:'wallet_switchEthereumChain', params:[{ chainId:'0x38' }] });
    } catch(switchErr) {
      if (switchErr.code === 4902) {
        await window.ethereum.request({
          method:'wallet_addEthereumChain',
          params:[{ chainId:'0x38', chainName:'BNB Smart Chain', nativeCurrency:{name:'BNB',symbol:'BNB',decimals:18}, rpcUrls:['https://bsc-dataseed.binance.org/'], blockExplorerUrls:['https://bscscan.com'] }]
        });
      }
    }
    document.getElementById('walConnStatus').innerHTML = '✅ Connected: <span style="color:var(--green);font-family:monospace">'+WALLET_ADDR.slice(0,8)+'…'+WALLET_ADDR.slice(-6)+'</span> (BEP-20)';
    document.getElementById('walSendBox').style.display = 'block';
    document.getElementById('frNetwork').value = 'BEP-20 (BSC)';
    toast('✅ Wallet connected!');
  } catch(e) { toast('Connect failed: '+e.message); }
};

window.connectTronLink = async () => {
  if (typeof window.tronWeb === 'undefined' || !window.tronWeb.ready) {
    toast('❌ TronLink পাওয়া যায়নি। TronLink extension/app দিয়ে এই পেজ খোলো।');
    return;
  }
  try {
    WALLET_ADDR = window.tronWeb.defaultAddress.base58;
    WALLET_MODE = 'tron';
    document.getElementById('walConnStatus').innerHTML = '✅ Connected: <span style="color:var(--green);font-family:monospace">'+WALLET_ADDR.slice(0,8)+'…'+WALLET_ADDR.slice(-6)+'</span> (TRC-20)';
    document.getElementById('walSendBox').style.display = 'block';
    document.getElementById('frNetwork').value = 'TRC-20 (TRON)';
    toast('✅ TronLink connected!');
  } catch(e) { toast('Connect failed: '+e.message); }
};

window.sendUSDTFromWallet = async () => {
  const amt = parseFloat(document.getElementById('walSendAmt').value);
  if (!amt || amt < 30) { toast('Minimum $30'); return; }
  if (!WALLET_MODE) { toast('আগে wallet connect করো'); return; }
  try {
    if (WALLET_MODE === 'evm') {
      const bepAddr = document.getElementById('adminWalletAddrBEP').textContent;
      if (!bepAddr || bepAddr.includes('Contact')) { toast('Admin BEP-20 address সেট করা নেই'); return; }
      const value = BigInt(Math.round(amt * 1e18)).toString(16);
      const data = '0xa9059cbb' + bepAddr.replace('0x','').padStart(64,'0') + value.padStart(64,'0');
      const txHash = await window.ethereum.request({ method:'eth_sendTransaction', params:[{ from:WALLET_ADDR, to:USDT_BEP20_CONTRACT, data }] });
      document.getElementById('frTxHash').value = txHash;
      document.getElementById('frAmount').value = amt;
      toast('✅ Transaction পাঠানো হয়েছে! এখন নিচের ফর্মে "Submit Fund Request" চাপো।');
    } else if (WALLET_MODE === 'tron') {
      const trcAddr = document.getElementById('adminWalletAddrTRC').textContent;
      if (!trcAddr || trcAddr.includes('Contact')) { toast('Admin TRC-20 address সেট করা নেই'); return; }
      const USDT_TRC20_CONTRACT = 'TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t';
      const contract = await window.tronWeb.contract().at(USDT_TRC20_CONTRACT);
      const amountSun = Math.round(amt * 1e6);
      const tx = await contract.transfer(trcAddr, amountSun).send();
      document.getElementById('frTxHash').value = typeof tx === 'string' ? tx : (tx.txid||'');
      document.getElementById('frAmount').value = amt;
      toast('✅ Transaction পাঠানো হয়েছে! এখন নিচের ফর্মে "Submit Fund Request" চাপো।');
    }
  } catch(e) { toast('❌ Transaction failed: '+(e.message||e)); }
};

window.submitFundRequest = async () => {
  if (!CU) return;
  const amount  = parseFloat(document.getElementById('frAmount').value);
  const txHash  = document.getElementById('frTxHash').value.trim();
  const network = document.getElementById('frNetwork').value;
  const note    = document.getElementById('frNote').value.trim();

  if (!amount || amount < 30) return toast('Minimum deposit is $30');
  if (!txHash) return toast('Please enter your Transaction Hash (TxID)');

  try {
    const snap = await rtdb.ref('fundRequests').get();
    if (snap.exists()) {
      const myReqs = Object.values(snap.val()).filter(f => f.uid === CU.uid);
      const hasPending = myReqs.some(f => f.status === 'pending');
      if (hasPending) return toast('You already have a pending request. Wait for admin approval.');
    }

    await rtdb.ref('fundRequests').push({
      uid:       CU.uid,
      email:     CU.email || '',
      name:      UD?.fullName || UD?.username || '',
      amount,
      txHash,
      network,
      note,
      creditTarget: 'walletBalance',
      status:    'pending',
      createdAt: Date.now()
    });

    toast('✅ Fund request submitted! অনুমোদনের পর Main Wallet এ credit হবে।');
    document.getElementById('frAmount').value  = '';
    document.getElementById('frTxHash').value  = '';
    document.getElementById('frNote').value    = '';
    loadFundRequestPage();
  } catch(e) { toast('Error: ' + e.message); }
};
</script>
</body>
</html>