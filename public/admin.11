  apiKey: "AIzaSyA3G2bMOJ_HSDYXJPuM70tVjfbkHlMftr4",
  authDomain: "livelinemeta.firebaseapp.com",
  databaseURL: "https://livelinemeta-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId: "livelinemeta",
  storageBucket: "livelinemeta.firebasestorage.app",
  messagingSenderId: "206900805598",
  appId: "1:206900805598:web:10e6b39100af201b4e674f"
};

firebase.initializeApp(firebaseConfig);
const auth   = firebase.auth();
const fsdb   = firebase.firestore();   // Firestore (users stored here from register)
const rtdb   = firebase.database();   // Realtime DB (income, transactions)

let CU   = null; // currentUser
let UD   = null; // userData (Firestore doc)
let ALLU = {};   // all users cache

// ── AUTH GUARD ───────────────────────────────────────
auth.onAuthStateChanged(async user => {
  if (!user) { window.location.href = 'login.html'; return; }
  CU = user;
  await loadAll();
});

async function loadAll() {
  try {
    // 1. Load current user from Firestore (where register.html saved it)
    const docSnap = await fsdb.collection('users').doc(CU.uid).get();
    if (!docSnap.exists) { toast('User data not found. Please re-login.'); return; }
    UD = { id: CU.uid, ...docSnap.data() };

    // 2. Load all users for team/tree
    const allSnap = await fsdb.collection('users').get();
    allSnap.forEach(d => { ALLU[d.id] = { id: d.id, ...d.data() }; });

    renderAll();
    loadRTDBData();

    // 3. Live listener for RTDB income
    rtdb.ref('users/' + CU.uid + '/income').on('value', snap => {
      if (snap.exists() && UD) {
        UD.income = snap.val();
        renderIncomeCards();
      }
    });

    // 4. Live listener for RTDB transactions
    rtdb.ref('transactions/' + CU.uid).on('value', snap => {
      if (snap.exists()) renderTransactions(snap.val());
      else renderTransactions({});
    });

  } catch(e) { toast('Error: ' + e.message); }
}

async function loadRTDBData() {
  // Load income from RTDB
  const incSnap = await rtdb.ref('users/' + CU.uid + '/income').get();
  if (incSnap.exists()) { UD.income = incSnap.val(); renderIncomeCards(); }

  // Load wallet balance from RTDB
  const walSnap = await rtdb.ref('users/' + CU.uid + '/walletBalance').get();
  if (walSnap.exists()) { UD.walletBalance = walSnap.val(); renderWallet(); }

  // Load ROI settings
  const rateSnap = await rtdb.ref('settings/roiRate').get();
  if (rateSnap.exists()) document.getElementById('roiRateD').textContent = rateSnap.val() + '%';

  // Load investments
  const invSnap = await rtdb.ref('investments/' + CU.uid).get();
  if (invSnap.exists()) renderROIPlans(invSnap.val());

  // Load withdrawal requests
  const wdSnap = await rtdb.ref('withdrawals/' + CU.uid).get();
  if (wdSnap.exists()) renderWalletHistory(wdSnap.val());
}

// ── RENDER ALL ────────────────────────────────────────
function renderAll() {
  const u    = UD;
  const name = u.fullName || u.username || (CU.email ? CU.email.split('@')[0] : 'User');
  const init = name[0].toUpperCase();

  // Sidebar
  document.getElementById('avInit').textContent   = init;
  document.getElementById('sbName').textContent   = name;
  document.getElementById('sbStatus').textContent = u.isActive ? '✅ Active' : '⚠️ Inactive';

  // Greeting
  const h = new Date().getHours();
  const g = h<12?'Good Morning':h<17?'Good Afternoon':'Good Evening';
  document.getElementById('greetMsg').textContent = g + ', ' + name + '!';

  // Activation banner
  document.getElementById('actBanner').style.display = u.isActive ? 'none' : 'flex';

  // Profile page
  document.getElementById('pfAv').textContent         = init;
  document.getElementById('pfNameD').textContent       = name;
  document.getElementById('pfEmailD').textContent      = u.email || CU.email || '';
  document.getElementById('pfName').value              = u.fullName || '';
  document.getElementById('pfUsername').value          = u.username || '';
  document.getElementById('pfPhone').value             = u.mobile || '';
  document.getElementById('pfCountry').value           = u.country || '';
  document.getElementById('pfWallet').value            = u.paymentWallet || '';
  document.getElementById('pfBadge').innerHTML         = u.isActive
    ? '<span class="pill pg">✅ Active</span>'
    : '<span class="pill py">⚠️ Inactive</span>';

  // Account info
  document.getElementById('infoUID').textContent      = CU.uid;
  document.getElementById('infoUsername').textContent = u.username || '—';
  document.getElementById('infoSponsor').textContent  = u.sponsorId || 'None (Root)';
  document.getElementById('infoJoined').textContent   = u.createdAt
    ? (u.createdAt.toDate ? u.createdAt.toDate().toLocaleDateString('en-BD') : new Date(u.createdAt).toLocaleDateString())
    : '—';
  document.getElementById('infoStatus').textContent   = u.isActive ? '✅ Active' : '⚠️ Inactive';
  document.getElementById('infoMethod').textContent   = u.signupMethod || 'email';

  // Referral link — uses username or uid as ref code (matching register.html myRefCode)
  const refCode = u.myRefCode || u.username || CU.uid;
  const refLink = window.location.origin + '/register.html?ref=' + encodeURIComponent(refCode);
  document.getElementById('refLinkInput').value = refLink;

  // Activation page
  if (u.isActive) {
    document.getElementById('activeCard').style.display   = 'block';
    document.getElementById('actFormCard').style.display  = 'none';
  } else {
    document.getElementById('activeCard').style.display   = 'none';
    document.getElementById('actFormCard').style.display  = 'block';
  }

  renderIncomeCards();
  loadReferrals();
  renderBinaryTree();
}

// ── INCOME CARDS ──────────────────────────────────────
function renderIncomeCards() {
  const inc     = (UD && UD.income) || {};
  const sponsor = parseFloat(inc.sponsor    || 0);
  const match   = parseFloat(inc.matching   || 0);
  const cb      = parseFloat(inc.cashback   || 0);
  const club    = parseFloat(inc.club       || 0);
  const roi     = parseFloat(inc.roi        || 0);
  const gen     = parseFloat(inc.generation || 0);
  const total   = sponsor + match + cb + club + roi + gen;
  const wallet  = parseFloat((UD && UD.walletBalance) || 0);
  const wd      = parseFloat((UD && UD.totalWithdrawn) || 0);
  const invested= parseFloat((UD && UD.totalInvested)  || 0);
  const teamSales = parseFloat((UD && UD.teamSales) || 0);

  // Overview
  set('ovTotal',   '$'+total.toFixed(2));
  set('ovWallet',  '$'+wallet.toFixed(2));
  set('ovMatch',   '$'+match.toFixed(2));
  setW('ovMatchP', Math.min((match/1000)*100,100)+'%');

  // Income breakdown (overview)
  set('ibSponsor',  '$'+sponsor.toFixed(2));
  set('ibMatch',    '$'+match.toFixed(2));
  set('ibCashback', '$'+cb.toFixed(2));
  set('ibClub',     '$'+club.toFixed(2));
  set('ibRoi',      '$'+roi.toFixed(2));
  set('ibGen',      '$'+gen.toFixed(2));

  // Income page
  set('incAll',           '$'+total.toFixed(2));
  set('incWd',            '$'+wd.toFixed(2));
  set('incTotalInv',      '$'+invested.toFixed(2));
  set('incTypeSponsor',   '$'+sponsor.toFixed(2));
  set('incTypeMatch',     '$'+match.toFixed(2));
  set('incTypeCB',        '$'+cb.toFixed(2));
  set('incTypeClub',      '$'+club.toFixed(2));
  set('incTypeROI',       '$'+roi.toFixed(2));
  set('incTypeGen',       '$'+gen.toFixed(2));
  set('incCapUsed',       '$'+total.toFixed(0)+' / $1000');
  set('incCapLeft',       '$'+Math.max(0,1000-total).toFixed(2));

  // Wallet page
  renderWallet(wallet, total, wd);

  // ROI summary
  set('roiTotalInv',    '$'+invested.toFixed(2));
  set('roiTotalEarned', '$'+roi.toFixed(2));

  // Cashback
  set('cbEarned', '$'+cb.toFixed(2));
  const cbPct = Math.min((cb/60)*100,100);
  setW('cbProg', cbPct+'%');
  const cbEl = document.getElementById('cbStatus');
  if(cb >= 60) cbEl.innerHTML = '<span style="color:var(--red)">Limit Reached ($60)</span>';
  else if(UD && UD.isActive) cbEl.innerHTML = '<span style="color:var(--green)">✅ Eligible</span>';
  else cbEl.innerHTML = '<span style="color:var(--muted)">Not Activated</span>';

  // Club
  const dirCount = Object.values(ALLU).filter(u=>u.sponsorId===CU.uid).length;
  set('clubDir',   dirCount+' / 10');
  set('clubMatch', '$'+match.toFixed(0)+' / $50');
  set('clubEarned','$'+club.toFixed(2));
  const clubOk = dirCount>=10 || match>=50;
  document.getElementById('clubEligBadge').innerHTML = clubOk
    ? '<span class="pill pg">✅ Eligible</span>'
    : '<span class="pill py">Not yet</span>';

  // Rank
  renderRank(match, teamSales);
}

function renderWallet(wallet, total, wd) {
  const w = wallet !== undefined ? wallet : parseFloat((UD && UD.walletBalance)||0);
  const t = total  !== undefined ? total  : 0;
  const d = wd     !== undefined ? wd     : parseFloat((UD && UD.totalWithdrawn)||0);
  set('walBalD',      '$'+w.toFixed(2));
  set('wTotalEarned', '$'+t.toFixed(2));
  set('wTotalWd',     '$'+d.toFixed(2));
  set('wCapLeft',     '$'+Math.max(0,1000-t).toFixed(2));
}

// ── REFERRALS ────────────────────────────────────────
function loadReferrals() {
  const myRefs    = Object.values(ALLU).filter(u => u.sponsorId === CU.uid);
  const activeRef = myRefs.filter(u => u.isActive);

  set('ovDirRef',    myRefs.length);
  set('ovDirRefSub', activeRef.length+' active');
  set('refCountLbl', myRefs.length+' total');
  set('tmDirRef',    myRefs.length);
  set('tmTotal',     myRefs.length);
  set('tmActive',    activeRef.length);
  set('tmVol',       '$'+(activeRef.length*30));

  // Referral table
  const rb = document.getElementById('refTbody');
  rb.innerHTML = myRefs.length === 0
    ? '<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:16px">No referrals yet. Share your link!</td></tr>'
    : myRefs.map(u => `<tr>
        <td style="font-weight:700">${u.fullName||'User'}</td>
        <td style="color:var(--muted)">@${u.username||'—'}</td>
        <td style="color:var(--muted)">${u.email||'—'}</td>
        <td>${u.createdAt ? (u.createdAt.toDate?u.createdAt.toDate().toLocaleDateString():new Date(u.createdAt).toLocaleDateString()) : '—'}</td>
        <td><span class="pill ${u.isActive?'pg':'py'}">${u.isActive?'Active':'Inactive'}</span></td>
        <td style="color:var(--green);font-weight:700">${u.isActive?'$4.00':'$0.00'}</td>
      </tr>`).join('');
}

// ── BINARY TREE ──────────────────────────────────────
function renderBinaryTree() {
  const container = document.getElementById('treeContainer');
  const downlineTb = document.getElementById('downlineTbody');
  if (!UD) return;

  // Count left and right leg
  const leftChild  = UD.leftChild;
  const rightChild = UD.rightChild;
  let leftCount = 0, rightCount = 0;

  // BFS to count and collect all downline
  const allDownline = [];
  function bfsCount(uid, side, level) {
    if (!uid || !ALLU[uid]) return;
    const u = ALLU[uid];
    if (side === 'left') leftCount++;
    else if (side === 'right') rightCount++;
    allDownline.push({ u, side, level });
    if (u.leftChild)  bfsCount(u.leftChild,  side||'left',  level+1);
    if (u.rightChild) bfsCount(u.rightChild, side||'right', level+1);
  }
  if (leftChild)  bfsCount(leftChild,  'left',  1);
  if (rightChild) bfsCount(rightChild, 'right', 1);

  set('treeLeftCount',  leftCount);
  set('treeRightCount', rightCount);
  set('treeWeakerLeg',  leftCount <= rightCount ? 'Left' : 'Right');

  // Build visual tree (you + level 1 + level 2)
 function makeNode(uid, label, isYou) {
    const u = uid && ALLU[uid];
    if (!uid) {
      return `<div class="tree-node">
        <div class="tree-box empty-node">
          <div class="tree-name" style="color:var(--muted)">Empty</div>
          <div class="tree-status" style="color:var(--muted)">— slot —</div>
        </div>
        ${label ? `<div style="font-size:.64rem;color:var(--muted);margin-top:4px">${label}</div>` : ''}
      </div>`;
    }
    const name   = u ? (u.fullName||u.username||'User') : '?';
    const active = u ? u.isActive : false;
    const cls    = isYou ? 'you-node' : (active ? 'active-node' : '');
    return `<div class="tree-node">
      <div class="tree-box ${cls}" title="${name}">
        <div class="tree-name">${isYou ? '👤 '+name : name}</div>
        <div class="tree-status"><span class="pill ${active?'pg':'py'}" style="font-size:.6rem">${active?'Active':'Inactive'}</span></div>
      </div>
      ${label ? `<div style="font-size:.64rem;color:var(--muted);margin-top:4px">${label}</div>` : ''}
    </div>`;
  }

  // Level 2 children
  function lvl2(uid) {
    const u = uid && ALLU[uid];
    const lc = u ? u.leftChild  : null;
    const rc = u ? u.rightChild : null;
    return `<div style="display:flex;gap:16px;position:relative">
      <div style="position:absolute;top:0;left:25%;right:25%;height:1px;background:var(--border)"></div>
      ${makeNode(lc,'L')}${makeNode(rc,'R')}
    </div>`;
  }

  container.innerHTML = `
    <div style="display:flex;flex-direction:column;align-items:center;gap:0">
      <!-- ROOT (YOU) -->
      ${makeNode(CU.uid,'You',true)}
      <!-- Vertical connector -->
      <div style="width:1px;height:20px;background:var(--border)"></div>
      <!-- Horizontal line -->
      <div style="position:relative;width:200px;height:1px;background:${(leftChild||rightChild)?'var(--border)':'transparent'}"></div>
      <!-- Level 1 -->
      <div style="display:flex;gap:40px;position:relative">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0">
          <div style="width:1px;height:0px"></div>
          ${makeNode(leftChild,'LEFT')}
          <div style="width:1px;height:16px;background:${leftChild?'var(--border)':'transparent'}"></div>
          ${lvl2(leftChild)}
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:0">
          <div style="width:1px;height:0px"></div>
          ${makeNode(rightChild,'RIGHT')}
          <div style="width:1px;height:16px;background:${rightChild?'var(--border)':'transparent'}"></div>
          ${lvl2(rightChild)}
        </div>
      </div>
    </div>`;

  // Downline table
  downlineTb.innerHTML = allDownline.length === 0
    ? '<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:16px">No downline yet</td></tr>'
    : allDownline.map(({u,side,level}) => `<tr>
        <td style="font-weight:700">${u.fullName||'User'}</td>
        <td style="color:var(--muted)">@${u.username||'—'}</td>
        <td><span class="pill pb">Level ${level}</span></td>
        <td><span class="pill ${side==='left'?'pb':'pp'}">${side.toUpperCase()}</span></td>
        <td><span class="pill ${u.isActive?'pg':'py'}">${u.isActive?'Active':'Inactive'}</span></td>
        <td>${u.createdAt?(u.createdAt.toDate?u.createdAt.toDate().toLocaleDateString():new Date(u.createdAt).toLocaleDateString()):'—'}</td>
      </tr>`).join('');
}

// ── RANK ─────────────────────────────────────────────
function renderRank(matching, teamSales) {
  const ranks = [
    {name:'No Rank',    stars:'☆',         mReq:0,      sReq:0},
    {name:'One Star',   stars:'⭐',         mReq:50,     sReq:100},
    {name:'Two Star',   stars:'⭐⭐',       mReq:300,    sReq:300},
    {name:'Three Star', stars:'⭐⭐⭐',     mReq:1000,   sReq:1000},
    {name:'Four Star',  stars:'⭐⭐⭐⭐',   mReq:3000,   sReq:10000},
    {name:'Five Star',  stars:'⭐⭐⭐⭐⭐', mReq:10000,  sReq:100000},
    {name:'Six Star',   stars:'6⭐',        mReq:30000,  sReq:300000},
    {name:'Seven Star', stars:'7⭐',        mReq:100000, sReq:10000000}
  ];
  let idx = 0;
  for(let i=1;i<ranks.length;i++) {
    if(matching>=ranks[i].mReq && teamSales>=ranks[i].sReq) idx=i;
  }
  const cur  = ranks[idx];
  const next = ranks[idx+1]||null;
  set('rankStarsD', cur.stars);
  set('rankNameD',  cur.name);
  set('infoRank',   cur.name);
  if(next){
    set('rankNextHint', 'Next: '+next.name+' — need '+next.mReq+' matching + $'+next.sReq+' team sales');
    setW('rankMatchF', Math.min((matching/next.mReq)*100,100)+'%');
    setW('rankSalesF', Math.min((teamSales/next.sReq)*100,100)+'%');
    set('rankMatchV', matching+'/'+next.mReq);
    set('rankSalesV', '$'+teamSales+'/$'+next.sReq);
  } else {
    set('rankNextHint','🏆 Highest rank achieved!');
  }
}

// ── TRANSACTIONS ─────────────────────────────────────
function renderTransactions(txObj) {
  const txns = Object.entries(txObj).sort(([,a],[,b])=>b.timestamp-a.timestamp);
  set('txCountLbl', txns.length+' records');

  const today = new Date(); today.setHours(0,0,0,0);
  const monthStart = new Date(today.getFullYear(),today.getMonth(),1);
  let todayTotal=0, monthTotal=0;

  const rows = txns.map(([id,t]) => {
    const d = new Date(t.timestamp);
    if(d >= today) todayTotal += t.amount||0;
    if(d >= monthStart) monthTotal += t.amount||0;
    const dt = d.toLocaleDateString()+' '+d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
    return `<tr>
      <td style="color:var(--muted);font-size:.72rem">${dt}</td>
      <td>${t.type||'—'}</td>
      <td style="color:var(--muted);font-size:.75rem">${t.note||'—'}</td>
      <td style="font-weight:700;color:${t.amount>0?'var(--green)':'var(--red)'}">
        ${t.amount>0?'+':''}$${Math.abs(t.amount||0).toFixed(2)}
      </td>
      <td style="color:var(--muted)">$${(t.balance||0).toFixed(2)}</td>
      <td><span class="pill ${t.status==='completed'?'pg':t.status==='pending'?'py':'pb'}">${t.status||'done'}</span></td>
    </tr>`;
  }).join('');

  document.getElementById('incTxTable').innerHTML = rows ||
    '<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:18px">No transactions yet</td></tr>';
  set('incToday', '$'+todayTotal.toFixed(2));
  set('incMonth', '$'+monthTotal.toFixed(2));

  // Overview recent 5
  document.getElementById('ovRecentTx').innerHTML = txns.slice(0,5).map(([id,t])=>`
    <tr>
      <td>${new Date(t.timestamp).toLocaleDateString()}</td>
      <td>${t.type||'—'}</td>
      <td style="color:${t.amount>0?'var(--green)':'var(--red)'};font-weight:700">
        ${t.amount>0?'+':''}$${Math.abs(t.amount||0).toFixed(2)}
      </td>
    </tr>`).join('') ||
    '<tr><td colspan="3" style="text-align:center;color:var(--muted)">None</td></tr>';

  // Wallet history
  renderWalletHistory(txObj);
}

function renderWalletHistory(txObj) {
  const txns = Object.entries(txObj).sort(([,a],[,b])=>b.timestamp-a.timestamp);
  document.getElementById('walHistTb').innerHTML = txns.length
    ? txns.slice(0,30).map(([id,t])=>`<tr>
        <td>${new Date(t.timestamp).toLocaleDateString()}</td>
        <td>${t.type||'—'}</td>
        <td style="font-weight:700;color:${t.amount>0?'var(--green)':'var(--red)'}">
          ${t.amount>0?'+':''}$${Math.abs(t.amount||0).toFixed(2)}
        </td>
        <td><span class="pill ${t.status==='completed'?'pg':t.status==='pending'?'py':'pb'}">${t.status||'done'}</span></td>
      </tr>`).join('')
    : '<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:14px">No transactions</td></tr>';
}

function renderROIPlans(plans) {
  const tb = document.getElementById('roiPlansTb');
  const entries = Object.entries(plans).sort(([,a],[,b])=>b.createdAt-a.createdAt);
  let activeCnt=0, nextD=null;
  tb.innerHTML = entries.length
    ? entries.map(([id,p],i)=>{
        if(p.status==='active') activeCnt++;
        const lockEnd  = new Date(p.createdAt + 6*30*24*60*60*1000);
        const locked   = Date.now() < lockEnd.getTime();
        if(!nextD && p.status==='active') nextD = new Date(p.createdAt+30*24*60*60*1000);
        return `<tr>
          <td style="color:var(--muted)">${i+1}</td>
          <td style="color:var(--accent);font-weight:700">$${p.amount}</td>
          <td>${new Date(p.createdAt).toLocaleDateString()}</td>
          <td style="color:var(--green)">${p.roiRate||12}%</td>
          <td style="color:var(--gold)">$${(p.earnedROI||0).toFixed(2)}</td>
          <td>${lockEnd.toLocaleDateString()}</td>
          <td><span class="pill ${p.status==='active'?'pg':p.status==='pending'?'py':'pb'}">${p.status||'pending'}</span></td>
          <td>${!locked&&p.status==='active'
            ?'<button class="btn btn-r btn-sm" onclick="withdrawCapital(\''+id+'\')">Withdraw</button>'
            :'<span style="color:var(--muted);font-size:.7rem">'+(p.status==='pending'?'Awaiting':'Locked')+'</span>'}</td>
        </tr>`;
      }).join('')
    : '<tr><td colspan="8" style="text-align:center;color:var(--muted);padding:18px">No investments yet</td></tr>';
  set('roiActivePlans', activeCnt);
  set('roiNextDate', nextD ? nextD.toLocaleDateString() : '—');
}

// ── ACTIONS ──────────────────────────────────────────
window.saveProfile = async () => {
  try {
    const updates = {
      fullName:      document.getElementById('pfName').value.trim(),
      mobile:        document.getElementById('pfPhone').value.trim(),
      paymentWallet: document.getElementById('pfWallet').value.trim(),
      updatedAt:     new Date()
    };
    await fsdb.collection('users').doc(CU.uid).update(updates);
    Object.assign(UD, updates);
    document.getElementById('sbName').textContent = UD.fullName||'User';
    toast('✅ Profile saved!');
  } catch(e) { toast('Error: '+e.message); }
};

window.submitActivation = async () => {
  if (UD && UD.isActive) { toast('Already active!'); return; }
  const txid   = document.getElementById('actTxid').value.trim();
  const method = document.getElementById('actMethod').value;
  if (!txid) { toast('Please enter transaction hash'); return; }
  try {
    await rtdb.ref('activationRequests').push({
      uid:       CU.uid,
      email:     CU.email,
      name:      UD?.fullName || UD?.username || '',
      username:  UD?.username || '',
      txid, method, amount: 30,
      status:    'pending',
      createdAt: Date.now()
    });
    toast('✅ Request submitted! Admin will approve soon.');
    document.getElementById('actTxid').value = '';
  } catch(e) { toast('Error: '+e.message); }
};

window.submitInvestment = async () => {
  if (!UD?.isActive) { toast('Activate your account first!'); return; }
  const amt  = parseFloat(document.getElementById('invAmt').value);
  const txid = document.getElementById('invTxid').value.trim();
  if (!amt || amt < 100) { toast('Minimum investment is $100'); return; }
  if (!txid) { toast('Please enter transaction hash'); return; }
  try {
    await rtdb.ref('investments/'+CU.uid).push({
      amount:    amt,
      method:    document.getElementById('invMethod').value,
      txid,
      roiRate:   12,
      status:    'pending',
      earnedROI: 0,
      createdAt: Date.now()
    });
    const newInv = (UD.totalInvested||0) + amt;
    await rtdb.ref('users/'+CU.uid+'/totalInvested').set(newInv);
    UD.totalInvested = newInv;
    toast('✅ Investment submitted! Admin will activate shortly.');
    document.getElementById('invAmt').value  = '';
    document.getElementById('invTxid').value = '';
    const invSnap = await rtdb.ref('investments/'+CU.uid).get();
    if(invSnap.exists()) renderROIPlans(invSnap.val());
  } catch(e) { toast('Error: '+e.message); }
};

window.withdrawCapital = async pid => {
  if (!confirm('Withdraw capital? 10% fee will be deducted.')) return;
  await rtdb.ref('investments/'+CU.uid+'/'+pid).update({
    status:'withdrawal_requested', wdRequestAt: Date.now()
  });
  toast('Capital withdrawal requested!');
  const invSnap = await rtdb.ref('investments/'+CU.uid).get();
  if(invSnap.exists()) renderROIPlans(invSnap.val());
};

window.submitWithdraw = async () => {
  const amt  = parseFloat(document.getElementById('wdAmt').value);
  const addr = document.getElementById('wdAddr').value.trim();
  if (!amt || amt<10)  { toast('Min withdrawal $10'); return; }
  if (!addr)           { toast('Enter wallet address'); return; }
  const bal = parseFloat(UD?.walletBalance||0);
  if (amt > bal)       { toast('Insufficient balance'); return; }
  try {
    await rtdb.ref('withdrawals/'+CU.uid).push({
      amount:    amt,
      address:   addr,
      status:    'pending',
      createdAt: Date.now()
    });
    toast('✅ Withdrawal request submitted!');
    document.getElementById('wdAmt').value  = '';
    document.getElementById('wdAddr').value = '';
    hideWdForm();
  } catch(e) { toast('Error: '+e.message); }
};

window.copyRef = () => {
  const v = document.getElementById('refLinkInput').value;
  navigator.clipboard.writeText(v)
    .then(()=>toast('✅ Referral link copied!'))
    .catch(()=>{ document.getElementById('refLinkInput').select(); document.execCommand('copy'); toast('✅ Copied!'); });
};
window.shareWA = () => {
  const l=document.getElementById('refLinkInput').value;
  window.open('https://wa.me/?text=Join+Life+Line+Meta+with+my+link:+'+encodeURIComponent(l),'_blank');
};
window.shareTG = () => {
  const l=document.getElementById('refLinkInput').value;
  window.open('https://t.me/share/url?url='+encodeURIComponent(l)+'&text=Join+Life+Line+Meta','_blank');
};
window.showWdForm  = ()=>{ document.getElementById('wdFormCard').style.display='block'; };
window.hideWdForm  = ()=>{ document.getElementById('wdFormCard').style.display='none'; };

window.doLogout = async ()=>{ await auth.signOut(); window.location.href='login.html'; };

// ── HELPERS ──────────────────────────────────────────
function set(id,val){ const el=document.getElementById(id); if(el) el.textContent=val; }
function setW(id,val){ const el=document.getElementById(id); if(el) el.style.width=val; }

function toast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.classList.add('show');
  clearTimeout(t._t);
  t._t=setTimeout(()=>t.classList.remove('show'),3200);
}

// ── NAV ──────────────────────────────────────────────
window.showPage = (page, el) => {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const target = document.getElementById('page-'+page);
  if(target) target.classList.add('active');
  document.querySelectorAll('nav a').forEach(a=>a.classList.remove('active'));
  if(el) el.classList.add('active');
  const labels={
    overview:'Overview', profile:'Profile', referral:'Referral', tree:'Binary Tree',
    team:'My Team', income:'Income Report', roi:'ROI Investment', wallet:'Wallet',
    rank:'Rank Progress', cashback:'Cashback Pool', club:'Club Bonus', activation:'Activation',
    fundrequest:'Fund Request'
  };
  document.getElementById('pgLabel').textContent = labels[page]||page;
  closeSidebar();
  if(page==='tree' && UD) renderBinaryTree();
  if(page==='fundrequest') loadFundRequestPage();
};

window.toggleSidebar = ()=>{
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('overlay').classList.toggle('show');
};
window.closeSidebar = ()=>{
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
};

let isLight=false;
window.toggleTheme = ()=>{
  isLight=!isLight;
  document.body.classList.toggle('light',isLight);
  document.getElementById('themeBtn').textContent=isLight?'🌙 Dark':'☀️ Light';
};

// ── FUND REQUEST PAGE ─────────────────────────────────
async function loadFundRequestPage() {
  if (!CU) return;

  // Load admin wallet address from settings
  try {
    const setSnap = await rtdb.ref('settings/adminWallet').get();
    const addr = setSnap.exists() ? setSnap.val() : 'Contact admin for wallet address';
    document.getElementById('adminWalletAddr').textContent = addr;
  } catch(e) {
    document.getElementById('adminWalletAddr').textContent = 'Contact admin for wallet address';
  }

  // Load user's fund request history — filter client-side (no index needed)
  try {
    const snap = await rtdb.ref('fundRequests').get();
    const allReqs = snap.exists() ? snap.val() : {};
    const list = Object.entries(allReqs)
      .filter(([,f]) => f.uid === CU.uid)
      .sort(([,a],[,b]) => b.createdAt - a.createdAt);

    // Check if any pending
    const pending = list.find(([,f]) => f.status === 'pending');
    const banner  = document.getElementById('frPendingBanner');
    if (pending) {
      banner.style.display = 'block';
      document.getElementById('frPendingInfo').textContent =
        `$${pending[1].amount} request pending approval — TxHash: ${(pending[1].txHash||'—').slice(0,20)}…`;
      const badge = document.getElementById('frPendingBadge');
      if (badge) { badge.style.display='inline'; badge.textContent='1'; }
    } else {
      banner.style.display = 'none';
      const badge = document.getElementById('frPendingBadge');
      if (badge) badge.style.display = 'none';
    }

    // Render history
    const tb = document.getElementById('frHistTb');
    tb.innerHTML = list.length ? list.map(([id,f]) => {
      const sc = f.status==='approved'?'pg':f.status==='rejected'?'pr':'py';
      return `<tr>
        <td style="font-weight:700;color:var(--accent)">$${Number(f.amount||0).toFixed(2)}</td>
        <td style="font-size:.73rem">${f.network||'TRC-20'}</td>
        <td style="color:var(--green);font-weight:700">${f.status==='approved'?'$'+Number(f.netCredited||0).toFixed(2):'—'}</td>
        <td><span class="pill ${sc}">${f.status||'pending'}</span></td>
        <td style="font-size:.72rem;color:var(--muted)">${f.createdAt?new Date(f.createdAt).toLocaleDateString():'—'}</td>
      </tr>`;
    }).join('')
    : '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:18px">No requests yet</td></tr>';
  } catch(e) {
    document.getElementById('frHistTb').innerHTML =
      '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:18px">Error: ' + e.message + '</td></tr>';
  }
}

window.calcFundPreview = () => {
  const amt = parseFloat(document.getElementById('frAmount').value);
  const prev = document.getElementById('frPreview');
  if (!amt || amt < 1) { prev.style.display='none'; return; }
  const comm = parseFloat((amt * 0.05).toFixed(2));
  const net  = parseFloat((amt - comm).toFixed(2));
  document.getElementById('frPrevSend').textContent = '$' + amt.toFixed(2);
  document.getElementById('frPrevComm').textContent = '-$' + comm.toFixed(2);
  document.getElementById('frPrevNet').textContent  = '$' + net.toFixed(2);
  prev.style.display = 'block';
};

window.copyAdminWallet = () => {
  const addr = document.getElementById('adminWalletAddr').textContent;
  if (!addr || addr === 'Loading…' || addr.includes('Contact')) return toast('Wallet address not set by admin yet');
  navigator.clipboard.writeText(addr)
    .then(()=>toast('✅ Wallet address copied!'))
    .catch(()=>toast('Copy failed'));
};

window.submitFundRequest = async () => {
  if (!CU) return;
  const amount  = parseFloat(document.getElementById('frAmount').value);
  const txHash  = document.getElementById('frTxHash').value.trim();
  const network = document.getElementById('frNetwork').value;
  const note    = document.getElementById('frNote').value.trim();

  if (!amount || amount < 30) return toast('Minimum deposit is $30');
  if (!txHash) return toast('Please enter your Transaction Hash (TxID)');

  try {
    // Check no duplicate pending — read all then filter by uid client-side
    const snap = await rtdb.ref('fundRequests').get();
    if (snap.exists()) {
      const myReqs = Object.values(snap.val()).filter(f => f.uid === CU.uid);
      const hasPending = myReqs.some(f => f.status === 'pending');
      if (hasPending) return toast('You already have a pending request. Wait for admin approval.');
    }

    await rtdb.ref('fundRequests').push({
      uid:       CU.uid,
      email:     CU.email || '',
      name:      UD?.fullName || UD?.username || '',
      amount,
      txHash,
      network,
      note,
      status:    'pending',
      createdAt: Date.now()
    });

    toast('✅ Fund request submitted! Admin will approve shortly.');
    document.getElementById('frAmount').value  = '';
    document.getElementById('frTxHash').value  = '';
    document.getElementById('frNote').value    = '';
    document.getElementById('frPreview').style.display = 'none';
    loadFundRequestPage();
  } catch(e) { toast('Error: ' + e.message); }
};
</script>
</body>
</html>