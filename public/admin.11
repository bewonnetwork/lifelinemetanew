<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Life Line Meta – Dashboard</title>
<style>
:root{
  --bg:#0b0f1a;--surface:#111827;--card:#1a2235;--border:#1e2d45;
  --accent:#00c6ff;--accent2:#7c3aed;--gold:#f59e0b;--green:#10b981;
  --red:#ef4444;--text:#e2e8f0;--muted:#64748b;--radius:14px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
button{cursor:pointer;font-family:inherit}

/* SIDEBAR */
.sidebar{position:fixed;top:0;left:0;height:100vh;width:245px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:100;transition:transform .3s}
.logo-area{padding:18px 18px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:11px}
.logo-img{width:42px;height:42px;border-radius:50%;object-fit:cover;border:2px solid var(--accent);flex-shrink:0}
.logo-text h2{font-size:1rem;font-weight:900;background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.logo-text p{font-size:.62rem;color:var(--muted);margin-top:1px}
nav{flex:1;padding:8px 0;overflow-y:auto}
nav a{display:flex;align-items:center;gap:10px;padding:10px 18px;font-size:.82rem;color:var(--muted);border-left:3px solid transparent;transition:.2s;cursor:pointer;user-select:none}
nav a:hover{color:var(--text);background:rgba(0,198,255,.05)}
nav a.active{color:var(--text);background:rgba(0,198,255,.07);border-left-color:var(--accent)}
nav a .ic{width:17px;text-align:center;font-size:.9rem}
.sb-footer{padding:13px 18px;border-top:1px solid var(--border)}
.user-mini{display:flex;align-items:center;gap:9px}
.av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.82rem;color:#fff;flex-shrink:0}
.um-info strong{font-size:.79rem;display:block;max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.um-info span{font-size:.66rem;color:var(--muted)}

/* TOPBAR */
.topbar{position:fixed;top:0;left:245px;right:0;height:56px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 20px;z-index:99;transition:left .3s}
.menu-btn{display:none;background:none;border:none;color:var(--text);font-size:1.3rem;padding:4px 8px}
.pg-label{font-size:.87rem;font-weight:700;color:var(--muted)}
.tb-right{display:flex;align-items:center;gap:10px}
.theme-btn{background:none;border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:5px 11px;font-size:.76rem;cursor:pointer}

/* MAIN */
.main{margin-left:245px;padding-top:56px;min-height:100vh;transition:margin-left .3s}
.page{display:none;padding:20px}
.page.active{display:block}
.pg-title{font-size:1.25rem;font-weight:800;margin-bottom:16px}
.pg-title span{font-size:.8rem;color:var(--muted);font-weight:400;margin-left:6px}

/* BANNER */
.banner{border-radius:12px;padding:13px 16px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.banner-warn{background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.25)}

/* CARDS */
.cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:13px;margin-bottom:18px}
.sc{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;position:relative;overflow:hidden}
.sc::before{content:'';position:absolute;top:-20px;right:-20px;width:75px;height:75px;border-radius:50%;opacity:.07}
.sc.cb::before{background:var(--accent)}.sc.cp::before{background:var(--accent2)}.sc.cg::before{background:var(--gold)}.sc.cgr::before{background:var(--green)}
.sc-lbl{font-size:.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px}
.sc-val{font-size:1.6rem;font-weight:800;margin-bottom:2px}
.cb .sc-val{color:var(--accent)}.cp .sc-val{color:var(--accent2)}.cg .sc-val{color:var(--gold)}.cgr .sc-val{color:var(--green)}
.sc-sub{font-size:.7rem;color:var(--muted)}
.sc-ic{position:absolute;bottom:12px;right:12px;font-size:1.4rem;opacity:.2}

/* PROGRESS */
.prog{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:7px}
.prog-f{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:2px;transition:width .5s}

/* CARD */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:14px}
.card-title{font-size:.87rem;font-weight:700;margin-bottom:11px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px}
.card-title small{font-size:.7rem;color:var(--muted);font-weight:400}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-bottom:14px}

/* TABLE */
.tw{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:.78rem}
th{color:var(--muted);font-weight:600;padding:7px 10px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap;font-size:.7rem;text-transform:uppercase;letter-spacing:.3px}
td{padding:9px 10px;border-bottom:1px solid rgba(30,45,69,.4);white-space:nowrap;vertical-align:middle}
tr:last-child td{border-bottom:none}
.pill{display:inline-block;padding:2px 8px;border-radius:20px;font-size:.68rem;font-weight:700}
.pg{background:rgba(16,185,129,.15);color:var(--green)}
.py{background:rgba(245,158,11,.15);color:var(--gold)}
.pr{background:rgba(239,68,68,.15);color:var(--red)}
.pb{background:rgba(0,198,255,.15);color:var(--accent)}
.pp{background:rgba(124,58,237,.15);color:var(--accent2)}

/* FORM */
.fg{margin-bottom:13px}
.fg label{display:block;font-size:.73rem;color:var(--muted);margin-bottom:4px;font-weight:600}
.fg input,.fg select{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:9px 12px;color:var(--text);font-size:.85rem;outline:none;transition:.2s}
.fg input:focus,.fg select:focus{border-color:var(--accent)}

/* BUTTONS */
.btn{padding:8px 16px;border-radius:9px;font-size:.79rem;font-weight:700;border:none;cursor:pointer;transition:.15s}
.btn:hover{opacity:.85}
.btn-p{background:linear-gradient(90deg,var(--accent),var(--accent2));color:#fff}
.btn-g{background:linear-gradient(90deg,var(--gold),#d97706);color:#000}
.btn-gr{background:var(--green);color:#fff}
.btn-o{background:none;border:1px solid var(--border);color:var(--text)}
.btn-r{background:var(--red);color:#fff}
.btn-sm{padding:3px 9px;font-size:.7rem}

/* REF BOX */
.ref-box{background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:10px 13px;display:flex;align-items:center;gap:9px}
.ref-box input{flex:1;background:none;border:none;color:var(--text);font-size:.78rem;outline:none}

/* INFO BOX */
.info-box{background:rgba(0,198,255,.05);border:1px solid rgba(0,198,255,.15);border-radius:9px;padding:11px 14px;font-size:.77rem;color:var(--accent);margin-bottom:13px;line-height:1.7}

/* BINARY TREE */
.tree-container{overflow-x:auto;padding:10px 0;min-height:200px}
.tree-node{display:flex;flex-direction:column;align-items:center;position:relative}
.tree-box{background:var(--bg);border:2px solid var(--border);border-radius:10px;padding:8px 12px;text-align:center;min-width:90px;font-size:.73rem;cursor:default;transition:.2s;position:relative}
.tree-box:hover{border-color:var(--accent);background:rgba(0,198,255,.05)}
.tree-box.active-node{border-color:var(--green)}
.tree-box.you-node{border-color:var(--accent);background:rgba(0,198,255,.08)}
.tree-box.empty-node{border-style:dashed;border-color:var(--muted);opacity:.4}
.tree-name{font-weight:700;font-size:.75rem;max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tree-status{font-size:.62rem;margin-top:1px}
.tree-children{display:flex;gap:30px;margin-top:0;position:relative;padding-top:20px}
.tree-connector{position:absolute;top:0;left:50%;width:1px;height:20px;background:var(--border);transform:translateX(-50%)}
.tree-h-line{position:absolute;top:0;height:1px;background:var(--border)}

/* RANK */
.rank-stars{font-size:1.5rem;letter-spacing:3px;margin:6px 0 3px}
.rank-name-d{font-size:.93rem;font-weight:800;color:var(--gold)}
.rank-bar-row{display:flex;align-items:center;gap:8px;margin-bottom:8px;font-size:.74rem}
.rank-bar-row .rl{width:85px;color:var(--muted)}
.rank-bar-row .rv{width:85px;text-align:right;color:var(--muted);font-size:.7rem}

/* WALLET */
.wal-bal{font-size:2rem;font-weight:800;color:var(--green)}

/* OVERLAY & TOAST */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:99}
.overlay.show{display:block}
.toast{position:fixed;bottom:20px;right:20px;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 16px;font-size:.81rem;z-index:9999;opacity:0;transform:translateY(14px);transition:.3s;pointer-events:none;max-width:270px}
.toast.show{opacity:1;transform:translateY(0)}

body.light{--bg:#f1f5f9;--surface:#fff;--card:#f8fafc;--border:#e2e8f0;--text:#1e293b;--muted:#64748b}

@media(max-width:768px){
  .sidebar{transform:translateX(-100%)}
  .sidebar.open{transform:translateX(0)}
  .main{margin-left:0}
  .topbar{left:0}
  .menu-btn{display:block}
  .two-col{grid-template-columns:1fr}
  .cards-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:440px){.cards-grid{grid-template-columns:1fr}}
</style>
</head>
<body>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <div class="logo-area">
    <img src="assets/images/logo.jpeg" alt="LLM"
         class="logo-img"
         onerror="this.onerror=null;this.src='assets/logo/livelinemeta.png';this.onerror=function(){this.style.display='none'}">
    <div class="logo-text">
      <h2>Life Line Meta</h2>
      <p>MLM + ROI Platform</p>
    </div>
  </div>
  <nav>
    <a class="active" onclick="showPage('overview',this)"><span class="ic">🏠</span> Overview</a>
    <a onclick="showPage('profile',this)"><span class="ic">👤</span> Profile</a>
    <a onclick="showPage('referral',this)"><span class="ic">🔗</span> Referral</a>
    <a onclick="showPage('tree',this)"><span class="ic">🌳</span> Binary Tree</a>
    <a onclick="showPage('team',this)"><span class="ic">👥</span> My Team</a>
    <a onclick="showPage('income',this)"><span class="ic">💰</span> Income Report</a>
    <a onclick="showPage('roi',this)"><span class="ic">📈</span> ROI Investment</a>
    <a onclick="showPage('wallet',this)"><span class="ic">💳</span> Wallet</a>
    <a onclick="showPage('rank',this)"><span class="ic">⭐</span> Rank Progress</a>
    <a onclick="showPage('cashback',this)"><span class="ic">🎁</span> Cashback Pool</a>
    <a onclick="showPage('club',this)"><span class="ic">🏆</span> Club Bonus</a>
    <a onclick="showPage('activation',this)"><span class="ic">✅</span> Activation</a>
    <a onclick="showPage('fundrequest',this)"><span class="ic">💳</span> Fund Request <span id="frPendingBadge" style="display:none;background:var(--red);color:#fff;border-radius:10px;padding:1px 6px;font-size:.62rem;margin-left:auto"></span></a>
    <a onclick="doLogout()" style="color:var(--red);margin-top:6px"><span class="ic">🚪</span> Logout</a>
  </nav>
  <div class="sb-footer">
    <div class="user-mini">
      <div class="av" id="avInit">U</div>
      <div class="um-info">
        <strong id="sbName">Loading…</strong>
        <span id="sbStatus">—</span>
      </div>
    </div>
  </div>
</aside>

<!-- TOPBAR -->
<div class="topbar">
  <div style="display:flex;align-items:center;gap:9px">
    <button class="menu-btn" onclick="toggleSidebar()">☰</button>
    <span class="pg-label" id="pgLabel">Overview</span>
  </div>
  <div class="tb-right">
    <button class="theme-btn" onclick="toggleTheme()" id="themeBtn">☀️ Light</button>
    <button class="btn btn-o btn-sm" onclick="doLogout()">Logout</button>
  </div>
</div>

<main class="main">

<!-- ===== OVERVIEW ===== -->
<div class="page active" id="page-overview">
  <div class="pg-title">Overview <span id="greetMsg"></span></div>

  <div id="actBanner" class="banner banner-warn" style="display:none">
    <div>
      <strong style="color:var(--gold)">⚠️ Account Not Activated</strong><br>
      <small style="color:var(--muted)">Pay $30 to unlock all income features</small>
    </div>
    <button class="btn btn-g btn-sm" onclick="showPage('activation',null)">Activate Now →</button>
  </div>

  <div class="cards-grid">
    <div class="sc cb">
      <div class="sc-lbl">Total Income</div>
      <div class="sc-val" id="ovTotal">$0.00</div>
      <div class="sc-sub">Lifetime earnings</div>
      <div class="sc-ic">💵</div>
    </div>
    <div class="sc cp">
      <div class="sc-lbl">Wallet Balance</div>
      <div class="sc-val" id="ovWallet">$0.00</div>
      <div class="sc-sub">Available</div>
      <div class="sc-ic">💳</div>
    </div>
    <div class="sc cg">
      <div class="sc-lbl">Direct Referrals</div>
      <div class="sc-val" id="ovDirRef">0</div>
      <div class="sc-sub" id="ovDirRefSub">0 active</div>
      <div class="sc-ic">👥</div>
    </div>
    <div class="sc cgr">
      <div class="sc-lbl">Matching Income</div>
      <div class="sc-val" id="ovMatch">$0.00</div>
      <div class="sc-sub">Cap: $1,000</div>
      <div class="sc-ic">🤝</div>
      <div class="prog"><div class="prog-f" id="ovMatchP" style="width:0%"></div></div>
    </div>
  </div>

  <div class="two-col">
    <div class="card">
      <div class="card-title">Income Breakdown</div>
      <div class="tw">
        <table>
          <thead><tr><th>Type</th><th>Amount</th><th>Status</th></tr></thead>
          <tbody>
            <tr><td>Sponsor Commission</td><td id="ibSponsor">$0.00</td><td><span class="pill pg">Active</span></td></tr>
            <tr><td>Matching Bonus</td><td id="ibMatch">$0.00</td><td><span class="pill pg">Active</span></td></tr>
            <tr><td>Daily Cashback</td><td id="ibCashback">$0.00</td><td><span class="pill pb">Pool</span></td></tr>
            <tr><td>Club Bonus</td><td id="ibClub">$0.00</td><td><span class="pill py">Check</span></td></tr>
            <tr><td>ROI Returns</td><td id="ibRoi">$0.00</td><td><span class="pill pg">Active</span></td></tr>
            <tr><td>Generation Bonus</td><td id="ibGen">$0.00</td><td><span class="pill pb">7 Lvls</span></td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div class="card">
      <div class="card-title">Recent Transactions</div>
      <div class="tw">
        <table>
          <thead><tr><th>Date</th><th>Type</th><th>Amount</th></tr></thead>
          <tbody id="ovRecentTx">
            <tr><td colspan="3" style="text-align:center;color:var(--muted);padding:16px">No transactions yet</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- ===== PROFILE ===== -->
<div class="page" id="page-profile">
  <div class="pg-title">My Profile</div>
  <div style="max-width:540px">
    <div class="card">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px">
        <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:1.7rem;color:#fff;font-weight:800;flex-shrink:0" id="pfAv">U</div>
        <div>
          <div style="font-size:1.05rem;font-weight:800" id="pfNameD">—</div>
          <div style="color:var(--muted);font-size:.78rem" id="pfEmailD">—</div>
          <div id="pfBadge" style="margin-top:5px"></div>
        </div>
      </div>
      <div class="fg"><label>Full Name</label><input type="text" id="pfName" placeholder="Full name"/></div>
      <div class="fg"><label>Username</label><input type="text" id="pfUsername" readonly style="opacity:.6"/></div>
      <div class="fg"><label>Phone</label><input type="text" id="pfPhone" placeholder="+880 …"/></div>
      <div class="fg"><label>Country</label><input type="text" id="pfCountry" placeholder="Country" readonly style="opacity:.6"/></div>
      <div class="fg"><label>USDT TRC20 Wallet</label><input type="text" id="pfWallet" placeholder="T… wallet address"/></div>
      <button class="btn btn-p" onclick="saveProfile()">💾 Save Profile</button>
    </div>
    <div class="card">
      <div class="card-title">Account Info</div>
      <table style="width:100%;font-size:.8rem">
        <tr><td style="color:var(--muted);padding:6px 0;width:120px">Member ID</td><td id="infoUID" style="font-family:monospace;font-size:.72rem;word-break:break-all">—</td></tr>
        <tr><td style="color:var(--muted);padding:6px 0">Username</td><td id="infoUsername">—</td></tr>
        <tr><td style="color:var(--muted);padding:6px 0">Sponsor</td><td id="infoSponsor">—</td></tr>
        <tr><td style="color:var(--muted);padding:6px 0">Joined</td><td id="infoJoined">—</td></tr>
        <tr><td style="color:var(--muted);padding:6px 0">Rank</td><td id="infoRank">No Rank</td></tr>
        <tr><td style="color:var(--muted);padding:6px 0">Status</td><td id="infoStatus">—</td></tr>
        <tr><td style="color:var(--muted);padding:6px 0">Signup Method</td><td id="infoMethod">—</td></tr>
      </table>
    </div>
  </div>
</div>

<!-- ===== REFERRAL ===== -->
<div class="page" id="page-referral">
  <div class="pg-title">Referral Program</div>
  <div class="two-col" style="max-width:840px">
    <div class="card">
      <div class="card-title">Your Referral Link</div>
      <div class="ref-box">
        <input type="text" id="refLinkInput" readonly/>
        <button class="btn btn-p btn-sm" onclick="copyRef()">Copy</button>
      </div>
      <div style="font-size:.7rem;color:var(--muted);margin-top:7px">Earn <strong style="color:var(--green)">$4</strong> for every activated referral</div>
      <div style="display:flex;gap:7px;margin-top:12px;flex-wrap:wrap">
        <button class="btn btn-o btn-sm" onclick="shareWA()">📲 WhatsApp</button>
        <button class="btn btn-o btn-sm" onclick="shareTG()">✈️ Telegram</button>
        <button class="btn btn-o btn-sm" onclick="copyRef()">📋 Copy</button>
      </div>
    </div>
    <div class="card">
      <div class="card-title">Commission Structure</div>
      <table style="font-size:.79rem;width:100%">
        <tr><td style="color:var(--muted);padding:6px 0">Activation Fee</td><td style="color:var(--accent);font-weight:700">$30</td></tr>
        <tr><td style="color:var(--muted);padding:6px 0">Sponsor Commission</td><td style="color:var(--green);font-weight:700">$4 / referral</td></tr>
        <tr><td style="color:var(--muted);padding:6px 0">Matching Bonus</td><td style="color:var(--gold);font-weight:700">5%</td></tr>
        <tr><td style="color:var(--muted);padding:6px 0">Capping Limit</td><td style="color:var(--red);font-weight:700">$1,000</td></tr>
        <tr><td style="color:var(--muted);padding:6px 0">ROI Referral Bonus</td><td style="color:var(--accent2);font-weight:700">$5 / investor</td></tr>
      </table>
    </div>
  </div>
  <div class="card" style="max-width:840px">
    <div class="card-title">Direct Referrals <small id="refCountLbl">0 total</small></div>
    <div class="tw">
      <table>
        <thead><tr><th>Name</th><th>Username</th><th>Email</th><th>Joined</th><th>Status</th><th>Comm.</th></tr></thead>
        <tbody id="refTbody">
          <tr><td colspan="6" style="text-align:center;color:var(--muted);padding:16px">No referrals yet</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ===== BINARY TREE ===== -->
<div class="page" id="page-tree">
  <div class="pg-title">Binary Tree</div>
  <div class="info-box">🌳 Binary placement tree — Left and Right legs. Green border = active member. Dashed = empty slot.</div>
  <div class="cards-grid" style="max-width:600px;margin-bottom:16px">
    <div class="sc cb"><div class="sc-lbl">Left Leg</div><div class="sc-val" id="treeLeftCount">0</div><div class="sc-sub">Members</div></div>
    <div class="sc cp"><div class="sc-lbl">Right Leg</div><div class="sc-val" id="treeRightCount">0</div><div class="sc-sub">Members</div></div>
    <div class="sc cg"><div class="sc-lbl">Weaker Leg</div><div class="sc-val" id="treeWeakerLeg">—</div><div class="sc-sub">For matching</div></div>
  </div>
  <div class="card">
    <div class="card-title">Tree View <small>3 levels shown</small></div>
    <div class="tree-container" id="treeContainer">
      <div style="text-align:center;color:var(--muted);padding:30px">Loading tree…</div>
    </div>
  </div>
  <div class="card" style="margin-top:0">
    <div class="card-title">All Downline Members</div>
    <div class="tw">
      <table>
